---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const {
  title = 'Ι.Ν. Ἁγίου Ἀνδρέου Πατρῶν',
  description = 'Τρισδιάστατη ἐκπαιδευτικὴ ἐφαρμογὴ γιὰ τὸν Καθεδρικὸ Ναὸ τοῦ Πρωτοκλήτου Ἀποστόλου Ἀνδρέου τῶν Πατρῶν.',
  hideHeader = false,
  hideFooter = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0c0604" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <title>{title}</title>
</head>
<body>
  {!hideHeader && <Header />}
  <main class="page-main">
    <slot />
  </main>
  {!hideFooter && <Footer />}
</body>
</html>

<style is:global>
  .page-main {
    position: relative;
    z-index: 3;
    min-height: calc(100vh - var(--nav-h));
    padding-top: var(--nav-h);
  }
</style>
