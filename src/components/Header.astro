---
import { NAV } from '../data/nav';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand" aria-label="ἀρχή">
      <span class="brand-orn">✦</span>
      <span class="brand-text">
        <span class="brand-eyebrow">Three.js · WebXR · Educational</span>
        <span class="brand-name">Ἅγιος Ἀνδρέας</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="κύρια πλοήγησις">
      {NAV.filter(n => n.href !== '/').map(item => (
        <a
          href={item.href}
          class={`nav-link${path === item.href ? ' active' : ''}`}
          data-label={item.label}
        >
          <span class="nav-greek">{item.greek}</span>
          <span class="nav-lbl">{item.label}</span>
        </a>
      ))}
    </nav>

    <button class="nav-toggle" id="nav-toggle" aria-label="μενοῦ">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    z-index: 20;
    background: linear-gradient(180deg, rgba(8,4,2,0.92) 0%, rgba(8,4,2,0.55) 70%, rgba(8,4,2,0) 100%);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid rgba(217,180,120,0.12);
  }
  .header-row {
    display: flex; align-items: center; gap: 24px;
    height: 100%;
  }
  .brand {
    display: flex; align-items: center; gap: 12px;
    text-decoration: none;
    color: var(--gold-mid);
    transition: opacity 0.3s;
  }
  .brand:hover { opacity: 0.82; }
  .brand-orn {
    font-size: 22px;
    color: var(--gold-pale);
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.7));
  }
  .brand-text {
    display: flex; flex-direction: column; gap: 1px;
    line-height: 1.05;
  }
  .brand-eyebrow {
    font-family: var(--sans);
    font-size: 8px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 600;
  }
  .brand-name {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 21px;
    color: var(--gold-bright);
    letter-spacing: 0.005em;
  }

  .primary-nav {
    display: flex; align-items: center; gap: 4px;
    margin-left: auto;
  }
  .nav-link {
    position: relative;
    display: flex; flex-direction: column; align-items: center;
    padding: 8px 14px;
    text-decoration: none;
    line-height: 1.1;
    border-radius: var(--radius-s);
    transition: all 0.28s;
  }
  .nav-link:hover { background: rgba(217,180,120,0.07); }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 50%;
    transform: translateX(-50%);
    width: 16px; height: 1px;
    background: var(--gold-bright);
  }
  .nav-greek {
    font-family: var(--serif);
    font-size: 15px;
    font-style: italic;
    color: var(--gold-mid);
  }
  .nav-link.active .nav-greek { color: var(--gold-bright); }
  .nav-lbl {
    font-family: var(--sans);
    font-size: 7px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin-top: 1px;
    font-weight: 600;
  }

  .nav-toggle {
    display: none;
    flex-direction: column; gap: 4px;
    width: 32px; height: 32px;
    background: transparent;
    border: 1px solid rgba(217,180,120,0.25);
    border-radius: var(--radius-s);
    padding: 7px;
    cursor: pointer;
    margin-left: auto;
  }
  .nav-toggle span {
    display: block;
    width: 100%; height: 1.5px;
    background: var(--gold-mid);
    transition: all 0.25s;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  @media (max-width: 860px) {
    .primary-nav {
      position: absolute;
      top: var(--nav-h); left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      padding: 14px;
      background: rgba(8,4,2,0.97);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(217,180,120,0.15);
      transform: translateY(-110%);
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    .primary-nav.open { transform: translateY(0); }
    .nav-link { flex-direction: row; justify-content: space-between; padding: 14px; }
    .nav-toggle { display: flex; }
    .nav-link.active::after { display: none; }
    .nav-link.active { background: rgba(217,180,120,0.08); }
  }
</style>

<script is:inline>
  (() => {
    const toggle = document.getElementById('nav-toggle');
    const nav = document.querySelector('.primary-nav');
    if (!toggle || !nav) return;
    toggle.addEventListener('click', () => {
      toggle.classList.toggle('open');
      nav.classList.toggle('open');
    });
    nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      toggle.classList.remove('open');
      nav.classList.remove('open');
    }));
  })();
</script>
