---
import BaseLayout from '../layouts/BaseLayout.astro';
import { QUIZ } from '../data/quiz';
---

<BaseLayout
  title="Γνώρισέ τον · Ἅγιος Ἀνδρέας"
  description="Ἐκπαιδευτικὸ μίνι-παιχνίδι μὲ ἐρωτήσεις γιὰ τὴν ἱστορία τοῦ Ναοῦ."
>
  <section class="section">
    <div class="container">
      <div class="eyebrow">ἐκπαιδευτικὸ μίνι-παιχνίδι</div>
      <h1>Γνώρισέ τον <em>τὸν ναό</em></h1>
      <hr class="rule" />
      <p class="lead">
        Δώδεκα ἐρωτήσεις γιὰ τὴν ἱστορία, τὰ πρόσωπα καὶ τὴν ἀρχιτεκτονικὴ τοῦ Καθεδρικοῦ Ναοῦ.
        Πάτησε <b>ἔναρξις</b> γιὰ νὰ ξεκινήσεις.
      </p>

      <div class="quiz" id="quiz">
        <!-- Welcome screen -->
        <div class="quiz-screen welcome" data-screen="welcome">
          <div class="welcome-orn">✦</div>
          <h2 class="serif italic">12 ἐρωτήσεις · 4 ἀπαντήσεις ἀνὰ ἐρώτησιν</h2>
          <p class="lead">Πέρνα τὶς ἐρωτήσεις τὴ μία μετὰ τὴν ἄλλη. Στὸ τέλος βλέπεις τὸ σκὸρ καὶ ποιὲς ἀπάντησες σωστά.</p>
          <div class="quiz-categories">
            <span class="qchip">χρονολογίες</span>
            <span class="qchip">πρόσωπα</span>
            <span class="qchip">ἀρχιτεκτονική</span>
            <span class="qchip">ἱστορία</span>
          </div>
          <button class="btn primary" id="start-btn">
            <span>ἔναρξις</span>
            <span class="arrow">→</span>
          </button>
        </div>

        <!-- Question screen -->
        <div class="quiz-screen question hidden" data-screen="question">
          <div class="q-progress">
            <div class="q-progress-row">
              <span class="q-pos"><em id="q-pos-num">1</em> / <span id="q-pos-tot">12</span></span>
              <span class="q-cat" id="q-cat">—</span>
            </div>
            <div class="q-progress-bar"><div class="q-progress-fill" id="q-fill"></div></div>
          </div>

          <h2 class="q-prompt" id="q-prompt">—</h2>

          <div class="q-options" id="q-options">
            <!-- buttons injected by JS -->
          </div>

          <div class="q-feedback" id="q-feedback" aria-live="polite">
            <div class="q-feedback-tag" id="q-tag">—</div>
            <p class="q-explanation" id="q-explanation">—</p>
            <button class="btn" id="q-next-btn">
              <span>ἑπόμενη</span>
              <span class="arrow">→</span>
            </button>
          </div>
        </div>

        <!-- Result screen -->
        <div class="quiz-screen result hidden" data-screen="result">
          <div class="result-score">
            <div class="score-ring" id="score-ring">
              <svg viewBox="0 0 120 120" aria-hidden="true">
                <circle cx="60" cy="60" r="54" class="ring-bg" />
                <circle cx="60" cy="60" r="54" class="ring-fg" id="ring-fg" />
              </svg>
              <div class="score-text">
                <div class="score-num" id="score-num">0</div>
                <div class="score-tot">/ <span id="score-tot">12</span></div>
              </div>
            </div>
            <div class="score-msg">
              <h2 class="serif italic" id="score-msg-h">Καλὴ προσπάθεια!</h2>
              <p id="score-msg-p">—</p>
            </div>
          </div>

          <hr class="rule center" />

          <h3>Ἀνάλυσις τῶν ἀπαντήσεων</h3>
          <div class="results-list" id="results-list">
            <!-- injected -->
          </div>

          <div class="result-actions">
            <button class="btn" id="restart-btn">↺ ἀρχίζω πάλι</button>
            <a class="btn ghost" href="/chronicle">διάβασε τὸ χρονικό →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  h1 em { font-style: italic; color: var(--gold-pale); }

  .quiz {
    margin-top: clamp(36px, 5vw, 56px);
    background: rgba(20,12,6,0.5);
    border: 1px solid rgba(217,180,120,0.18);
    border-radius: var(--radius-m);
    padding: clamp(28px, 4vw, 48px);
    min-height: 480px;
    position: relative;
  }
  .quiz-screen.hidden { display: none; }

  .welcome { text-align: center; max-width: 560px; margin: 0 auto; padding: 24px 0; }
  .welcome-orn { font-size: 48px; color: var(--gold-pale); margin-bottom: 18px; filter: drop-shadow(0 3px 6px rgba(0,0,0,0.5)); }
  .welcome h2 { font-size: clamp(20px, 2.6vw, 28px); margin-bottom: 14px; }
  .welcome .lead { margin-bottom: 28px; }
  .quiz-categories { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 36px; }
  .qchip {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-deep);
    padding: 5px 11px;
    background: rgba(154,103,48,0.15);
    border: 1px solid rgba(217,180,120,0.22);
    border-radius: var(--radius-pill);
    font-weight: 600;
  }

  /* QUESTION */
  .question { display: flex; flex-direction: column; gap: 24px; }

  .q-progress-row {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .q-pos em { font-style: italic; color: var(--gold-bright); font-size: 18px; font-family: var(--serif); padding-right: 4px; }
  .q-cat { color: var(--gold-mid); }
  .q-progress-bar { height: 3px; background: rgba(217,180,120,0.12); border-radius: 2px; overflow: hidden; }
  .q-progress-fill {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--gold-deep), var(--gold-bright));
    border-radius: 2px;
    transition: width 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .q-prompt {
    font-size: clamp(22px, 3vw, 32px);
    color: var(--gold-bright);
    line-height: 1.25;
    margin-top: 6px;
  }

  .q-options {
    display: grid;
    gap: 12px;
  }
  .opt {
    display: grid;
    grid-template-columns: 36px 1fr 28px;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: rgba(8,4,2,0.5);
    border: 1px solid rgba(217,180,120,0.2);
    border-radius: var(--radius-m);
    color: var(--gold-mid);
    font-family: var(--sans);
    font-size: 14px;
    cursor: pointer;
    text-align: left;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .opt:hover:not(:disabled) {
    background: rgba(217,180,120,0.08);
    border-color: rgba(217,180,120,0.5);
    transform: translateX(3px);
  }
  .opt:disabled { cursor: not-allowed; }
  .opt .opt-letter {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--gold-deep);
    line-height: 1;
    text-align: center;
  }
  .opt .opt-mark { text-align: right; font-size: 17px; opacity: 0; transition: opacity 0.25s; line-height: 1; }
  .opt.correct {
    background: rgba(95,160,90,0.18);
    border-color: rgba(140,210,130,0.55);
    color: #d8f0c8;
  }
  .opt.correct .opt-letter { color: #aedb9e; }
  .opt.correct .opt-mark { opacity: 1; color: #aedb9e; }
  .opt.wrong {
    background: rgba(180,70,60,0.18);
    border-color: rgba(220,110,90,0.55);
    color: #f3c4b8;
  }
  .opt.wrong .opt-letter { color: #e09a8a; }
  .opt.wrong .opt-mark { opacity: 1; color: #e09a8a; }

  .q-feedback {
    display: none;
    padding: 18px 20px;
    background: rgba(8,4,2,0.6);
    border: 1px solid rgba(217,180,120,0.2);
    border-radius: var(--radius-m);
    margin-top: 4px;
    animation: fadeUp 0.42s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .q-feedback.visible { display: block; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .q-feedback-tag {
    display: inline-block;
    padding: 4px 11px;
    background: rgba(154,103,48,0.5);
    color: var(--gold-bright);
    font-size: 9px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 600;
    border-radius: var(--radius-pill);
    margin-bottom: 10px;
  }
  .q-feedback-tag.correct { background: rgba(110,180,100,0.45); color: #fff; }
  .q-feedback-tag.wrong   { background: rgba(190,90,80,0.45); color: #fff; }
  .q-explanation { font-size: 14px; line-height: 1.7; color: var(--gold-mid); margin-bottom: 16px; }
  .q-feedback .btn { margin-top: 8px; }

  /* RESULT */
  .result-score {
    display: flex;
    align-items: center;
    gap: clamp(20px, 4vw, 40px);
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 32px;
  }
  .score-ring { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
  .score-ring svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .score-ring .ring-bg, .score-ring .ring-fg {
    fill: none; stroke-width: 7;
  }
  .score-ring .ring-bg { stroke: rgba(217,180,120,0.15); }
  .score-ring .ring-fg {
    stroke: url(#ring-grad);
    stroke: var(--gold-bright);
    stroke-linecap: round;
    stroke-dasharray: 339;        /* 2π × 54 */
    stroke-dashoffset: 339;
    transition: stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 0 8px rgba(255,220,150,0.5));
  }
  .score-text {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    line-height: 1;
  }
  .score-num { font-family: var(--serif); font-size: 48px; color: var(--gold-bright); font-weight: 500; font-variant-numeric: tabular-nums; }
  .score-tot { font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold-deep); margin-top: 6px; font-weight: 600; }

  .score-msg { max-width: 440px; }
  .score-msg h2 { font-size: clamp(22px, 3vw, 32px); margin-bottom: 12px; }
  .score-msg p { font-size: 15px; color: var(--gold-mid); line-height: 1.6; }

  .result-actions {
    display: flex; gap: 12px; flex-wrap: wrap;
    justify-content: center;
    margin-top: 36px;
  }

  .results-list { display: flex; flex-direction: column; gap: 8px; }
  .res-row {
    display: grid;
    grid-template-columns: 32px 1fr 22px;
    gap: 12px;
    align-items: center;
    padding: 11px 14px;
    background: rgba(8,4,2,0.4);
    border: 1px solid rgba(217,180,120,0.12);
    border-radius: var(--radius-s);
    font-size: 13px;
    color: var(--gold-soft);
  }
  .res-row .res-num {
    font-family: var(--serif); font-style: italic;
    font-size: 18px; color: var(--gold-deep);
    text-align: center; line-height: 1;
  }
  .res-row.correct { border-color: rgba(140,210,130,0.3); }
  .res-row.wrong   { border-color: rgba(220,110,90,0.3); }
  .res-row .res-mark { text-align: right; line-height: 1; font-size: 15px; }
  .res-row.correct .res-mark { color: #aedb9e; }
  .res-row.wrong   .res-mark { color: #e09a8a; }

  @media (max-width: 720px) {
    .q-prompt { font-size: 18px; }
    .opt { padding: 12px 14px; font-size: 13px; grid-template-columns: 28px 1fr 22px; gap: 10px; }
    .opt .opt-letter { font-size: 17px; }
  }
</style>

<script>
  import { QUIZ } from '../data/quiz';

  const CAT_LABELS: Record<string, string> = {
    dates: 'χρονολογίες',
    people: 'πρόσωπα',
    architecture: 'ἀρχιτεκτονική',
    history: 'ἱστορία',
  };
  const LETTERS = ['Α', 'Β', 'Γ', 'Δ', 'Ε', 'ϛ'];

  type Screen = 'welcome' | 'question' | 'result';

  interface Answer { questionId: string; selectedIdx: number; correct: boolean; }
  const answers: Answer[] = [];
  let current = 0;

  function showScreen(name: Screen) {
    document.querySelectorAll<HTMLElement>('.quiz-screen').forEach(s => {
      s.classList.toggle('hidden', s.dataset.screen !== name);
    });
  }

  function renderQuestion(idx: number) {
    const q = QUIZ[idx];
    if (!q) return showResult();
    current = idx;

    const totalEl = document.getElementById('q-pos-tot');
    if (totalEl) totalEl.textContent = String(QUIZ.length);
    const numEl = document.getElementById('q-pos-num');
    if (numEl) numEl.textContent = String(idx + 1);
    const catEl = document.getElementById('q-cat');
    if (catEl) catEl.textContent = CAT_LABELS[q.category] || q.category;
    const fillEl = document.getElementById('q-fill') as HTMLElement | null;
    if (fillEl) fillEl.style.width = (idx / QUIZ.length * 100) + '%';
    const promptEl = document.getElementById('q-prompt');
    if (promptEl) promptEl.textContent = q.prompt;

    const optsContainer = document.getElementById('q-options');
    if (optsContainer) {
      optsContainer.innerHTML = q.options.map((opt, i) => `
        <button class="opt" data-i="${i}">
          <span class="opt-letter">${LETTERS[i] || (i + 1)}</span>
          <span class="opt-text">${opt}</span>
          <span class="opt-mark"></span>
        </button>
      `).join('');
      optsContainer.querySelectorAll<HTMLButtonElement>('.opt').forEach(btn => {
        btn.addEventListener('click', () => handleAnswer(parseInt(btn.dataset.i || '0', 10)));
      });
    }

    const fb = document.getElementById('q-feedback');
    if (fb) fb.classList.remove('visible');
  }

  function handleAnswer(selectedIdx: number) {
    const q = QUIZ[current];
    const correct = selectedIdx === q.correctIdx;
    answers.push({ questionId: q.id, selectedIdx, correct });

    const opts = document.querySelectorAll<HTMLButtonElement>('#q-options .opt');
    opts.forEach((btn, i) => {
      btn.disabled = true;
      if (i === q.correctIdx) {
        btn.classList.add('correct');
        btn.querySelector('.opt-mark')!.textContent = '✓';
      } else if (i === selectedIdx) {
        btn.classList.add('wrong');
        btn.querySelector('.opt-mark')!.textContent = '✕';
      }
    });

    const tag = document.getElementById('q-tag');
    const expl = document.getElementById('q-explanation');
    if (tag) {
      tag.textContent = correct ? 'σωστά!' : 'λάθος';
      tag.className = 'q-feedback-tag ' + (correct ? 'correct' : 'wrong');
    }
    if (expl) expl.textContent = q.explanation;
    const fb = document.getElementById('q-feedback');
    if (fb) fb.classList.add('visible');

    const fillEl = document.getElementById('q-fill') as HTMLElement | null;
    if (fillEl) fillEl.style.width = ((current + 1) / QUIZ.length * 100) + '%';
  }

  function showResult() {
    const correctCount = answers.filter(a => a.correct).length;
    const numEl = document.getElementById('score-num');
    const totEl = document.getElementById('score-tot');
    if (numEl) numEl.textContent = String(correctCount);
    if (totEl) totEl.textContent = String(QUIZ.length);

    const ring = document.getElementById('ring-fg') as SVGCircleElement | null;
    if (ring) {
      const circ = 339;
      const offset = circ * (1 - correctCount / QUIZ.length);
      // trigger transition next tick
      ring.style.strokeDashoffset = String(circ);
      requestAnimationFrame(() => { ring.style.strokeDashoffset = String(offset); });
    }

    const pct = correctCount / QUIZ.length;
    let msgH = 'Καλὴ προσπάθεια!';
    let msgP = 'Δοκίμασε ξανὰ διαβάζοντας τὸ χρονικό.';
    if (pct >= 0.9) { msgH = 'Ἐξαίσιο!'; msgP = 'Γνωρίζεις τὸν ναὸν τοῦ Ἁγίου Ἀνδρέου σὰν εἰδικός.'; }
    else if (pct >= 0.7) { msgH = 'Πολὺ καλά!'; msgP = 'Λίγη ἐπανάληψις καὶ θὰ ἀναμετρηθῆς μὲ τοὺς εἰδικούς.'; }
    else if (pct >= 0.5) { msgH = 'Σχεδὸν τὰ μισά.'; msgP = 'Ρίξε μιὰ ματιὰ στὸ χρονικὸ καὶ προσπάθησε ξανά.'; }
    const msgHEl = document.getElementById('score-msg-h');
    const msgPEl = document.getElementById('score-msg-p');
    if (msgHEl) msgHEl.textContent = msgH;
    if (msgPEl) msgPEl.textContent = msgP;

    const list = document.getElementById('results-list');
    if (list) {
      list.innerHTML = QUIZ.map((q, i) => {
        const a = answers[i];
        const ok = a?.correct ?? false;
        return `
          <div class="res-row ${ok ? 'correct' : 'wrong'}">
            <span class="res-num">${i + 1}</span>
            <span class="res-prompt">${q.prompt}</span>
            <span class="res-mark">${ok ? '✓' : '✕'}</span>
          </div>
        `;
      }).join('');
    }

    showScreen('result');
  }

  function restart() {
    answers.length = 0;
    current = 0;
    showScreen('welcome');
  }

  document.getElementById('start-btn')?.addEventListener('click', () => {
    showScreen('question');
    renderQuestion(0);
  });
  document.getElementById('q-next-btn')?.addEventListener('click', () => {
    if (current + 1 >= QUIZ.length) showResult();
    else renderQuestion(current + 1);
  });
  document.getElementById('restart-btn')?.addEventListener('click', restart);
</script>
