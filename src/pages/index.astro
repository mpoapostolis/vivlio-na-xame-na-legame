---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CHRONICLE, STATS } from '../data/chronicle';
import { PHOTOS } from '../data/photos';

const featurePhotos = [
  PHOTOS.find(p => p.id === 'foundation-ceremony'),
  PHOTOS.find(p => p.id === 'inauguration'),
  PHOTOS.find(p => p.id === 'cross'),
].filter(Boolean) as typeof PHOTOS;

const eras = [
  { year: '1902', label: 'διαγωνισμός' },
  { year: '1908', label: 'θεμελίωσις' },
  { year: '1932', label: 'ἀνοικοδόμησις' },
  { year: '1974', label: 'ἐγκαίνια' },
  { year: '1980', label: 'ὁ σταυρός' },
  { year: '2005', label: 'ἐνθρόνισις' },
];
---

<BaseLayout
  title="Ι.Ν. Ἁγίου Ἀνδρέου Πατρῶν · τὸ χρονικὸ ἀνεγέρσεως"
  description="Τρισδιάστατη ἐκπαιδευτικὴ ἐφαρμογὴ μὲ τὴν ἱστορία τοῦ Καθεδρικοῦ Ναοῦ τοῦ Πρωτοκλήτου Ἀποστόλου Ἀνδρέου τῶν Πατρῶν."
>
  <!-- ============== HERO ============== -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <img src="/photos/church_page-0013.jpg" alt="" />
      <div class="hero-bg-fade"></div>
    </div>

    <div class="container hero-inner">
      <div class="eyebrow hero-eyebrow">three.js · webxr · ἐκπαιδευτικὴ ἐφαρμογή</div>
      <h1 class="hero-title">
        <span class="line"><em>Ἱερὸς</em> Ναός</span>
        <span class="line gold-text">Ἀποστόλου Ἀνδρέου</span>
        <span class="line"><span class="sub">Καθεδρικὸς τῶν Πατρῶν</span></span>
      </h1>

      <div class="hero-rule">
        <span class="orn">✦</span>
        <span class="line"></span>
        <span class="orn">❦</span>
        <span class="line"></span>
        <span class="orn">✦</span>
      </div>

      <p class="hero-lead">
        Ἕνα τρισδιάστατο ἐκπαιδευτικὸ βιβλίο μὲ τὸ χρονικὸ τῆς ἀνεγέρσεως —
        ἀπὸ τὸν διεθνῆ διαγωνισμὸ τοῦ <em>1902</em> ἕως τὶς ἀνακαινίσεις τοῦ 21ου αἰῶνος.
      </p>

      <div class="hero-cta">
        <a href="/book" class="btn primary lg">
          <span>ἀνοίξτε τὸ βιβλίον</span>
          <span class="arrow">→</span>
        </a>
        <a href="/chronicle" class="btn ghost lg">διαβᾶστε τὸ χρονικὸ</a>
      </div>

      <div class="hero-eras" aria-hidden="true">
        {eras.map(e => (
          <div class="era">
            <div class="era-year">{e.year}</div>
            <div class="era-label">{e.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="scroll-hint">
      <span class="lbl">συνεχίστε</span>
      <span class="arrow">↓</span>
    </div>
  </section>

  <!-- ============== APPS GRID ============== -->
  <section class="section apps">
    <div class="container">
      <div class="eyebrow">τέσσερις τρόποι ἀνακαλύψεως</div>
      <h2 class="section-title">Διάλεξε <em>πῶς</em> νὰ τὸν γνωρίσεις</h2>
      <hr class="rule" />

      <div class="apps-grid">
        <a href="/book" class="app-card book">
          <div class="card-symbol">❦</div>
          <div class="card-num">α´</div>
          <h3>Τὸ Βιβλίον</h3>
          <p>Τρισδιάστατο βιβλίο μὲ φυσικὸ γύρισμα σελίδων. Φωτογραφίες σὲ μεγέθυνσιν μὲ keyframes.</p>
          <div class="card-meta">
            <span>three.js</span><span>·</span><span>WebGPU</span><span>·</span><span>WebXR</span>
          </div>
          <span class="card-go">εἴσοδος στὴν σκηνὴν →</span>
        </a>

        <a href="/chronicle" class="app-card chronicle">
          <div class="card-symbol">⌘</div>
          <div class="card-num">β´</div>
          <h3>Τὸ Χρονικόν</h3>
          <p>Ἀνάγνωσις γραμμικὰ τῶν γεγονότων κατὰ σειρὰν χρόνου. Mobile-friendly μὲ ἀφήγησιν.</p>
          <div class="card-meta">
            <span>{CHRONICLE.length} γεγονότα</span><span>·</span><span>πολυτονικὸ</span>
          </div>
          <span class="card-go">διαβᾶστε →</span>
        </a>

        <a href="/gallery" class="app-card gallery">
          <div class="card-symbol">◈</div>
          <div class="card-num">γ´</div>
          <h3>Ἡ Συλλογή</h3>
          <p>Πέντε θεματικὲς κατηγορίες φωτογραφιῶν ἀπὸ τὸ ἀρχεῖο τοῦ Ναοῦ. Φιλτράρισμα ἀνὰ ἐποχή.</p>
          <div class="card-meta">
            <span>{PHOTOS.length} φωτογραφίες</span><span>·</span><span>5 κατηγορίες</span>
          </div>
          <span class="card-go">περιηγηθεῖτε →</span>
        </a>

        <a href="/quiz" class="app-card quiz">
          <div class="card-symbol">◉</div>
          <div class="card-num">δ´</div>
          <h3>Γνώρισέ τον</h3>
          <p>Ἐκπαιδευτικὸ μίνι-παιχνίδι μὲ ἐρωτήσεις γιὰ χρονολογίες, πρόσωπα, ἀρχιτεκτονικὴ καὶ ἱστορία.</p>
          <div class="card-meta">
            <span>12 ἐρωτήσεις</span><span>·</span><span>4 κατηγορίες</span>
          </div>
          <span class="card-go">δοκιμᾶστε →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== STATS STRIP ============== -->
  <section class="section-tight">
    <div class="container">
      <div class="stats">
        <div class="stats-header">
          <div class="eyebrow">τεχνικὰ στοιχεῖα</div>
          <h3 class="serif italic">Ὁ Ναὸς σὲ ἀριθμούς</h3>
        </div>
        <div class="stats-grid">
          {STATS.map(s => (
            <div class="stat">
              <div class="stat-label">{s.label}</div>
              <div class="stat-value">{s.value}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============== FEATURE STRIP — historic photos ============== -->
  <section class="section">
    <div class="container">
      <div class="eyebrow">τὸ ἀρχεῖο</div>
      <h2 class="section-title">Στιγμὲς ἀπὸ τὴν <em>ἱστορία</em></h2>
      <hr class="rule" />

      <div class="photo-strip">
        {featurePhotos.map(p => (
          <a href="/gallery" class="photo-strip-item">
            <div class="psi-img"><img src={p.src} alt={p.title} loading="lazy" /></div>
            <div class="psi-meta">
              <span class="psi-year">{p.year}</span>
              <h4>{p.title}</h4>
              <p>{p.caption}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== CLOSING CTA ============== -->
  <section class="section closing">
    <div class="container">
      <div class="closing-inner">
        <div class="orn">❦</div>
        <h2 class="serif italic">«Πρὸς τὸν ἔνδοξον πολιοῦχον τῶν Πατρῶν»</h2>
        <p class="lead">
          Ἀνεγείρομε τὸν Ναὸν στὸ ψηφιακό μας ἀρχεῖο.
          Μπορεῖτε νὰ τὸν περιηγηθεῖτε σὲ ὑπολογιστή, κινητό, ἢ μέσῳ Oculus Quest.
        </p>
        <div class="closing-cta">
          <a href="/book" class="btn primary lg">
            <span>μπεῖτε στὸ βιβλίον</span>
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============== HERO ============== */
  .hero {
    position: relative;
    min-height: calc(100vh - var(--nav-h));
    display: flex;
    align-items: center;
    overflow: hidden;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
  }
  .hero-bg {
    position: absolute; inset: 0;
    z-index: -1;
    overflow: hidden;
  }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.18;
    filter: contrast(1.1) saturate(0.6) blur(1.2px);
    transform: scale(1.05);
    animation: heroPan 30s ease-in-out infinite alternate;
  }
  @keyframes heroPan {
    from { transform: scale(1.05) translate(0, 0); }
    to   { transform: scale(1.15) translate(-2%, -3%); }
  }
  .hero-bg-fade {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% 60%, transparent 0%, var(--bg-deep) 95%),
      linear-gradient(180deg, rgba(8,4,2,0.55) 0%, rgba(8,4,2,0.4) 50%, var(--bg-deep) 100%);
  }
  .hero-inner {
    text-align: center;
    padding-top: clamp(40px, 6vw, 80px);
    padding-bottom: clamp(40px, 6vw, 80px);
  }
  .hero-eyebrow { margin-bottom: 22px; }
  .hero-title {
    display: flex; flex-direction: column;
    gap: 4px;
    margin-bottom: 28px;
    font-size: clamp(40px, 7vw, 96px);
  }
  .hero-title .line { display: block; }
  .hero-title em { font-style: italic; color: var(--gold-mid); font-weight: 400; font-size: 0.6em; }
  .hero-title .sub {
    font-size: 0.36em;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-family: var(--sans);
    font-weight: 600;
    font-style: normal;
    display: inline-block;
    margin-top: 8px;
  }

  .hero-rule {
    display: flex; align-items: center; justify-content: center;
    gap: 14px;
    margin: 16px auto 32px;
    max-width: 320px;
  }
  .hero-rule .orn { color: var(--gold-mid); font-size: 14px; line-height: 1; }
  .hero-rule .line {
    flex: 1; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-soft) 50%, transparent);
  }

  .hero-lead {
    font-family: var(--serif);
    font-size: clamp(17px, 2vw, 22px);
    font-style: italic;
    color: var(--gold-mid);
    max-width: 640px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }
  .hero-lead em { color: var(--gold-pale); font-style: italic; }

  .hero-cta {
    display: flex; gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: clamp(48px, 6vw, 80px);
  }
  .btn.lg { padding: 14px 26px; font-size: 11px; }

  .hero-eras {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
    border-top: 1px solid rgba(217,180,120,0.18);
    border-bottom: 1px solid rgba(217,180,120,0.18);
    padding: 18px 0;
    max-width: 720px;
    margin: 0 auto;
  }
  .era {
    text-align: center;
    border-right: 1px solid rgba(217,180,120,0.1);
    padding: 4px;
  }
  .era:last-child { border-right: none; }
  .era-year {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(15px, 2vw, 19px);
    color: var(--gold-bright);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .era-label {
    font-size: 7px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin-top: 4px;
    font-weight: 600;
  }

  .scroll-hint {
    position: absolute;
    bottom: 26px; left: 50%;
    transform: translateX(-50%);
    display: flex; align-items: center; gap: 8px;
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold-deep);
    opacity: 0.6;
    animation: scrollBounce 2.4s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0);   opacity: 0.6; }
    50%      { transform: translateX(-50%) translateY(6px); opacity: 0.95; }
  }

  /* ============== APPS GRID ============== */
  .section-title { font-size: clamp(28px, 4.5vw, 48px); margin-bottom: 0; }
  .section-title em { color: var(--gold-pale); font-style: italic; }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: clamp(16px, 2vw, 24px);
    margin-top: clamp(36px, 5vw, 56px);
  }
  .app-card {
    position: relative;
    display: flex; flex-direction: column;
    padding: clamp(24px, 3vw, 36px);
    background: linear-gradient(180deg, rgba(20,12,6,0.6) 0%, rgba(8,4,2,0.4) 100%);
    border: 1px solid rgba(217,180,120,0.22);
    border-radius: var(--radius-m);
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    min-height: 260px;
  }
  .app-card::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 20% 20%, rgba(255,170,80,0.06) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }
  .app-card:hover {
    background: linear-gradient(180deg, rgba(40,24,12,0.7) 0%, rgba(20,10,6,0.5) 100%);
    border-color: rgba(217,180,120,0.5);
    transform: translateY(-4px);
    box-shadow: 0 26px 60px -16px rgba(0,0,0,0.7), 0 0 60px rgba(255,170,80,0.05);
  }
  .app-card:hover::after { opacity: 1; }

  .card-symbol {
    font-size: 36px;
    color: var(--gold-pale);
    line-height: 1;
    margin-bottom: 14px;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }
  .card-num {
    position: absolute;
    top: 24px; right: 28px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 38px;
    color: var(--gold-deep);
    opacity: 0.55;
    line-height: 1;
  }
  .app-card h3 {
    font-size: clamp(22px, 3vw, 28px);
    color: var(--gold-bright);
    margin-bottom: 10px;
  }
  .app-card p {
    font-size: 13px;
    line-height: 1.65;
    color: var(--gold-soft);
    margin-bottom: 18px;
    flex: 1;
  }
  .card-meta {
    display: flex; align-items: center; gap: 6px;
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 600;
    margin-bottom: 18px;
  }
  .card-meta span:nth-child(even) { opacity: 0.4; }
  .card-go {
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-mid);
    font-weight: 500;
    padding-top: 14px;
    border-top: 1px solid rgba(217,180,120,0.15);
    transition: color 0.3s, padding-left 0.3s;
  }
  .app-card:hover .card-go {
    color: var(--gold-bright);
    padding-left: 6px;
  }

  /* ============== STATS ============== */
  .stats { display: grid; gap: 20px; }
  .stats-header { text-align: center; }
  .stats-header h3 { margin-top: 8px; font-size: clamp(22px, 3vw, 30px); }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1px;
    background: rgba(217,180,120,0.15);
    border: 1px solid rgba(217,180,120,0.15);
    border-radius: var(--radius-m);
    overflow: hidden;
  }
  .stat {
    padding: 18px 14px;
    background: rgba(20,12,6,0.6);
    text-align: center;
  }
  .stat-label {
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .stat-value {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--gold-bright);
    font-variant-numeric: tabular-nums;
  }

  /* ============== PHOTO STRIP ============== */
  .photo-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(14px, 2vw, 22px);
    margin-top: clamp(28px, 4vw, 48px);
  }
  .photo-strip-item {
    text-decoration: none;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .photo-strip-item:hover { transform: translateY(-3px); }
  .psi-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #000;
    border-radius: var(--radius-m);
    border: 1px solid rgba(217,180,120,0.18);
    transition: border-color 0.4s, box-shadow 0.4s;
  }
  .psi-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: contrast(1.05);
    transition: transform 0.7s, filter 0.4s;
  }
  .photo-strip-item:hover .psi-img {
    border-color: rgba(217,180,120,0.45);
    box-shadow: 0 16px 40px -10px rgba(0,0,0,0.6);
  }
  .photo-strip-item:hover .psi-img img {
    transform: scale(1.06);
    filter: contrast(1.1) saturate(1.1);
  }
  .psi-meta { padding: 14px 4px; }
  .psi-year {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 0.4em;
    color: var(--gold-deep);
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .psi-meta h4 {
    font-family: var(--serif);
    font-style: italic;
    font-size: 21px;
    color: var(--gold-bright);
    line-height: 1.2;
    margin-bottom: 4px;
  }
  .psi-meta p {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-mid);
    margin: 0;
    font-weight: 600;
  }

  /* ============== CLOSING ============== */
  .closing {
    background: radial-gradient(ellipse 60vw 50vh at center, rgba(154,103,48,0.08) 0%, transparent 60%);
  }
  .closing-inner {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 56px) 0;
  }
  .closing-inner .orn {
    font-size: 48px;
    color: var(--gold-pale);
    margin-bottom: 20px;
    filter: drop-shadow(0 3px 6px rgba(0,0,0,0.5));
  }
  .closing-inner h2 { font-size: clamp(24px, 3.5vw, 36px); margin-bottom: 18px; }
  .closing-cta { margin-top: 28px; }

  @media (max-width: 720px) {
    .hero-eras { grid-template-columns: repeat(3, 1fr); }
    .hero-eras .era:nth-child(3) { border-right: none; }
    .hero-eras .era:nth-child(4), .hero-eras .era:nth-child(5), .hero-eras .era:nth-child(6) {
      border-top: 1px solid rgba(217,180,120,0.1);
      padding-top: 12px;
    }
  }
</style>
