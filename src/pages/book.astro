// Atmospheric dust motes — sparse single layer; disabled on low-perf devices.
function makeDust() {
  const N = 80;
  const geom = new THREE.BufferGeometry();
  const positions = new Float32Array(N * 3);
  const speeds = new Float32Array(N);
  for (let i = 0; i < N; i++) {
    positions[i*3]   = (Math.random() - 0.5) * 8;
    positions[i*3+1] = -1 + Math.random() * 5;
    positions[i*3+2] = (Math.random() - 0.5) * 6;
    speeds[i] = 0.04 + Math.random() * 0.08;
  }
  geom.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  const c = document.createElement('canvas'); c.width = c.height = 32;
  const cc = c.getContext('2d');
  const g = cc.createRadialGradient(16, 16, 0, 16, 16, 16);
  g.addColorStop(0, 'rgba(255,220,160,1)');
  g.addColorStop(1, 'rgba(255,180,100,0)');
  cc.fillStyle = g; cc.fillRect(0, 0, 32, 32);
  const tex = new THREE.CanvasTexture(c);
  const mat = new THREE.PointsMaterial({
    size: 0.028, map: tex, color: 0xffd9a0,
    transparent: true, opacity: 0.55,
    blending: THREE.AdditiveBlending, depthWrite: false, sizeAttenuation: true,
  });
  const points = new THREE.Points(geom, mat);
  points.userData.speeds = speeds;
  return points;
}
const dust = IS_LOW_PERF ? null : makeDust();
