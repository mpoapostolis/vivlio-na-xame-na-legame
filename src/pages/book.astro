const pages = [];

// Apply per-page content overrides from the PocketBase CMS onto each PAGES entry's
// pre-built DOM and photo metadata, BEFORE the page is rasterised to a canvas
// texture. PB record's (book_index, side) maps to PAGES[bookIndex][side].
const PB_URL = 'https://yms.galerra.art';

// Tiny non-blocking status pill in the HUD that surfaces the PocketBase
// fetch state without blocking the user. Tracked counts let the pill stay
// visible while either the church_pages or church_animations fetch is in
// flight, then settle to a brief success/offline notice.
const _syncPill = {
  inflight: 0,
  failed: false,
  el() { return document.getElementById('sync-pill'); },
  _setText(text, offline) {
    const el = this.el(); if (!el) return;
    el.textContent = text;
    el.classList.toggle('offline', !!offline);
    el.classList.add('visible');
  },
  _hideSoon(ms) {
    const el = this.el(); if (!el) return;
    setTimeout(() => { el.classList.remove('visible'); }, ms);
  },
  begin() {
    this.inflight++;
    this._setText('⌛ συγχρονισμός…', false);
  },
  end(ok) {
    this.inflight = Math.max(0, this.inflight - 1);
    if (!ok) this.failed = true;
    if (this.inflight > 0) return;
    if (this.failed) {
      this._setText('○ offline — τοπικὰ δεδομένα', true);
      this._hideSoon(4000);
    } else {
      this._setText('✓ συγχρονισμένο', false);
      this._hideSoon(1500);
    }
  },
};

async function _loadAndApplyContentOverrides() {
  _syncPill.begin();
  let records = null;
  try {
    const res = await fetch(`${PB_URL}/api/collections/church_pages/records?sort=order&perPage=100`);
    if (!res.ok) throw new Error('PB status ' + res.status);
    const json = await res.json();
    records = Array.isArray(json && json.items) ? json.items : [];
  } catch (e) {
    console.info('[content] PB unreachable — using inline defaults');
    _syncPill.end(false);
    return;
  }
  if (!records.length) { _syncPill.end(true); return; }

  // Sort records by `order`, then pair them sequentially into sheets. Index-
  // based pairing is resilient to gaps in the `order` values (e.g. after a
  // page is deleted in /admin and the remaining orders are not compacted).
  const sortedRecs = records
    .filter(rec => rec && typeof rec === 'object' && Number.isFinite(Number(rec.order)))
    .sort((a, b) => a.order - b.order);
  if (records.length !== sortedRecs.length) {
    console.warn('[content] skipped', records.length - sortedRecs.length, 'malformed PB record(s)');
  }

  const sheets = {};
  for (let i = 0; i < sortedRecs.length; i++) {
    const sheetIdx = Math.floor(i / 2);
    const sideName = i % 2 === 0 ? 'front' : 'back';
    if (!sheets[sheetIdx]) sheets[sheetIdx] = {};
    sheets[sheetIdx][sideName] = sortedRecs[i];
  }

  const sheetKeys = Object.keys(sheets).map(Number).sort((a, b) => a - b);
  if (!sheetKeys.length) { _syncPill.end(true); return; }

  // Build a fresh PAGES array from PB records. The explicit `type` field on
  // each record drives the renderer: 'cover' / 'back-cover' use cover(),
  // 'page' (or missing) uses page().
  function _buildSide(rec, i, sideName) {
    if (!rec) return (PAGES[i] && PAGES[i][sideName]) || page({ blocks: [], folio: '' });
    const isCover = rec.type === 'cover' || rec.type === 'back-cover';
    const data = _pbRecordToPageData(rec, i, sideName);
    const built = isCover
      ? cover(rec.title || rec.label || '', _stripHtml(rec.lead || rec.body || ''), rec.eyebrow || '')
      : page(data);
    if (data._narrationUrl) built._narrationUrl = data._narrationUrl;
    return built;
  }

  const rebuilt = [];
  for (const i of sheetKeys) {
    const sheet = sheets[i];
    rebuilt.push({
      front: _buildSide(sheet.front, i, 'front'),
      back:  _buildSide(sheet.back,  i, 'back'),
    });
  }

  // Replace inline PAGES contents in place (PAGES is const but contents mutable)
  PAGES.length = 0;
  for (const p of rebuilt) PAGES.push(p);
  // photoView state references PAGES; nothing else cached yet at this point.
  console.info('[content] rebuilt', PAGES.length, 'sheet(s) from PB');
  _syncPill.end(true);
}

// Map a flat PB record onto the {eyebrow, h2, date, blocks, folio} shape
// expected by page(). Body and lead are emitted as separate blocks; if a
// photo file is present, it becomes a 'photo' block with caption/desc/etc.
function _pbRecordToPageData(rec, bookIndex, side) {
  const blocks = [];
  if (rec.lead) blocks.push({ type: 'lead', text: _stripHtml(rec.lead) });
  if (rec.body) blocks.push({ type: 'p',    text: _stripHtml(rec.body) });
  if (rec.photo) {
    const photoUrl = `${PB_URL}/api/files/${rec.collectionId}/${rec.id}/${rec.photo}`;
    blocks.push({
      type:   'photo',
      src:    photoUrl,
      cap:    rec.photo_cap    || '',
      title:  rec.photo_title  || rec.title || '',
      desc:   _stripHtml(rec.photo_desc) || '',
      italic: rec.photo_italic || '',
      audio:  rec.photo_audio ? `${PB_URL}/api/files/${rec.collectionId}/${rec.id}/${rec.photo_audio}` : null,
    });
  }
  const folioNum = bookIndex * 2 + (side === 'front' ? 1 : 2);
  return {
    eyebrow: rec.eyebrow || '',
    h2:      rec.title   || rec.label || '',
    date:    rec.date    || '',
    blocks,
    folio:   _toRomanish(folioNum),
    _narrationUrl: rec.narration ? `${PB_URL}/api/files/${rec.collectionId}/${rec.id}/${rec.narration}` : null,
  };
}
// Strip an HTML string down to its text content. PB 'editor' fields return
// HTML; the page renderer uses textContent for most blocks so we collapse
// it to plain text here. Keeps line breaks from <br>/<p> via newline.
function _stripHtml(html) {
  if (!html || typeof html !== 'string') return html || '';
  const tmp = document.createElement('div');
  tmp.innerHTML = html.replace(/<br\s*\/?>/gi, '\n').replace(/<\/p>/gi, '\n');
  return (tmp.textContent || tmp.innerText || '').trim();
}
function _toRomanish(n) {
  const map = ['','i','ii','iii','iv','v','vi','vii','viii','ix','x','xi','xii','xiii','xiv','xv','xvi','xvii','xviii','xix','xx'];
  return map[n] || String(n);
}

async function buildBook() {
  await _loadAndApplyContentOverrides();
  const total = PAGES.length;
  const progress = document.getElementById('progress');

  for (let i = 0; i < total; i++) {
    progress.textContent = `${i*2+1} / ${total*2}`;
    const fc = await renderHtmlToCanvas(PAGES[i].front);
    progress.textContent = `${i*2+2} / ${total*2}`;
    const bc = await renderHtmlToCanvas(PAGES[i].back);

    const ft = new THREE.CanvasTexture(fc);
    ft.colorSpace = THREE.SRGBColorSpace; ft.anisotropy = 16; ft.needsUpdate = true;
    const bt = new THREE.CanvasTexture(bc);
    bt.colorSpace = THREE.SRGBColorSpace; bt.anisotropy = 16; bt.needsUpdate = true;

    const p = new Page(i, ft, bt, total, PAGES[i].front.photos, PAGES[i].back.photos);
    pages.push(p);
    bookGroup.add(p.group);
  }
}

// =====================================================================
//   PAGE TURN STATE (delayed page like wawa)
// =====================================================================
let targetPage = 0, delayedPage = 0, pageStepTimer = 0;
function goToPage(n) {
  closeModal();
  const clamped = THREE.MathUtils.clamp(n, 0, PAGES.length);
  // Stop any active narration on page change so they don't overlap.
  if (clamped !== targetPage && typeof stopNarration === 'function') stopNarration();
  targetPage = clamped;
  updateUI();
}
function stepDelayedPage(dt) {
  if (delayedPage === targetPage) return;
  pageStepTimer += dt;
  const interval = Math.abs(targetPage - delayedPage) > 2 ? 0.05 : 0.15;
  if (pageStepTimer >= interval) {
    pageStepTimer = 0;
    delayedPage += targetPage > delayedPage ? 1 : -1;
    playPageFlip();
    updateUI();
  }
}

// =====================================================================
//   AUDIO
// =====================================================================
let audioCtx = null;
function ensureAudio() { if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
function playPageFlip() {
  if (!audioCtx) return;
  const dur = 0.18, sr = audioCtx.sampleRate;
  const buf = audioCtx.createBuffer(1, sr * dur, sr);
  const d = buf.getChannelData(0);
  for (let i = 0; i < d.length; i++) {
    const t = i / d.length; const env = Math.exp(-t * 14) * (1 - t);
    d[i] = (Math.random() * 2 - 1) * env;
  }
  const src = audioCtx.createBufferSource(); src.buffer = buf;
  const fl = audioCtx.createBiquadFilter(); fl.type = 'bandpass'; fl.frequency.value = 2500 + Math.random()*800; fl.Q.value = 0.7;
  const g = audioCtx.createGain(); g.gain.value = 0.3;
  src.connect(fl); fl.connect(g); g.connect(audioCtx.destination); src.start();
}
function playPop() {
  if (!audioCtx) return;
  const o = audioCtx.createOscillator(); const g = audioCtx.createGain();
  o.type = 'sine';
  o.frequency.setValueAtTime(660, audioCtx.currentTime);
  o.frequency.exponentialRampToValueAtTime(330, audioCtx.currentTime + 0.2);
  g.gain.setValueAtTime(0.16, audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);
  o.connect(g); g.connect(audioCtx.destination); o.start(); o.stop(audioCtx.currentTime + 0.27);
}

// =====================================================================
//   NARRATION (recorded mp3) — per-page and per-photo
// =====================================================================
const NARRATION_BASE = '';   // PHOTO_NARRATION_MAP values are already absolute paths under /audio/
// Photo→narration map injected at build time from src/data/animations.ts.
// Defaults to an empty map if the inline JSON is missing or malformed —
// per-photo narrations simply become a no-op.
const PHOTO_NARRATION_MAP = (() => {
  try {
    const el = document.getElementById('photo-narrations-data');
    return el ? (JSON.parse(el.textContent) || {}) : {};
  } catch (e) {
    console.warn('[narration] malformed PHOTO_NARRATION_MAP — using empty');
    return {};
  }
})();
let _narrationAudio = null;
let _narrationProgressTimer = null;

function _updateAudioBtn() {
  const btn = document.getElementById('audio-btn');
  const icon = document.getElementById('audio-icon');
  const prog = document.getElementById('audio-progress');
  if (!btn) return;
  const playing = _narrationAudio && !_narrationAudio.paused && !_narrationAudio.ended;
  btn.classList.toggle('playing', !!playing);
  icon.textContent = playing ? '⏸' : '▶';
  if (playing && _narrationAudio.duration) {
    prog.style.transform = 'scaleX(' + (_narrationAudio.currentTime / _narrationAudio.duration) + ')';
  } else {
    prog.style.transform = 'scaleX(0)';
  }
}
function playNarration(filename) {
  stopNarration();
  if (!filename) return;
  _narrationAudio = new Audio(NARRATION_BASE + filename);
  _narrationAudio.addEventListener('ended', () => { _updateAudioBtn(); });
  _narrationAudio.addEventListener('pause', _updateAudioBtn);
  _narrationAudio.addEventListener('play',  _updateAudioBtn);
  const p = _narrationAudio.play();
  if (p && p.catch) p.catch(err => { console.warn('[narration] play blocked:', err); });
  if (_narrationProgressTimer) clearInterval(_narrationProgressTimer);
  _narrationProgressTimer = setInterval(_updateAudioBtn, 200);
}
function stopNarration() {
  if (_narrationAudio) { _narrationAudio.pause(); _narrationAudio.currentTime = 0; _narrationAudio = null; }
  if (_narrationProgressTimer) { clearInterval(_narrationProgressTimer); _narrationProgressTimer = null; }
  _updateAudioBtn();
}
function toggleNarration() {
  if (_narrationAudio) {
    if (_narrationAudio.paused) _narrationAudio.play(); else _narrationAudio.pause();
    _updateAudioBtn();
  } else {
    playPageNarration(targetPage);
  }
}
// Per-sheet page narration: PB override (stored on PAGES[i].front._narrationUrl
// during _loadAndApplyContentOverrides) wins over the default mp3.
function playPageNarration(idx) {
  if (idx < 0 || idx >= PAGES.length) return;
  const frontUrl = PAGES[idx].front && PAGES[idx].front._narrationUrl;
  const backUrl  = PAGES[idx].back  && PAGES[idx].back._narrationUrl;
  const file = frontUrl || backUrl || ('/audio/narration_p' + idx + '.mp3');
  playNarration(file);
}
// photoOrSrc can be a {src, audio?} photo object OR a plain src string.
function playPhotoNarration(photoOrSrc) {
  const isObj = photoOrSrc && typeof photoOrSrc === 'object';
  const src = isObj ? photoOrSrc.src : photoOrSrc;
  const override = isObj ? photoOrSrc.audio : null;
  const file = override || PHOTO_NARRATION_MAP[src];
  if (file) playNarration(file);
}
document.getElementById('audio-btn').addEventListener('click', () => { ensureAudio(); toggleNarration(); });

