const numerals = ['ἐξώφυλλο','α´','β´','γ´','δ´','ε´','ϛ´','ζ´','τέλος'];
function updateUI() {
  document.getElementById('cur').textContent = numerals[delayedPage] || delayedPage;
  document.getElementById('tot').textContent = numerals[PAGES.length] || PAGES.length;
  document.getElementById('prev').disabled = targetPage <= 0;
  document.getElementById('next').disabled = targetPage >= PAGES.length;
  const strip = document.getElementById('strip');
  if (strip.children.length === 0) {
    for (let i = 0; i <= PAGES.length; i++) {
      const b = document.createElement('button'); b.className = 'dot';
      b.addEventListener('click', () => { ensureAudio(); goToPage(i); });
      strip.appendChild(b);
    }
  }
  Array.from(strip.children).forEach((d, i) => d.classList.toggle('active', i === targetPage));
}
document.getElementById('prev').addEventListener('click', () => { ensureAudio(); goToPage(targetPage - 1); });
document.getElementById('next').addEventListener('click', () => { ensureAudio(); goToPage(targetPage + 1); });
window.addEventListener('keydown', e => {
  // Don't intercept when the user is typing in a form field — matters
  // especially when /book is embedded in the admin's preview iframe.
  const t = e.target;
  if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
  if (e.key === 'ArrowRight' || e.key === ' ') { ensureAudio(); goToPage(targetPage + 1); }
  if (e.key === 'ArrowLeft')                    { ensureAudio(); goToPage(targetPage - 1); }
  if (e.key === 'Escape') { closeModal(); stopNarration(); }
});

// ---------------------------------------------------------------------------
// Admin-preview bridge — when /book is embedded in the admin's preview iframe.
//   { type:'goToSheet',   sheet:N }                → flip to sheet N
//   { type:'previewRecord', listIndex:N, record:R } → live re-render one side
// ---------------------------------------------------------------------------
// If a goToSheet message arrives before buildBook has finished — the iframe
// can load faster than the page textures — we stash the target and replay
// it from the boot path. Without this the message hits an empty PAGES
// array and the editor's click silently does nothing.
let _pendingGoTo = null;

window.addEventListener('message', (e) => {
  const data = e.data;
  if (!data) return;
  if (data.type === 'goToSheet') {
    const n = Number(data.sheet);
    if (!Number.isFinite(n)) return;
    if (!PAGES.length) { _pendingGoTo = n; return; }
    goToPage(n);
    // Snap the delayed page so the iframe doesn't cascade-flip every
    // sheet on its way to the target. The admin's sidebar wants a hard
    // jump, not a flipbook reveal — that's a /book-standalone behaviour.
    delayedPage = targetPage;
    updateUI();
    return;
  }
  if (data.type === 'previewRecord') {
    _previewLiveRecord(data.listIndex, data.record);
  }
});

// Live single-side re-render. Builds a fresh DOM for the affected side,
// rasterises it, and swaps the texture on the right Page mesh. Coalesces
// concurrent calls so a fast typist gets the latest input, not a backlog.
let _previewBusy = false;
let _previewQueued = null;
async function _previewLiveRecord(listIndex, rec) {
  if (!Number.isFinite(Number(listIndex)) || !rec) return;
  if (_previewBusy) { _previewQueued = { listIndex, rec }; return; }
  _previewBusy = true;
  try {
    const sheetIdx = Math.floor(listIndex / 2);
    const sideName = (listIndex % 2 === 0) ? 'front' : 'back';
    const pageInst = pages[sheetIdx];
    if (!pageInst) return;

    const isCover = rec.type === 'cover' || rec.type === 'back-cover';
    const data    = _pbRecordToPageData(rec, sheetIdx, sideName);
    const built   = isCover
      ? cover(rec.title || rec.label || '', _stripHtml(rec.lead || rec.body || ''), rec.eyebrow || '')
      : page(data);

    // Render to canvas BEFORE touching the existing material — if the
    // rasteriser throws (broken image, timeout), the old texture is still
    // live and we just bail without leaking a half-allocated CanvasTexture.
    const canvas = await renderHtmlToCanvas(built);
    const newTex = new THREE.CanvasTexture(canvas);
    newTex.colorSpace = THREE.SRGBColorSpace;
    newTex.anisotropy = 16;
    newTex.needsUpdate = true;

    const mat    = (sideName === 'front') ? pageInst.frontMat : pageInst.backMat;
    const oldTex = mat.map;
    mat.map = newTex;
    mat.needsUpdate = true;
    // Dispose AFTER the swap so we never leave the material pointing at a
    // disposed map mid-frame.
    if (oldTex && oldTex !== newTex && oldTex.dispose) oldTex.dispose();

    // Keep the photo bbox cache in sync so click-to-zoom still hits correctly.
    if (sideName === 'front') pageInst.frontPhotos = built.photos;
    else                      pageInst.backPhotos  = built.photos;
    if (PAGES[sheetIdx]) PAGES[sheetIdx][sideName] = built;
  } catch (err) {
    console.warn('[preview] live update failed:', err);
  } finally {
    _previewBusy = false;
    if (_previewQueued) {
      const q = _previewQueued; _previewQueued = null;
      _previewLiveRecord(q.listIndex, q.rec);
    }
  }
}

// =====================================================================
//   KEYFRAME RUNTIME — JSON-driven animation player.
//   Targets can be DOM HTMLElements (transform/opacity) or three.js Object3Ds
//   (position/scale/rotation). Drives the photo modal and is editable
//   through the /admin CMS, which writes to the PocketBase
//   `church_animations` collection (fetched below).
// =====================================================================
const EASE = {
  linear:         t => t,
  easeInQuad:     t => t*t,
  easeOutQuad:    t => 1 - (1-t)*(1-t),
  easeInOutQuad:  t => t<0.5 ? 2*t*t : 1 - Math.pow(-2*t+2, 2)/2,
  easeInCubic:    t => t*t*t,
  easeOutCubic:   t => 1 - Math.pow(1-t, 3),
  easeInOutCubic: t => t<0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3)/2,
  easeInQuart:    t => t*t*t*t,
  easeOutQuart:   t => 1 - Math.pow(1-t, 4),
  easeOutBack:    t => { const c1=1.70158, c3=c1+1; return 1 + c3*Math.pow(t-1,3) + c1*Math.pow(t-1,2); },
  easeOutElastic: t => { if (t===0||t===1) return t; const c4=(2*Math.PI)/3; return Math.pow(2,-10*t)*Math.sin((t*10-0.75)*c4)+1; },
  easeOutBounce:  t => { const n=7.5625, d=2.75;
    if (t<1/d) return n*t*t;
    if (t<2/d){ t-=1.5/d; return n*t*t+0.75; }
    if (t<2.5/d){ t-=2.25/d; return n*t*t+0.9375; }
    t-=2.625/d; return n*t*t+0.984375; },
};

function _sampleNumber(keyframes, t01) {
  if (!keyframes.length) return null;
  if (t01 <= keyframes[0].t) return keyframes[0].value;
  const last = keyframes[keyframes.length-1];
  if (t01 >= last.t) return last.value;
  for (let i=0; i<keyframes.length-1; i++) {
    const a = keyframes[i], b = keyframes[i+1];
    if (t01 >= a.t && t01 <= b.t) {
      const local = (t01 - a.t) / Math.max(b.t - a.t, 1e-6);
      const ease = EASE[a.ease || 'linear'] || EASE.linear;
      return a.value + (b.value - a.value) * ease(local);
    }
  }
  return last.value;
}

// Apply a single property frame onto a DOM element. CSS transform parts compose.
function _applyDom(target, prop, value, transformAccum) {
  if (prop === 'opacity') {
    target.style.opacity = String(value);
  } else if (prop === 'scale' || prop === 'rotation' || prop === 'translateX' || prop === 'translateY') {
    transformAccum[prop] = value;
  }
}
function _flushTransform(target, t) {
  const parts = [];
  if (t.translateX !== undefined || t.translateY !== undefined)
    parts.push(`translate(${t.translateX || 0}px, ${t.translateY || 0}px)`);
  if (t.rotation !== undefined)  parts.push(`rotate(${t.rotation}rad)`);
  if (t.scale !== undefined)     parts.push(`scale(${t.scale})`);
  target.style.transform = parts.length ? parts.join(' ') : '';
}

// Apply a single property frame onto a three.js Object3D. The keyframe
// editor can target any registered 3D object (see `register3DTarget`) by
// name and animate its position / scale / rotation / opacity. All values
// are absolute — the runtime assigns directly so the order of multiple
// tracks doesn't matter.
function _applyObject3D(target, prop, value) {
  switch (prop) {
    case 'positionX': target.position.x = value; break;
    case 'positionY': target.position.y = value; break;
    case 'positionZ': target.position.z = value; break;
    case 'scale':     target.scale.setScalar(value); break;
    case 'scaleX':    target.scale.x = value; break;
    case 'scaleY':    target.scale.y = value; break;
    case 'scaleZ':    target.scale.z = value; break;
    case 'rotationX': target.rotation.x = value; break;
    case 'rotationY': target.rotation.y = value; break;
    case 'rotationZ': target.rotation.z = value; break;
    case 'opacity':
      if (target.material) {
        // Materials default to opaque; flag once when fading.
        if (!target.material.transparent && value < 1) target.material.transparent = true;
        target.material.opacity = value;
      }
      break;
  }
}

// Tiny cache so an audio URL referenced from many keyframes loads once.
const _kfAudioCache = new Map();
function _fireKeyframeAudio(url) {
  if (!url) return;
  let aud = _kfAudioCache.get(url);
  if (!aud) {
    try { aud = new Audio(url); aud.preload = 'auto'; _kfAudioCache.set(url, aud); }
    catch (_) { return; }
  }
  try { aud.currentTime = 0; aud.play().catch(() => {}); } catch (_) {}
}

class KeyframePlayer {
  constructor(animations) {
    this.animations = animations;
    this.activeClips = [];
  }
  play(name, opts = {}) {
    const anim = this.animations[name];
    if (!anim) { console.warn('[keyframe] unknown anim:', name); return null; }
    const clip = {
      name, anim,
      time: 0, duration: anim.duration,
      targets: opts.targets || {},
      onComplete: opts.onComplete || null,
      done: false,
      // Index of next-to-fire audio keyframe per (trackIdx:prop) — lets us
      // play each playAudio exactly once as the playhead crosses its t.
      audioCursor: new Map(),
    };
    this.activeClips.push(clip);
    return clip;
  }
  stopAll() { this.activeClips.length = 0; }
  update(dt) {
    for (let i = this.activeClips.length - 1; i >= 0; i--) {
      const clip = this.activeClips[i];
      const prevT01 = clip.duration > 0 ? clip.time / clip.duration : 1;
      clip.time = Math.min(clip.time + dt, clip.duration);
      const t01 = clip.duration > 0 ? clip.time / clip.duration : 1;

      clip.anim.tracks.forEach((track, trackIdx) => {
        // Resolve target: explicit per-call (clip.targets) wins, then the
        // global 3D registry (cathedral.dome, etc.), then nothing.
        const target = clip.targets[track.target] || _3D_TARGET_REGISTRY[track.target] || null;
        const isDom  = target instanceof HTMLElement;
        const is3D   = !isDom && target && target.isObject3D;
        const transformAccum = {};

        for (const prop in track.properties) {
          const keyframes = track.properties[prop];

          // 1. Apply the numeric value at the current playhead — only if
          //    we actually have a target to apply it to.
          if (target) {
            const value = _sampleNumber(keyframes, t01);
            if (value !== null) {
              if (isDom)     _applyDom(target, prop, value, transformAccum);
              else if (is3D) _applyObject3D(target, prop, value);
            }
          }

          // 2. Fire playAudio for any keyframe the playhead just crossed.
          //    Audio cues fire regardless of whether the visual target exists,
          //    so a sound cue can sit on an "abstract" track.
          const cursorKey = trackIdx + ':' + prop;
          let cursor = clip.audioCursor.get(cursorKey);
          if (cursor === undefined) cursor = 0;
          while (cursor < keyframes.length) {
            const kf = keyframes[cursor];
            if (kf.t > t01) break;
            if (kf.playAudio && kf.t >= prevT01) _fireKeyframeAudio(kf.playAudio);
            cursor++;
          }
          clip.audioCursor.set(cursorKey, cursor);
        }
        if (isDom) _flushTransform(target, transformAccum);
      });

      if (clip.time >= clip.duration && !clip.done) {
        clip.done = true;
        if (clip.onComplete) clip.onComplete();
        this.activeClips.splice(i, 1);
      }
    }
  }
}

