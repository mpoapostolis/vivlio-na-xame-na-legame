// PMREM environment — initialized later in bootstrap (WebGPU needs renderer.init() first)
let pmrem = null;
async function setupEnvironment() {
  pmrem = new THREE.PMREMGenerator(renderer);
  if (pmrem.compileEquirectangularShader) pmrem.compileEquirectangularShader();

  // Beautiful equirectangular HDR skybox — Poly Haven (CC0). HDR gives
  // proper highlights and physically-plausible reflections on the copper
  // domes and gold cross. If the load fails (network / CORS / asset
  // moved) we fall back silently to the procedural RoomEnvironment.
  const SKYBOX_URL = 'https://dl.polyhaven.org/file/ph-assets/HDRIs/hdr/2k/kloppenheim_06_puresky_2k.hdr';
  let envTex = null;
  try {
    const loader = new RGBELoader();
    loader.setCrossOrigin('anonymous');
    const tex = await new Promise((resolve, reject) => {
      loader.load(SKYBOX_URL, resolve, undefined, () => reject(new Error('skybox load failed')));
    });
    tex.mapping = THREE.EquirectangularReflectionMapping;
    scene.background = tex;
    envTex = pmrem.fromEquirectangular(tex).texture;
    // Sky is bright — soften the fog so it reads at distance, and reduce
    // tone-mapping a touch so candles don't go nuclear against the sky.
    scene.fog.density = 0.010;
    renderer.toneMappingExposure = 0.85;
    console.info('[env] HDR skybox loaded');
  } catch (e) {
    console.info('[env] fallback to RoomEnvironment:', String(e).slice(0, 120));
    const result = pmrem.fromSceneAsync
      ? await pmrem.fromSceneAsync(new RoomEnvironment(), 0.04)
      : pmrem.fromScene(new RoomEnvironment(), 0.04);
    envTex = result.texture;
  }
  scene.environment = envTex;
}

