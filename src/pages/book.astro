// =====================================================================
//   PHOTO MODAL — HTML overlay, animation-driven
// =====================================================================
const photoView = { active: false, closing: false };
const modalEl      = document.getElementById('modal');
const modalPanel   = modalEl ? modalEl.querySelector('.panel') : null;
const modalCloseEl = document.getElementById('modal-close');
const modalImg     = document.getElementById('modal-img');
const modalInfo    = modalEl ? modalEl.querySelector('.info-side') : null;
const modalEyebrow = document.getElementById('modal-eyebrow');
const modalTitle   = document.getElementById('modal-title');
const modalDesc    = document.getElementById('modal-desc');
const modalItalic  = document.getElementById('modal-italic');

function cleanupPhotoView() {
  photoView.active = false;
  photoView.closing = false;
}

async function openModal(photo /*, hitPoint */) {
  if (photoView.active && !photoView.closing) return;
  cleanupPhotoView();

  modalImg.src = photo.src;
  modalImg.alt = photo.title || photo.cap || '';
  modalEyebrow.textContent = 'φωτογραφία · ἀπὸ τὸ ἀρχεῖον';
  modalTitle.textContent   = photo.title || photo.cap || '';
  modalDesc.textContent    = photo.desc  || '';
  modalItalic.textContent  = photo.italic || '';
  modalItalic.style.display = photo.italic ? '' : 'none';

  // Reset the transforms to the keyframe's t=0 pose so the first frame doesn't pop.
  modalImg.style.opacity = '0';
  modalImg.style.transform = 'scale(0.65) rotate(-0.035rad)';
  modalInfo.style.opacity = '0';
  modalInfo.style.transform = 'translate(40px, 0px)';

  modalEl.classList.add('open');
  modalEl.setAttribute('aria-hidden', 'false');
  photoView.active = true;
  photoView.closing = false;
  playPop();

  keyframePlayer.stopAll();
  keyframePlayer.play('photoModalOpen', { targets: { modalImg, modalInfo } });

  setTimeout(() => playPhotoNarration(photo), 350);
}

function closeModal() {
  if (!photoView.active || photoView.closing) return;
  photoView.closing = true;
  stopNarration();
  modalEl.setAttribute('aria-hidden', 'true');

  keyframePlayer.stopAll();
  keyframePlayer.play('photoModalClose', {
    targets: { modalImg, modalInfo },
    onComplete: () => {
      modalEl.classList.remove('open');
      cleanupPhotoView();
    },
  });
}

// (A) X button — explicit close, stop propagation so nothing else interferes
modalCloseEl.addEventListener('click', e => { e.stopPropagation(); e.preventDefault(); closeModal(); });
modalCloseEl.addEventListener('touchend', e => { e.stopPropagation(); e.preventDefault(); closeModal(); });

// (B) Clicking the dim backdrop (the #modal element, not the panel) closes
modalEl.addEventListener('click', e => {
  if (e.target === modalEl) closeModal();
});

// (C) Clicking the panel content does NOT close — stop propagation here, but
//     ALLOW the close button inside to keep working (it uses stopPropagation
//     in its own handler before this one fires).
modalPanel.addEventListener('click', e => { e.stopPropagation(); });

// =====================================================================
//   PICKING — raycaster on page meshes; UV → photo bbox lookup
// =====================================================================
const raycaster = new THREE.Raycaster();
const ndc = new THREE.Vector2();

function pickFromEvent(e) {
  const r = renderer.domElement.getBoundingClientRect();
  ndc.x = ((e.clientX - r.left) / r.width) * 2 - 1;
  ndc.y = -((e.clientY - r.top) / r.height) * 2 + 1;
  raycaster.setFromCamera(ndc, camera);
  const meshes = pages.map(p => p.mesh);
  const hits = raycaster.intersectObjects(meshes, false);
  return hits.length ? hits[0] : null;
}

renderer.domElement.addEventListener('pointermove', e => {
  const hit = pickFromEvent(e);
  if (hit && hit.uv) {
    const page = hit.object.userData.page;
    page.highlighted = true;
    document.body.style.cursor = 'pointer';
  } else {
    for (const p of pages) p.highlighted = false;
    document.body.style.cursor = '';
  }
  // clear other pages
  if (hit) {
    const page = hit.object.userData.page;
    for (const p of pages) if (p !== page) p.highlighted = false;
  }
});

renderer.domElement.addEventListener('click', e => {
  // Drag-to-look from the fly cam also fires a `click` event on pointerup —
  // suppress it so dragging the view doesn't accidentally flip pages.
  if (flyCam.lastWasDrag) { flyCam.lastWasDrag = false; return; }
  // If photo lift-off is active, any click closes it
  if (photoView.active && !photoView.closing) { closeModal(); return; }

  const hit = pickFromEvent(e);
  if (!hit) return;
  ensureAudio();
  const page = hit.object.userData.page;
  if (!hit.uv) { goToPage(page.lastOpened ? page.number : page.number + 1); return; }

  const faceIdx = hit.face ? hit.face.materialIndex : -1;
  const isFront = faceIdx === 4;
  const isBack  = faceIdx === 5;
  if (!isFront && !isBack) {
    goToPage(page.lastOpened ? page.number : page.number + 1);
    return;
  }
  const photos = isFront ? page.frontPhotos : page.backPhotos;
  if (!photos.length) {
    goToPage(page.lastOpened ? page.number : page.number + 1);
    return;
  }

  let u = hit.uv.x;
  const v = 1 - hit.uv.y;
  if (isBack) u = 1 - u;
  const px = u * TEX_W;
  const py = v * TEX_H;
  for (const ph of photos) {
    if (!ph.bbox) continue;
    const b = ph.bbox;
    if (px >= b.x && px <= b.x + b.w && py >= b.y && py <= b.y + b.h) {
      openModal(ph, hit.point); return;
    }
  }
  goToPage(page.lastOpened ? page.number : page.number + 1);
});

// =====================================================================
//   FLY CAMERA — WASD/E/C movement + drag-to-look. Replaces OrbitControls.
//
//   W/S forward / back     A/D strafe left / right
//   E   up                 C   down
//   left-mouse drag        look around (yaw + pitch, clamped to avoid flips)
//
//   A short drag below DRAG_PX still fires a click on the underlying mesh
//   (so clicking a page to flip it still works — `flyCam.lastWasDrag` is
//   read by the existing click handler to suppress click-after-drag).
// =====================================================================
const flyCam = (() => {
  const PAN_SPEED  = 0.0035;   // rad per pixel of pointer movement
  const MOVE_SPEED = 2.5;      // world units per second at full input
  const DAMP_TC    = 7;        // velocity smoothing — bigger = snappier
  const DRAG_PX    = 5;        // px before a pointer-down becomes a drag

  // Initialise yaw/pitch from the camera's current orientation so the
  // first frame doesn't jump (book starts with camera.lookAt(0,0,0)).
  const e0 = new THREE.Euler().setFromQuaternion(camera.quaternion, 'YXZ');
  let yaw = e0.y, pitch = e0.x;

  const velocity = new THREE.Vector3();
  const keys     = new Set();
  let mouseDown = false, dragging = false;
  let lastX = 0, lastY = 0, startX = 0, startY = 0;
  let lastWasDrag = false;

  // Disable browser touch gestures on the canvas so drag-to-look works
  // cleanly on tablets / trackpads.
  renderer.domElement.style.touchAction = 'none';

  renderer.domElement.addEventListener('pointerdown', e => {
    if (e.button !== 0) return;
    mouseDown = true; dragging = false;
    startX = lastX = e.clientX;
    startY = lastY = e.clientY;
    try { renderer.domElement.setPointerCapture(e.pointerId); } catch (_) {}
  });
  renderer.domElement.addEventListener('pointermove', e => {
    if (!mouseDown) return;
    if (!dragging) {
      if (Math.hypot(e.clientX - startX, e.clientY - startY) > DRAG_PX) {
        dragging = true;
        document.body.style.cursor = 'grabbing';
      } else return;
    }
    const dx = e.clientX - lastX, dy = e.clientY - lastY;
    lastX = e.clientX; lastY = e.clientY;
    yaw   -= dx * PAN_SPEED;
    pitch -= dy * PAN_SPEED;
    // Clamp slightly inside ±90° so the camera never goes upside-down.
    pitch = Math.max(-Math.PI / 2 + 0.05, Math.min(Math.PI / 2 - 0.05, pitch));
  });
  const release = (e) => {
    if (!mouseDown) return;
    lastWasDrag = dragging;
    mouseDown = false; dragging = false;
    document.body.style.cursor = '';
    try { renderer.domElement.releasePointerCapture(e.pointerId); } catch (_) {}
  };
  renderer.domElement.addEventListener('pointerup',     release);
  renderer.domElement.addEventListener('pointercancel', release);

  // Track keys at window level so they work even when the canvas isn't focused.
  // Skip key capture while the user is typing in a form field.
  window.addEventListener('keydown', e => {
    const t = e.target;
    if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
    keys.add(e.code);
  });
  window.addEventListener('keyup',   e => keys.delete(e.code));
  window.addEventListener('blur',    () => keys.clear());

  // Re-used buffers — no per-frame allocations.
  const fwd  = new THREE.Vector3();
  const rgt  = new THREE.Vector3();
  const UP   = new THREE.Vector3(0, 1, 0);
  const wish = new THREE.Vector3();
  const tmpEuler = new THREE.Euler(0, 0, 0, 'YXZ');

  function update(dt) {
    tmpEuler.set(pitch, yaw, 0);
    camera.quaternion.setFromEuler(tmpEuler);

    fwd.set(0, 0, -1).applyQuaternion(camera.quaternion);
    rgt.set(1, 0,  0).applyQuaternion(camera.quaternion);

    wish.set(0, 0, 0);
    if (keys.has('KeyW')) wish.add(fwd);
    if (keys.has('KeyS')) wish.sub(fwd);
    if (keys.has('KeyD')) wish.add(rgt);
    if (keys.has('KeyA')) wish.sub(rgt);
    if (keys.has('KeyE')) wish.add(UP);
    if (keys.has('KeyC')) wish.sub(UP);

    if (wish.lengthSq() > 0) wish.normalize().multiplyScalar(MOVE_SPEED);
    const alpha = 1 - Math.exp(-DAMP_TC * dt);
    velocity.lerp(wish, alpha);
    camera.position.addScaledVector(velocity, dt);
  }

  return {
    update,
    get lastWasDrag()  { return lastWasDrag; },
    set lastWasDrag(v) { lastWasDrag = v; },
  };
})();

// =====================================================================
//   WEBXR — only mount the entry button if WebXR is actually supported.
//   No "VR NOT SUPPORTED" stub for users that have no headset.
// =====================================================================
(async () => {
  if (!('xr' in navigator) || !navigator.xr) return;
  try {
    const ok = await navigator.xr.isSessionSupported('immersive-vr');
    if (ok) document.body.appendChild(VRButton.createButton(renderer));
  } catch (e) { /* unsupported — silently skip */ }
})();

// XR session handlers — only WebGLRenderer has these events; WebGPURenderer's xr API is still WIP
if (renderer.xr && typeof renderer.xr.addEventListener === 'function') {
  renderer.xr.addEventListener('sessionstart', () => {
    bookGroup.scale.setScalar(0.5);
    bookGroup.position.set(0, 1.3, -0.55);
    document.getElementById('hud').style.display = 'none';
  });
  renderer.xr.addEventListener('sessionend', () => {
    bookGroup.scale.setScalar(1.0);
    bookGroup.position.set(0, 0, 0);
    document.getElementById('hud').style.display = '';
  });
}

// =====================================================================
//   RESIZE
// =====================================================================
window.addEventListener('resize', () => {
  camera.aspect = innerWidth / innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
});

// =====================================================================
//   ANIMATION LOOP
// =====================================================================
const clock = new THREE.Clock();
function animate() {
  const dt = Math.min(clock.getDelta(), 1 / 30);
  const t = clock.elapsedTime;
  flyCam.update(dt);

  // candle flicker — only when candles exist (skipped on low-perf devices)
  keyLight.intensity = 3.2 * (1 + Math.sin(t * 8.3) * 0.03 + Math.sin(t * 17.1) * 0.015);
  if (candle1) candle1.intensity = 4 * (1 + Math.sin(t * 5.7 + 0.6) * 0.18 + Math.sin(t * 13.2 + 1.1) * 0.10);
  if (candle2) candle2.intensity = 3 * (1 + Math.sin(t * 4.9 + 1.3) * 0.16 + Math.sin(t * 11.6 + 0.4) * 0.09);
  // 12 cathedral candle flames flicker independently (size scale + Y-bob)
  const flameAux = cathedral && cathedral.group && cathedral.group.userData.flameAux;
  if (flameAux) {
    for (let i = 0; i < flameAux.length; i++) {
      const fl = flameAux[i];
      const f = 0.85 + Math.sin(t * 9.5 + i * 1.3) * 0.10 + Math.sin(t * 18.4 + i) * 0.06;
      fl.scale.set(f, f, f);
      fl.position.y = 1.05 + Math.sin(t * 6.2 + i * 0.7) * 0.012;
    }
  }

  // dust drift — skipped on low-perf (dust is null)
  if (dust && dust.geometry) {
    const arr = dust.geometry.attributes.position.array;
    const sp = dust.userData.speeds;
    for (let i = 0; i < sp.length; i++) {
      arr[i*3+1] += sp[i] * dt * 0.4;
      arr[i*3]   += Math.sin(t * 0.5 + i) * 0.0014;
      arr[i*3+2] += Math.cos(t * 0.4 + i * 1.7) * 0.0012;
      if (arr[i*3+1] > 5) {
        arr[i*3+1] = -1;
        arr[i*3]   = (Math.random() - 0.5) * 8;
        arr[i*3+2] = (Math.random() - 0.5) * 6;
      }
    }
    dust.geometry.attributes.position.needsUpdate = true;
  }

  stepDelayedPage(dt);

  keyframePlayer.update(dt);   // DOM-target animations (photo modal open/close)

  // Re-center the book group: when CLOSED, slide it so the (single-sided) page
  // stack is centred; when OPEN, the spine should be at x=0 so both halves are
  // symmetric. Smooth lerp avoids a visible jolt during the transition.
  const _isBookClosed = (delayedPage === 0) || (delayedPage === PAGES.length);
  const _targetGroupX = _isBookClosed ? -PAGE_WIDTH / 2 : 0;
  bookGroup.position.x = THREE.MathUtils.lerp(bookGroup.position.x, _targetGroupX, 0.12);

  for (const p of pages) {
    const isOpened = delayedPage > p.number;
    p.setOpened(isOpened);
    p.update(dt, delayedPage, _isBookClosed);
  }

  renderer.render(scene, camera);
}

// =====================================================================
//   BOOTSTRAP — async (WebGPU needs init)
// =====================================================================
(async () => {
  const bootStart = performance.now();
  if (renderer.init) await renderer.init();
  await setupEnvironment();
  renderer.setAnimationLoop(animate);
  await buildBook();
  updateUI();
  // Drain any goToSheet message that arrived before pages were built.
  if (_pendingGoTo !== null) {
    goToPage(_pendingGoTo);
    delayedPage = targetPage;
    updateUI();
    _pendingGoTo = null;
  }

  // Warm up the wawa rig — pages start with bones at zero rotation and
  // need many frames of dampAngle() to converge to the closed-cover
  // pose. Without this the user saw all the sheets flutter for ~0.7 s
  // after the loader hid. Run ~120 simulated frames now (∼2 s of
  // settling at 60 fps) so the book is already in its final pose by
  // the time the curtain lifts.
  for (let warm = 0; warm < 120; warm++) {
    for (const p of pages) p.update(1 / 60, 0, true);
  }

  // Hold the loading curtain a little longer (the user wanted a 2-3 s
  // pause) AND make sure the book has fully settled before we reveal
  // the scene.
  const MIN_LOADING_MS = 2200;
  const elapsed = performance.now() - bootStart;
  const wait = Math.max(0, MIN_LOADING_MS - elapsed);
  setTimeout(() => {
    document.getElementById('loading').classList.add('hidden');
    // Book starts CLOSED on the cover, both standalone and embedded.
    // The user opens it themselves via ΕΠΟΜΕΝΗ / Arrow keys / a click
    // on the right-hand cover face.
  }, wait);
})();
</script>
</ImmersiveLayout>

