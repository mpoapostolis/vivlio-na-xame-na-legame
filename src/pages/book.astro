function makeEdgeTexture() {
  const c = document.createElement('canvas'); c.width = 256; c.height = 256;
  const ctx = c.getContext('2d');
  // Vertical gradient — top dark, bottom warm cream
  const g = ctx.createLinearGradient(0, 0, 0, 256);
  g.addColorStop(0, '#dbcc9d'); g.addColorStop(0.4, '#cdb37e'); g.addColorStop(1, '#9c7e4f');
  ctx.fillStyle = g; ctx.fillRect(0, 0, 256, 256);
  // Densely-packed horizontal lines simulating a stack of page edges
  for (let y = 0; y < 256; y += 1) {
    const tone = 0.6 + Math.random() * 0.4;
    const isDark = Math.random() < 0.18;
    if (isDark) {
      ctx.fillStyle = `rgba(${40+Math.random()*35},${28+Math.random()*22},${12+Math.random()*15},${0.18+Math.random()*0.18})`;
    } else {
      ctx.fillStyle = `rgba(${190*tone+Math.random()*30},${165*tone+Math.random()*25},${110*tone+Math.random()*20},${0.08+Math.random()*0.10})`;
    }
    ctx.fillRect(0, y, 256, 1);
  }
  // Speckles / age dots
  for (let i = 0; i < 800; i++) {
    ctx.fillStyle = `rgba(${50+Math.random()*60},${30+Math.random()*30},${10+Math.random()*15},${Math.random()*0.22})`;
    ctx.fillRect(Math.random()*256, Math.random()*256, 1, 1);
  }
  // Sparse golden flecks suggesting subtle gilding
  for (let i = 0; i < 60; i++) {
    ctx.fillStyle = `rgba(255, ${200+Math.random()*40}, ${130+Math.random()*60}, ${0.18+Math.random()*0.24})`;
    ctx.fillRect(Math.random()*256, Math.random()*256, 2, 1);
  }
  const t = new THREE.CanvasTexture(c); t.colorSpace = THREE.SRGBColorSpace;
  t.wrapS = t.wrapT = THREE.RepeatWrapping; return t;
}
const edgeTex = makeEdgeTexture();

function makeLeatherTexture() {
  const c = document.createElement('canvas'); c.width = c.height = 512;
  const ctx = c.getContext('2d');
  ctx.fillStyle = '#3a1e0e'; ctx.fillRect(0, 0, 512, 512);
  // Leather grain — densely packed dark dots
  for (let i = 0; i < 18000; i++) {
    const a = Math.random() * 0.18;
    ctx.fillStyle = `rgba(0,0,0,${a})`;
    ctx.fillRect(Math.random()*512, Math.random()*512, 1.2, 1.2);
  }
  // Highlight specks
  for (let i = 0; i < 4000; i++) {
    ctx.fillStyle = `rgba(255, 220, 160, ${Math.random() * 0.05})`;
    ctx.fillRect(Math.random()*512, Math.random()*512, 1.4, 1.4);
  }
  // Subtle radial highlight
  const rg = ctx.createRadialGradient(256, 256, 0, 256, 256, 360);
  rg.addColorStop(0, 'rgba(120, 80, 40, 0.30)');
  rg.addColorStop(1, 'rgba(120, 80, 40, 0)');
  ctx.fillStyle = rg; ctx.fillRect(0, 0, 512, 512);
  const t = new THREE.CanvasTexture(c); t.colorSpace = THREE.SRGBColorSpace;
  t.wrapS = t.wrapT = THREE.RepeatWrapping;
  return t;
}
const leatherTex = makeLeatherTexture();

function makePaperNormalMap() {
  const SIZE = 512;
  const c = document.createElement('canvas'); c.width = c.height = SIZE;
  const ctx = c.getContext('2d');
  const h = new Float32Array(SIZE * SIZE).fill(0.5);
  for (let i = 0; i < 60000; i++) {
    const x = Math.floor(Math.random()*SIZE), y = Math.floor(Math.random()*SIZE);
    h[y*SIZE+x] += (Math.random()-0.5) * 0.35;
  }
  for (let i = 0; i < 350; i++) {
    let x = Math.random()*SIZE, y = Math.random()*SIZE;
    const dx = (Math.random()-0.5)*2, dy = (Math.random()-0.5)*2;
    const len = 6 + Math.random()*18;
    const intensity = (Math.random()-0.5) * 0.18;
    for (let s = 0; s < len; s++) {
      const ix = Math.floor(x+dx*s), iy = Math.floor(y+dy*s);
      if (ix>=0 && ix<SIZE && iy>=0 && iy<SIZE) h[iy*SIZE+ix] += intensity;
    }
  }
  const img = ctx.createImageData(SIZE, SIZE);
  const strength = 3.5;
  for (let y = 0; y < SIZE; y++) for (let x = 0; x < SIZE; x++) {
    const xL = h[y*SIZE + ((x-1+SIZE)%SIZE)];
    const xR = h[y*SIZE + ((x+1)%SIZE)];
    const yU = h[((y-1+SIZE)%SIZE)*SIZE + x];
    const yD = h[((y+1)%SIZE)*SIZE + x];
    const dx = (xR-xL)*strength, dy = (yD-yU)*strength;
    const nx = -dx, ny = -dy, nz = 1;
    const len = Math.sqrt(nx*nx + ny*ny + nz*nz);
    const idx = (y*SIZE + x) * 4;
    img.data[idx]   = (nx/len * 0.5 + 0.5) * 255;
    img.data[idx+1] = (ny/len * 0.5 + 0.5) * 255;
    img.data[idx+2] = (nz/len * 0.5 + 0.5) * 255;
    img.data[idx+3] = 255;
  }
  ctx.putImageData(img, 0, 0);
  const t = new THREE.CanvasTexture(c);
  t.wrapS = t.wrapT = THREE.RepeatWrapping;
  t.repeat.set(5, 7);
  return t;
}
const paperNormalTex = makePaperNormalMap();

