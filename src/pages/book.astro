// =====================================================================
//   HTML BUILDERS
// =====================================================================
function el(tag, cls, html) { const e = document.createElement(tag); if (cls) e.className = cls; if (html != null) e.innerHTML = html; return e; }
function escape(s) { return String(s).normalize('NFC').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function cover(title, subtitle, meta) {
  const root = el('div', 'render-page cover');
  const inner = el('div', 'cover-inner');
  inner.appendChild(el('span','cnr tl')); inner.appendChild(el('span','cnr tr'));
  inner.appendChild(el('span','cnr bl')); inner.appendChild(el('span','cnr br'));
  inner.appendChild(el('div','cover-orn','✦'));
  const t = el('div','cover-title'); t.textContent = title; inner.appendChild(t);
  inner.appendChild(el('div','cover-divider'));
  inner.appendChild(el('div','cover-subtitle', escape(subtitle)));
  const orn2 = el('div','cover-orn','❦'); orn2.style.fontSize='40px'; orn2.style.marginTop='24px'; inner.appendChild(orn2);
  const m = el('div','cover-meta'); m.textContent = meta.toUpperCase().split('').join('  '); inner.appendChild(m);
  root.appendChild(inner);
  return { dom: root, photos: [] };
}

function page(data) {
  const root = el('div','render-page');
  const photos = [];
  if (data.eyebrow) root.appendChild(el('div','eyebrow', escape(data.eyebrow)));
  if (data.h1) { const h = el('h1'); h.innerHTML = escape(data.h1).replace(/\n/g,'<br>'); root.appendChild(h); }
  if (data.h2) { const h = el('h2'); h.innerHTML = escape(data.h2).replace(/\n/g,'<br>'); root.appendChild(h); }
  if (data.date) root.appendChild(el('div','date', escape(data.date)));
  root.appendChild(el('div','rule'));
  for (const b of data.blocks || []) {
    switch (b.type) {
      case 'lead':  root.appendChild(el('p','lead', escape(b.text))); break;
      case 'p':     root.appendChild(el('p', null, escape(b.text))); break;
      case 'quote': root.appendChild(el('blockquote', null, escape(b.text))); break;
      case 'ul': {
        const ul = el('ul');
        for (const it of b.items) ul.appendChild(el('li', null, escape(it)));
        root.appendChild(ul); break;
      }
      case 'toc': {
        const wrap = el('div','toc');
        for (const it of b.items) {
          const r = el('div','toc-row');
          r.appendChild(el('div','num', escape(it.num)));
          r.appendChild(el('div','name', escape(it.name)));
          r.appendChild(el('div','year', escape(it.year)));
          wrap.appendChild(r);
        }
        root.appendChild(wrap); break;
      }
      case 'stat': {
        const s = el('div','stat');
        s.appendChild(el('span','label', escape(b.label)));
        s.appendChild(el('span','value', escape(b.value)));
        root.appendChild(s); break;
      }
      case 'meta': {
        const m = el('div','meta'); m.innerHTML = escape(b.text).replace(/\n/g,'<br>');
        root.appendChild(m); break;
      }
      case 'photo': {
        const fig = el('div','photo');
        const img = el('img'); img.src = b.src; img.crossOrigin = 'anonymous'; fig.appendChild(img);
        fig.appendChild(el('div','pop-hint','⛶ μεγέθυνση'));
        fig.appendChild(el('span','cap', escape(b.cap || '')));
        root.appendChild(fig);
        photos.push({ src: b.src, title: b.title || '', desc: b.desc || '', italic: b.italic || '', cap: b.cap || '', figEl: fig });
        break;
      }
    }
  }
  if (data.folio) { const f = el('div','folio'); f.textContent = `— ${data.folio} —`; root.appendChild(f); }
  return { dom: root, photos };
}

// =====================================================================
//   HTML → CANVAS
// =====================================================================
const RT = document.getElementById('render-target');
const TEX_W = 2400, TEX_H = 3200;  // 1200 × 1600 at scale=2 — sharper text

async function renderHtmlToCanvas(htmlSpec) {
  RT.innerHTML = '';
  RT.appendChild(htmlSpec.dom);
  const imgs = [...htmlSpec.dom.querySelectorAll('img')];
  await Promise.all(imgs.map(im => im.complete ? Promise.resolve() : new Promise(res => { im.onload = im.onerror = res; })));
  await new Promise(r => requestAnimationFrame(r));
  await document.fonts.ready;

  const rootRect = htmlSpec.dom.getBoundingClientRect();
  const SCALE = 2;
  for (const ph of htmlSpec.photos) {
    const r = ph.figEl.getBoundingClientRect();
    ph.bbox = {
      x: (r.left - rootRect.left) * SCALE, y: (r.top - rootRect.top) * SCALE,
      w: r.width * SCALE, h: r.height * SCALE,
    };
    delete ph.figEl;
  }

  const _err = console.error;
  console.error = (...a) => {
    const s = a.map(x => String(x ?? '')).join(' ');
    if (s.includes('modern-screenshot') || s.includes('cssRules') || s.includes('CSS rules')) return;
    _err.apply(console, a);
  };
  const canvas = await domToCanvas(htmlSpec.dom, {
    width: 1200, height: 1600, scale: SCALE, backgroundColor: null, font: false,
  });
  console.error = _err;

  RT.removeChild(htmlSpec.dom);
  return canvas;
}

// =====================================================================
//   SHARED PAGE GEOMETRY — DIRECT FROM WAWA SENSEI
// =====================================================================
const pageGeometry = new THREE.BoxGeometry(
  PAGE_WIDTH, PAGE_HEIGHT, PAGE_DEPTH, PAGE_SEGMENTS, 2
);
pageGeometry.translate(PAGE_WIDTH / 2, 0, 0);

{
  const position = pageGeometry.attributes.position;
  const vertex = new THREE.Vector3();
  const skinIndexes = [];
  const skinWeights = [];

  for (let i = 0; i < position.count; i++) {
    vertex.fromBufferAttribute(position, i);
    const x = vertex.x;
    const skinIndex = Math.max(0, Math.floor(x / SEGMENT_WIDTH));
    const skinWeight = (x % SEGMENT_WIDTH) / SEGMENT_WIDTH;
    skinIndexes.push(skinIndex, skinIndex + 1, 0, 0);
    skinWeights.push(1 - skinWeight, skinWeight, 0, 0);
  }
  pageGeometry.setAttribute('skinIndex', new THREE.Uint16BufferAttribute(skinIndexes, 4));
  pageGeometry.setAttribute('skinWeight', new THREE.Float32BufferAttribute(skinWeights, 4));
}

// =====================================================================
//   PAPER EDGE TEXTURE & PROCEDURAL NORMAL
// =====================================================================
function makeEdgeTexture() {
  const c = document.createElement('canvas'); c.width = 256; c.height = 256;
  const ctx = c.getContext('2d');
  // Vertical gradient — top dark, bottom warm cream
  const g = ctx.createLinearGradient(0, 0, 0, 256);
  g.addColorStop(0, '#dbcc9d'); g.addColorStop(0.4, '#cdb37e'); g.addColorStop(1, '#9c7e4f');
  ctx.fillStyle = g; ctx.fillRect(0, 0, 256, 256);
