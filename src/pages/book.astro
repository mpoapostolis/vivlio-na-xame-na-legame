function updateUI() {
  document.getElementById('cur').textContent = numerals[delayedPage] || delayedPage;
  document.getElementById('tot').textContent = numerals[PAGES.length] || PAGES.length;
  document.getElementById('prev').disabled = targetPage <= 0;
  document.getElementById('next').disabled = targetPage >= PAGES.length;
  const strip = document.getElementById('strip');
  if (strip.children.length === 0) {
    for (let i = 0; i <= PAGES.length; i++) {
      const b = document.createElement('button'); b.className = 'dot';
      b.addEventListener('click', () => { ensureAudio(); goToPage(i); });
      strip.appendChild(b);
    }
  }
  Array.from(strip.children).forEach((d, i) => d.classList.toggle('active', i === targetPage));
}
document.getElementById('prev').addEventListener('click', () => { ensureAudio(); goToPage(targetPage - 1); });
document.getElementById('next').addEventListener('click', () => { ensureAudio(); goToPage(targetPage + 1); });
window.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === ' ') { ensureAudio(); goToPage(targetPage + 1); }
  if (e.key === 'ArrowLeft')                    { ensureAudio(); goToPage(targetPage - 1); }
  if (e.key === 'Escape') { closeModal(); stopNarration(); }
});

// =====================================================================
//   PHOTO LIFTS OFF THE PAGE — image rises from book + info card beside
// =====================================================================

// Photo modal — HTML #modal (no 3D world meshes). Defensive close: anywhere
// outside the .panel content closes; X button closes; Esc closes.
const photoView = { active: false, closing: false };
const modalEl      = document.getElementById('modal');
const modalPanel   = modalEl ? modalEl.querySelector('.panel') : null;
const modalCloseEl = document.getElementById('modal-close');
const modalImg     = document.getElementById('modal-img');
const modalEyebrow = document.getElementById('modal-eyebrow');
const modalTitle   = document.getElementById('modal-title');
const modalDesc    = document.getElementById('modal-desc');
const modalItalic  = document.getElementById('modal-italic');

function cleanupPhotoView() {
  photoView.active = false;
  photoView.closing = false;
}

async function openModal(photo /*, hitPoint */) {
  if (photoView.active && !photoView.closing) return;
  cleanupPhotoView();

  modalImg.src = photo.src;
  modalImg.alt = photo.title || photo.cap || '';
  modalEyebrow.textContent = 'φωτογραφία · ἀπὸ τὸ ἀρχεῖον';
  modalTitle.textContent   = photo.title || photo.cap || '';
  modalDesc.textContent    = photo.desc  || '';
  modalItalic.textContent  = photo.italic || '';
  modalItalic.style.display = photo.italic ? '' : 'none';

  modalEl.classList.add('open');
  modalEl.setAttribute('aria-hidden', 'false');
  photoView.active = true;
  photoView.closing = false;
  playPop();
  setTimeout(() => playPhotoNarration(photo.src), 350);
}

function closeModal() {
  if (!photoView.active || photoView.closing) return;
  photoView.closing = true;
  stopNarration();
  modalEl.classList.remove('open');
  modalEl.setAttribute('aria-hidden', 'true');
  setTimeout(cleanupPhotoView, 500);
}

// (A) X button — explicit close, stop propagation so nothing else interferes
modalCloseEl.addEventListener('click', e => { e.stopPropagation(); e.preventDefault(); closeModal(); });
modalCloseEl.addEventListener('touchend', e => { e.stopPropagation(); e.preventDefault(); closeModal(); });

// (B) Clicking the dim backdrop (the #modal element, not the panel) closes
modalEl.addEventListener('click', e => {
  if (e.target === modalEl) closeModal();
});

// (C) Clicking the panel content does NOT close — stop propagation here, but
//     ALLOW the close button inside to keep working (it uses stopPropagation
//     in its own handler before this one fires).
modalPanel.addEventListener('click', e => { e.stopPropagation(); });

// =====================================================================
//   PICKING — raycaster on page meshes; UV → photo bbox lookup
// =====================================================================
const raycaster = new THREE.Raycaster();
const ndc = new THREE.Vector2();

function pickFromEvent(e) {
  const r = renderer.domElement.getBoundingClientRect();
  ndc.x = ((e.clientX - r.left) / r.width) * 2 - 1;
  ndc.y = -((e.clientY - r.top) / r.height) * 2 + 1;
  raycaster.setFromCamera(ndc, camera);
  const meshes = pages.map(p => p.mesh);
  const hits = raycaster.intersectObjects(meshes, false);
  return hits.length ? hits[0] : null;
}

renderer.domElement.addEventListener('pointermove', e => {
  const hit = pickFromEvent(e);
  if (hit && hit.uv) {
    const page = hit.object.userData.page;
    page.highlighted = true;
    document.body.style.cursor = 'pointer';
  } else {
    for (const p of pages) p.highlighted = false;
    document.body.style.cursor = '';
  }
  // clear other pages
  if (hit) {
    const page = hit.object.userData.page;
    for (const p of pages) if (p !== page) p.highlighted = false;
  }
});

renderer.domElement.addEventListener('click', e => {
  // If photo lift-off is active, any click closes it
  if (photoView.active && !photoView.closing) { closeModal(); return; }

  const hit = pickFromEvent(e);
  if (!hit) return;
  ensureAudio();
  const page = hit.object.userData.page;
  if (!hit.uv) { goToPage(page.lastOpened ? page.number : page.number + 1); return; }

  const faceIdx = hit.face ? hit.face.materialIndex : -1;
  const isFront = faceIdx === 4;
  const isBack  = faceIdx === 5;
  if (!isFront && !isBack) {
    goToPage(page.lastOpened ? page.number : page.number + 1);
    return;
  }
  const photos = isFront ? page.frontPhotos : page.backPhotos;
  if (!photos.length) {
    goToPage(page.lastOpened ? page.number : page.number + 1);
    return;
  }

  let u = hit.uv.x;
  const v = 1 - hit.uv.y;
  if (isBack) u = 1 - u;
  const px = u * TEX_W;
  const py = v * TEX_H;
  for (const ph of photos) {
    if (!ph.bbox) continue;
    const b = ph.bbox;
    if (px >= b.x && px <= b.x + b.w && py >= b.y && py <= b.y + b.h) {
      openModal(ph, hit.point); return;
    }
  }
  goToPage(page.lastOpened ? page.number : page.number + 1);
});

// =====================================================================
//   ORBIT CONTROLS
// =====================================================================
const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.dampingFactor = 0.06;
controls.enablePan = false;
controls.minDistance = 1.6;          // user can lean in close
controls.maxDistance = 5.5;
controls.minPolarAngle = 0.2;
controls.maxPolarAngle = Math.PI * 0.6;
controls.target.set(0, 0, 0);

// =====================================================================
//   WEBXR — only mount the entry button if WebXR is actually supported.
//   No "VR NOT SUPPORTED" stub for users that have no headset.
// =====================================================================
(async () => {
  if (!('xr' in navigator) || !navigator.xr) return;
  try {
    const ok = await navigator.xr.isSessionSupported('immersive-vr');
    if (ok) document.body.appendChild(VRButton.createButton(renderer));
  } catch (e) { /* unsupported — silently skip */ }
})();

// XR session handlers — only WebGLRenderer has these events; WebGPURenderer's xr API is still WIP
if (renderer.xr && typeof renderer.xr.addEventListener === 'function') {
  renderer.xr.addEventListener('sessionstart', () => {
    bookGroup.scale.setScalar(0.5);
    bookGroup.position.set(0, 1.3, -0.55);
    document.getElementById('hud').style.display = 'none';
  });
  renderer.xr.addEventListener('sessionend', () => {
    bookGroup.scale.setScalar(1.0);
    bookGroup.position.set(0, 0, 0);
    document.getElementById('hud').style.display = '';
  });
}

// =====================================================================
//   RESIZE
// =====================================================================
window.addEventListener('resize', () => {
  camera.aspect = innerWidth / innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
});

// =====================================================================
//   ANIMATION LOOP
// =====================================================================
const clock = new THREE.Clock();
function animate() {
  const dt = Math.min(clock.getDelta(), 1 / 30);
  const t = clock.elapsedTime;
  controls.update();

  // candle flicker — only when candles exist (skipped on low-perf devices)
  keyLight.intensity = 3.2 * (1 + Math.sin(t * 8.3) * 0.03 + Math.sin(t * 17.1) * 0.015);
  if (candle1) candle1.intensity = 4 * (1 + Math.sin(t * 5.7 + 0.6) * 0.18 + Math.sin(t * 13.2 + 1.1) * 0.10);
  if (candle2) candle2.intensity = 3 * (1 + Math.sin(t * 4.9 + 1.3) * 0.16 + Math.sin(t * 11.6 + 0.4) * 0.09);

  // dust drift — skipped on low-perf (dust is null)
  if (dust && dust.geometry) {
    const arr = dust.geometry.attributes.position.array;
    const sp = dust.userData.speeds;
    for (let i = 0; i < sp.length; i++) {
      arr[i*3+1] += sp[i] * dt * 0.4;
      arr[i*3]   += Math.sin(t * 0.5 + i) * 0.0014;
      arr[i*3+2] += Math.cos(t * 0.4 + i * 1.7) * 0.0012;
      if (arr[i*3+1] > 5) {
        arr[i*3+1] = -1;
        arr[i*3]   = (Math.random() - 0.5) * 8;
        arr[i*3+2] = (Math.random() - 0.5) * 6;
      }
    }
    dust.geometry.attributes.position.needsUpdate = true;
  }

  stepDelayedPage(dt);

  for (const p of pages) {
    const isOpened = delayedPage > p.number;
    const isBookClosed = (delayedPage === 0) || (delayedPage === PAGES.length);
    p.setOpened(isOpened);
    p.update(dt, delayedPage, isBookClosed);
  }


  renderer.render(scene, camera);
}

// =====================================================================
//   BOOTSTRAP — async (WebGPU needs init)
// =====================================================================
(async () => {
  if (renderer.init) await renderer.init();
  await setupEnvironment();
  renderer.setAnimationLoop(animate);
  await buildBook();
  updateUI();
  setTimeout(() => document.getElementById('loading').classList.add('hidden'), 200);
  // No startup animation — book appears already in its final pose.
})();
</script>
</ImmersiveLayout>

