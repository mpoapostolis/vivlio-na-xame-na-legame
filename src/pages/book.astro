async function buildBook() {
  const total = PAGES.length;
  const progress = document.getElementById('progress');

  for (let i = 0; i < total; i++) {
    progress.textContent = `${i*2+1} / ${total*2}`;
    const fc = await renderHtmlToCanvas(PAGES[i].front);
    progress.textContent = `${i*2+2} / ${total*2}`;
    const bc = await renderHtmlToCanvas(PAGES[i].back);

    const ft = new THREE.CanvasTexture(fc);
    ft.colorSpace = THREE.SRGBColorSpace; ft.anisotropy = 16; ft.needsUpdate = true;
    const bt = new THREE.CanvasTexture(bc);
    bt.colorSpace = THREE.SRGBColorSpace; bt.anisotropy = 16; bt.needsUpdate = true;

    const p = new Page(i, ft, bt, total, PAGES[i].front.photos, PAGES[i].back.photos);
    pages.push(p);
    bookGroup.add(p.group);
  }
}

// =====================================================================
//   PAGE TURN STATE (delayed page like wawa)
// =====================================================================
let targetPage = 0, delayedPage = 0, pageStepTimer = 0;
function goToPage(n) {
  closeModal();
  const clamped = THREE.MathUtils.clamp(n, 0, PAGES.length);
  // Stop any active narration on page change so they don't overlap.
  if (clamped !== targetPage && typeof stopNarration === 'function') stopNarration();
  targetPage = clamped;
  updateUI();
}
function stepDelayedPage(dt) {
  if (delayedPage === targetPage) return;
  pageStepTimer += dt;
  const interval = Math.abs(targetPage - delayedPage) > 2 ? 0.05 : 0.15;
  if (pageStepTimer >= interval) {
    pageStepTimer = 0;
    delayedPage += targetPage > delayedPage ? 1 : -1;
    playPageFlip();
    updateUI();
  }
}

// =====================================================================
//   AUDIO
// =====================================================================
let audioCtx = null;
function ensureAudio() { if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
function playPageFlip() {
  if (!audioCtx) return;
  const dur = 0.18, sr = audioCtx.sampleRate;
  const buf = audioCtx.createBuffer(1, sr * dur, sr);
  const d = buf.getChannelData(0);
  for (let i = 0; i < d.length; i++) {
    const t = i / d.length; const env = Math.exp(-t * 14) * (1 - t);
    d[i] = (Math.random() * 2 - 1) * env;
  }
  const src = audioCtx.createBufferSource(); src.buffer = buf;
  const fl = audioCtx.createBiquadFilter(); fl.type = 'bandpass'; fl.frequency.value = 2500 + Math.random()*800; fl.Q.value = 0.7;
  const g = audioCtx.createGain(); g.gain.value = 0.3;
  src.connect(fl); fl.connect(g); g.connect(audioCtx.destination); src.start();
}
function playPop() {
  if (!audioCtx) return;
  const o = audioCtx.createOscillator(); const g = audioCtx.createGain();
  o.type = 'sine';
  o.frequency.setValueAtTime(660, audioCtx.currentTime);
  o.frequency.exponentialRampToValueAtTime(330, audioCtx.currentTime + 0.2);
  g.gain.setValueAtTime(0.16, audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);
  o.connect(g); g.connect(audioCtx.destination); o.start(); o.stop(audioCtx.currentTime + 0.27);
}

// =====================================================================
//   NARRATION (recorded mp3) — per-page and per-photo
// =====================================================================
const NARRATION_BASE = '';   // PHOTO_NARRATION_MAP values are already absolute paths under /audio/
// Photo→narration map injected at build time from src/data/animations.ts
const PHOTO_NARRATION_MAP = JSON.parse(document.getElementById('photo-narrations-data').textContent);
let _narrationAudio = null;
let _narrationProgressTimer = null;

function _updateAudioBtn() {
  const btn = document.getElementById('audio-btn');
  const icon = document.getElementById('audio-icon');
  const prog = document.getElementById('audio-progress');
  if (!btn) return;
  const playing = _narrationAudio && !_narrationAudio.paused && !_narrationAudio.ended;
  btn.classList.toggle('playing', !!playing);
  icon.textContent = playing ? '⏸' : '▶';
  if (playing && _narrationAudio.duration) {
    prog.style.transform = 'scaleX(' + (_narrationAudio.currentTime / _narrationAudio.duration) + ')';
  } else {
    prog.style.transform = 'scaleX(0)';
  }
}
function playNarration(filename) {
  stopNarration();
  if (!filename) return;
  _narrationAudio = new Audio(NARRATION_BASE + filename);
  _narrationAudio.addEventListener('ended', () => { _updateAudioBtn(); });
  _narrationAudio.addEventListener('pause', _updateAudioBtn);
  _narrationAudio.addEventListener('play',  _updateAudioBtn);
  const p = _narrationAudio.play();
  if (p && p.catch) p.catch(err => { console.warn('[narration] play blocked:', err); });
  if (_narrationProgressTimer) clearInterval(_narrationProgressTimer);
  _narrationProgressTimer = setInterval(_updateAudioBtn, 200);
}
function stopNarration() {
  if (_narrationAudio) { _narrationAudio.pause(); _narrationAudio.currentTime = 0; _narrationAudio = null; }
  if (_narrationProgressTimer) { clearInterval(_narrationProgressTimer); _narrationProgressTimer = null; }
  _updateAudioBtn();
}
function toggleNarration() {
  if (_narrationAudio) {
    if (_narrationAudio.paused) _narrationAudio.play(); else _narrationAudio.pause();
    _updateAudioBtn();
  } else {
    playPageNarration(targetPage);
  }
}
function playPageNarration(idx) {
  if (idx < 0 || idx >= PAGES.length) return;
  playNarration('/audio/narration_p' + idx + '.mp3');
}
function playPhotoNarration(photoSrc) {
  const file = PHOTO_NARRATION_MAP[photoSrc];
  if (file) playNarration(file);
}
document.getElementById('audio-btn').addEventListener('click', () => { ensureAudio(); toggleNarration(); });

