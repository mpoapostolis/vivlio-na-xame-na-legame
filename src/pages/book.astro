// =====================================================================
//   CATHEDRAL INTERIOR — circular peristyle + dome + marble floor.
//   No walls (so the fly cam can roam freely between the columns); the
//   ring of columns + the dome overhead reads as a sacred interior. Each
//   element is exposed on `cathedral.{floor,columns,dome}` so the keyframe
//   editor can animate them by target name (e.g. `cathedral.dome` → scale).
// =====================================================================
// =====================================================================
//   CATHEDRAL OF SAINT ANDREW — Byzantine interior modelled on the real
//   Patras cathedral. Per the educational PDF:
//
//     "Ὁ κεντρικὸς τροῦλος περιστοιχίζεται ἀπὸ 12 ἄλλους χαμηλοτέρους
//      τρούλους-κωδωνοστάσια οἱ ὁποῖοι συμβολίζουν τὸν Ἰησοῦν Χριστὸν
//      μὲ τοὺς 12 Ἀποστόλους Του. Ὁ ἀρχικὸς σχεδιασμὸς προέβλεπε τὴν
//      ἐπικάλυψη ὅλων τῶν τρούλων μὲ φύλλα χαλκοῦ."
//
//   So we have a central dome on a drum + 12 satellite domes around it,
//   all in copper-bronze tones. 12 marble columns hold the perimeter,
//   each topped by a satellite dome. Twelve tall arched windows in the
//   drum (alpha-cut on a textured cylinder) admit a warm gold light from
//   the outside — the interior reads as bathed in candle + sunset light.
// =====================================================================
const cathedral = (() => {
  const group = new THREE.Group();
  group.name = 'cathedral';

  // Wider visibility — fog softened so the dome reads at distance.
  scene.fog.density = 0.022;

  // ── Materials (shared across all geometry) ─────────────────────────
  const MAT = {
    // Cream marble for floor, columns, drum walls.
    marble: new THREE.MeshStandardMaterial({
      color: 0xe6dac0, roughness: 0.52, metalness: 0.03, envMapIntensity: 1.0,
    }),
    // Darker marble for floor (more matte, less glare).
    floorMarble: new THREE.MeshStandardMaterial({
      color: 0x4a3826, roughness: 0.82, metalness: 0.04, envMapIntensity: 0.55,
    }),
    // Copper dome — the spec calls for copper sheets due to sea air.
    copper: new THREE.MeshStandardMaterial({
      color: 0x9a5e2a, roughness: 0.38, metalness: 0.78, envMapIntensity: 1.1,
    }),
    // Gold accents for cross + inlaid floor ring.
    gold: new THREE.MeshStandardMaterial({
      color: 0xc89a4c, roughness: 0.32, metalness: 0.92, envMapIntensity: 1.2,
    }),
    // Dark night sky visible through arched windows — looks like dusk.
    skyGlow: new THREE.MeshBasicMaterial({
      color: 0x18120a, side: THREE.BackSide,
    }),
  };

  // ── Procedural Byzantine floor pattern ─────────────────────────────
  // Concentric rings + 8-pointed star + radial gold spokes painted onto
  // a square canvas, mapped onto a CircleGeometry. Looks like a real
  // marble inlay floor from above.
  const floorTex = (() => {
    const cv = document.createElement('canvas');
    cv.width = 2048; cv.height = 2048;
    const g = cv.getContext('2d');
    const cx = cv.width / 2, cy = cv.height / 2, R = cv.width / 2;
    // Outer marble base
    g.fillStyle = '#4a3826'; g.fillRect(0, 0, cv.width, cv.height);
    // Subtle marble veining — thin random curves
    for (let i = 0; i < 24; i++) {
      g.strokeStyle = `rgba(${180 + Math.random()*40}, ${150 + Math.random()*30}, ${100 + Math.random()*30}, ${0.04 + Math.random() * 0.05})`;
      g.lineWidth = 0.5 + Math.random() * 1.5;
      g.beginPath();
      let x = Math.random() * cv.width, y = Math.random() * cv.height;
      g.moveTo(x, y);
      for (let s = 0; s < 60; s++) {
        x += (Math.random() - 0.5) * 80;
        y += (Math.random() - 0.5) * 80;
        g.lineTo(x, y);
      }
      g.stroke();
    }
    // Outer dark ring border
    g.strokeStyle = '#2a1a08'; g.lineWidth = 14;
    g.beginPath(); g.arc(cx, cy, R - 12, 0, Math.PI * 2); g.stroke();
    // Concentric gold rings
    [0.85, 0.65, 0.45, 0.30, 0.18].forEach((rRel, idx) => {
      g.strokeStyle = idx % 2 ? '#a07d3e' : '#c89a4c';
      g.lineWidth = idx === 0 ? 6 : 4;
      g.beginPath(); g.arc(cx, cy, R * rRel, 0, Math.PI * 2); g.stroke();
    });
    // 12 radial spokes from center to outer ring
    g.strokeStyle = '#7d5d2a'; g.lineWidth = 2;
    for (let i = 0; i < 12; i++) {
      const a = (i / 12) * Math.PI * 2;
      g.beginPath();
      g.moveTo(cx + Math.cos(a) * R * 0.30, cy + Math.sin(a) * R * 0.30);
      g.lineTo(cx + Math.cos(a) * R * 0.85, cy + Math.sin(a) * R * 0.85);
      g.stroke();
    }
    // 8-pointed star at center (Greek cross-derived)
    g.fillStyle = '#c89a4c';
    g.beginPath();
    for (let i = 0; i < 16; i++) {
      const a = (i / 16) * Math.PI * 2 - Math.PI / 2;
      const r = i % 2 ? R * 0.07 : R * 0.16;
      const px = cx + Math.cos(a) * r;
      const py = cy + Math.sin(a) * r;
      if (i === 0) g.moveTo(px, py); else g.lineTo(px, py);
    }
    g.closePath(); g.fill();
    // Inner gold disc
    g.fillStyle = '#e0bf6b';
    g.beginPath(); g.arc(cx, cy, R * 0.045, 0, Math.PI * 2); g.fill();
    const tex = new THREE.CanvasTexture(cv);
    tex.colorSpace = THREE.SRGBColorSpace;
    tex.anisotropy = 16;
    return tex;
  })();

  // ── Ground + podium so the cathedral doesn't float in the void ────
  // Three distinct vertical layers with proper Y separation so nothing
  // co-planar fights for depth pixels:
  //   y = -1.80  outdoor terrain plane
  //   y = -0.78  podium top (visible as a stone shelf around the floor)
  //   y = -0.70  stylobate step (1 ring outside the floor disc)
  //   y = -0.62  cathedral marble floor (interior)
  // const groundGeo = new THREE.PlaneGeometry(50, 50, 1, 1);
  // const groundMat = new THREE.MeshStandardMaterial({
  //   color: 0x35291b, roughness: 0.95, metalness: 0.02, envMapIntensity: 0.4,
  // });
  // const ground = new THREE.Mesh(groundGeo, groundMat);
  // ground.rotation.x = -Math.PI / 2;
  // ground.position.y = -1.80;
  // ground.receiveShadow = !IS_LOW_PERF;
  // group.add(ground);

  const FLOOR_RADIUS = 24;
  // Cylindrical stone podium — top at y=-0.78 (well below the floor),
  // bottom at y=-1.80 (touching the ground). Slight outward batter.
  const podiumH   = 1.02;
  const podiumGeo = new THREE.CylinderGeometry(FLOOR_RADIUS + 1.0, FLOOR_RADIUS + 1.5, podiumH, 64, 1);
  const podiumMat = new THREE.MeshStandardMaterial({
    color: 0xa89478, roughness: 0.66, metalness: 0.05,
    envMapIntensity: 0.7,
  });
  const podium = new THREE.Mesh(podiumGeo, podiumMat);
  podium.position.y = -1.80 + podiumH / 2;       // → top at -1.29 + 1.02 = -1.29 + 1.02 → -0.78
  podium.receiveShadow = !IS_LOW_PERF;
  group.add(podium);
  // Stylobate — short cylinder forming the step between podium top and
  // cathedral floor. Sits OUTSIDE the floor disc so the marble pattern
  // stays unobstructed and there's no co-planar fight.
  const stepGeo = new THREE.CylinderGeometry(FLOOR_RADIUS + 1.0, FLOOR_RADIUS + 1.0, 0.10, 96, 1);
  const step = new THREE.Mesh(stepGeo, MAT.marble);
  step.position.y = -0.73;                       // 0.05 above the podium top, 0.11 below floor
  group.add(step);
  const floor = new THREE.Mesh(
    new THREE.CircleGeometry(FLOOR_RADIUS, 96),
    new THREE.MeshStandardMaterial({
      map: floorTex, roughness: 0.7, metalness: 0.08,
      envMapIntensity: 0.65,
    }),
  );
  floor.rotation.x = -Math.PI / 2;
  floor.position.y = -0.62;
  floor.receiveShadow = !IS_LOW_PERF;
  floor.name = 'cathedral.floor';
  group.add(floor);

  // (gold ring + radial cross inlay are now painted into the floor
  // texture above, so we don't need extra ring/bar meshes any more.)

  // ── 12 columns in a regular dodecagon (Christ + 12 Apostles) ──────
  // Cathedral scaled up again so the camera has plenty of room to roam
  // between the lectern, the columns, and the walls.
  const COL_COUNT  = 12;
  const COL_RADIUS = 7.5;
  const COL_HEIGHT = 6.5;
  const colShaftGeo = new THREE.CylinderGeometry(0.20, 0.24, COL_HEIGHT, 32, 1);
  const colCapGeo   = new THREE.CylinderGeometry(0.36, 0.20, 0.45,       32, 1);
  const colCapAbacus= new THREE.BoxGeometry(0.88, 0.10, 0.88);
  const colBaseGeo  = new THREE.CylinderGeometry(0.32, 0.36, 0.30,       32, 1);
  const colBaseSocl = new THREE.BoxGeometry(0.78, 0.12, 0.78);
  const columns = [];
  for (let i = 0; i < COL_COUNT; i++) {
    const angle = (i / COL_COUNT) * Math.PI * 2;
    const x = Math.cos(angle) * COL_RADIUS;
    const z = Math.sin(angle) * COL_RADIUS;
    const col = new THREE.Group();
    col.position.set(x, -0.62, z);
    col.name = 'cathedral.column.' + i;
    // Shaft
    const shaft = new THREE.Mesh(colShaftGeo, MAT.marble);
    shaft.position.y = COL_HEIGHT / 2 + 0.30;
    shaft.castShadow = !IS_LOW_PERF;
    col.add(shaft);
    // Capital — a fluted cone with a square abacus on top.
    const cap = new THREE.Mesh(colCapGeo, MAT.marble);
    cap.position.y = COL_HEIGHT + 0.55;
    col.add(cap);
    const abacus = new THREE.Mesh(colCapAbacus, MAT.marble);
    abacus.position.y = COL_HEIGHT + 0.80;
    col.add(abacus);
    // Base — a square plinth with a rounded torus on top.
    const socle = new THREE.Mesh(colBaseSocl, MAT.marble);
    socle.position.y = 0.06;
    col.add(socle);
    const base = new THREE.Mesh(colBaseGeo, MAT.marble);
    base.position.y = 0.27;
    col.add(base);
    group.add(col);
    columns.push(col);
  }

  // ── Twelve satellite domes (Apostles) — one above each column ─────
  const SAT_DOME_RADIUS = 0.55;
  const satDomeGeo = new THREE.SphereGeometry(SAT_DOME_RADIUS, 24, 16, 0, Math.PI * 2, 0, Math.PI / 2);
  const satDrumGeo = new THREE.CylinderGeometry(SAT_DOME_RADIUS, SAT_DOME_RADIUS, 0.5, 16, 1);
  const satCrossV  = new THREE.BoxGeometry(0.02, 0.18, 0.02);
  const satCrossH  = new THREE.BoxGeometry(0.10, 0.02, 0.02);
  const satellites = [];
  for (let i = 0; i < COL_COUNT; i++) {
    const angle = (i / COL_COUNT) * Math.PI * 2;
    const x = Math.cos(angle) * COL_RADIUS;
    const z = Math.sin(angle) * COL_RADIUS;
    const sat = new THREE.Group();
    // Drum sits ON the shoulder roof (SHOULDER_Y = COL_HEIGHT + 0.55).
    // Anything higher gives a visible "floating" gap from outside.
    sat.position.set(x, COL_HEIGHT + 0.55, z);
    sat.name = 'cathedral.satellite.' + i;
    const drum = new THREE.Mesh(satDrumGeo, MAT.marble);
    drum.position.y = 0.25;
    sat.add(drum);
    const dome = new THREE.Mesh(satDomeGeo, MAT.copper);
    dome.position.y = 0.50;
    sat.add(dome);
    // Tiny gold cross on each satellite dome.
    const cv = new THREE.Mesh(satCrossV, MAT.gold);
    cv.position.y = 0.50 + SAT_DOME_RADIUS + 0.09;
    sat.add(cv);
    const ch = new THREE.Mesh(satCrossH, MAT.gold);
    ch.position.y = 0.50 + SAT_DOME_RADIUS + 0.13;
    sat.add(ch);
    group.add(sat);
    satellites.push(sat);
  }

  // ── Central drum + dome (Christ) ──────────────────────────────────
  // Drum is a cylinder of marble + 12 arched windows. Implement the
  // arches as alpha-cutout via a canvas texture so we get the look
  // without per-vertex window geometry.
  const DRUM_RADIUS = 3.5;
  const DRUM_HEIGHT = 1.5;
  const DRUM_Y = COL_HEIGHT + 1.0;

  // Procedural arch-window texture — marble base with 12 alpha-cut arches.
  // The cutouts use globalCompositeOperation='destination-out' so the
  // window areas become fully transparent; combined with alphaTest on
  // the material that gives hard-edged window openings the skybox
  // shows through from any angle. A gold frame is painted just outside
  // each cutout so the user sees a ring of light, not raw mesh edges.
  const drumTex = (() => {
    const cv = document.createElement('canvas');
    cv.width = 4096; cv.height = 1024;
    const g = cv.getContext('2d');
    // Marble base — opaque, will become the wall.
    g.fillStyle = '#e6dac0';
    g.fillRect(0, 0, cv.width, cv.height);
    // Subtle horizontal banding for stone texture.
    for (let y = 0; y < cv.height; y += 10) {
      g.fillStyle = `rgba(60,40,20,${0.012 + 0.018 * Math.sin(y * 0.03)})`;
      g.fillRect(0, y, cv.width, 4);
    }
    const arches = 12;
    const slot = cv.width / arches;
    const archW = slot * 0.38;
    const archH = cv.height * 0.66;
    const archTop = cv.height * 0.16;
    // Gold frame (drawn before the cutout so it remains visible as a ring).
    for (let i = 0; i < arches; i++) {
      const cx = i * slot + slot / 2;
      g.fillStyle = '#c89a4c';
      g.beginPath();
      g.roundRect(cx - archW/2 - 14, archTop - 14, archW + 28, archH + 28, archW/2 + 14);
      g.fill();
      g.fillStyle = '#a87a30';
      g.beginPath();
      g.roundRect(cx - archW/2 - 6, archTop - 6, archW + 12, archH + 12, archW/2 + 6);
      g.fill();
    }
    // Punch the actual window holes — destination-out makes the alpha 0.
    g.globalCompositeOperation = 'destination-out';
    for (let i = 0; i < arches; i++) {
      const cx = i * slot + slot / 2;
      g.beginPath();
      g.roundRect(cx - archW/2, archTop, archW, archH, archW/2);
      g.fill();
    }
    g.globalCompositeOperation = 'source-over';
    // Add thin mullions over the now-transparent area (drawn back in stone).
    g.fillStyle = '#3a2410';
    for (let i = 0; i < arches; i++) {
      const cx = i * slot + slot / 2;
      g.fillRect(cx - 3, archTop + archW/2, 6, archH - archW/2);
    }
    const tex = new THREE.CanvasTexture(cv);
    tex.colorSpace = THREE.SRGBColorSpace;
    tex.wrapS = THREE.RepeatWrapping;
    tex.anisotropy = 16;
    return tex;
  })();

  // alphaTest cuts hard at 0.5 — gives crisp window edges without
  // depth-sort issues that come with transparent materials.
  const drumMat = new THREE.MeshStandardMaterial({
    map: drumTex, transparent: true, alphaTest: 0.5,
    roughness: 0.55, metalness: 0.08,
    side: THREE.DoubleSide,
    envMapIntensity: 0.9,
  });
  const drum = new THREE.Mesh(
    new THREE.CylinderGeometry(DRUM_RADIUS, DRUM_RADIUS, DRUM_HEIGHT, 64, 1, true),
    drumMat,
  );
  drum.position.y = DRUM_Y;
  drum.name = 'cathedral.drum';
  group.add(drum);

  // Stone lintel under the drum + on top (a clean transition collar).
  const lintelTop = new THREE.Mesh(
    new THREE.TorusGeometry(DRUM_RADIUS + 0.05, 0.10, 16, 96),
    MAT.marble,
  );
  lintelTop.rotation.x = Math.PI / 2;
  lintelTop.position.y = DRUM_Y + DRUM_HEIGHT / 2;
  group.add(lintelTop);
  const lintelBot = lintelTop.clone();
  lintelBot.position.y = DRUM_Y - DRUM_HEIGHT / 2;
  group.add(lintelBot);

  // ── Byzantine fresco on the dome interior ─────────────────────────
  // Procedural canvas: dark-blue starry field, a frieze of 12 haloed
  // saints in arched niches near the rim, and a golden Pantocrator
  // medallion at the apex. Mapped onto the inside of the dome (BackSide),
  // it reads as a real frescoed cupola when the user looks up.
  const domeTex = (() => {
    const cv = document.createElement('canvas');
    cv.width = 4096; cv.height = 1024;
    const g = cv.getContext('2d');
    // Deep ultramarine sky base
    g.fillStyle = '#10182c'; g.fillRect(0, 0, cv.width, cv.height);
    // Vertical gradient — darker at the rim (bottom), gold-tinged at the apex (top).
    const grad = g.createLinearGradient(0, 0, 0, cv.height);
    grad.addColorStop(0,    'rgba(120,80,30,0.55)');
    grad.addColorStop(0.30, 'rgba(40,30,55,0.0)');
    grad.addColorStop(1,    'rgba(8,10,18,0.6)');
    g.fillStyle = grad; g.fillRect(0, 0, cv.width, cv.height);
    // Stars + tiny crosses sprinkled in the mid-band
    for (let i = 0; i < 220; i++) {
      const x = Math.random() * cv.width;
      const y = cv.height * 0.18 + Math.random() * cv.height * 0.55;
      const op = 0.4 + Math.random() * 0.55;
      const r = 1 + Math.random() * 2.5;
      g.fillStyle = `rgba(220, 180, 100, ${op})`;
      g.beginPath(); g.arc(x, y, r, 0, Math.PI * 2); g.fill();
      if (Math.random() > 0.65) {
        g.fillRect(x - r * 2, y - 0.5, r * 4, 1);
        g.fillRect(x - 0.5, y - r * 2, 1, r * 4);
      }
    }
    // Apex Pantocrator medallion — a tall narrow band at the top of the
    // canvas that wraps as a tight cap on the dome's pole.
    const apexH = cv.height * 0.15;
    const apexGrad = g.createLinearGradient(0, 0, 0, apexH);
    apexGrad.addColorStop(0, '#e0bf6b');
    apexGrad.addColorStop(1, '#a07d3e');
    g.fillStyle = apexGrad; g.fillRect(0, 0, cv.width, apexH);
    // Crosses repeated across the apex band
    g.fillStyle = '#3a2410';
    for (let i = 0; i < 24; i++) {
      const cx = (i + 0.5) * (cv.width / 24);
      const cy = apexH / 2;
      g.fillRect(cx - 14, cy - 3, 28, 6);
      g.fillRect(cx - 3, cy - 14, 6, 28);
    }
    // Frieze of 12 saint niches near the rim (bottom of canvas)
    const FRIEZE_Y = cv.height * 0.72;
    const FRIEZE_H = cv.height * 0.24;
    // Frieze background (deeper gold)
    const frGrad = g.createLinearGradient(0, FRIEZE_Y, 0, FRIEZE_Y + FRIEZE_H);
    frGrad.addColorStop(0, '#7d5d2a');
    frGrad.addColorStop(1, '#3a2418');
    g.fillStyle = frGrad; g.fillRect(0, FRIEZE_Y, cv.width, FRIEZE_H);
    // Borders top & bottom of frieze
    g.fillStyle = '#c89a4c'; g.fillRect(0, FRIEZE_Y - 4, cv.width, 4);
    g.fillStyle = '#a07d3e'; g.fillRect(0, FRIEZE_Y + FRIEZE_H - 4, cv.width, 4);
    // 12 arched niches with stylised haloed saints
    const niches = 12;
    const slot = cv.width / niches;
    for (let i = 0; i < niches; i++) {
      const ncx = i * slot + slot / 2;
      const w = slot * 0.7;
      const h = FRIEZE_H * 0.82;
      const top = FRIEZE_Y + FRIEZE_H * 0.08;
      // Niche apse (dark recess with arched top)
      g.fillStyle = '#1a1208';
      g.beginPath(); g.roundRect(ncx - w/2, top, w, h, [w/2, w/2, 0, 0]); g.fill();
      // Saint robe — alternating red & blue
      g.fillStyle = i % 2 ? '#7a2a1a' : '#1a2a5a';
      const robeTop = top + h * 0.50;
      g.beginPath();
      g.moveTo(ncx - w * 0.30, robeTop);
      g.lineTo(ncx + w * 0.30, robeTop);
      g.lineTo(ncx + w * 0.36, top + h * 0.96);
      g.lineTo(ncx - w * 0.36, top + h * 0.96);
      g.closePath(); g.fill();
      // Halo
      g.fillStyle = '#d4a85a';
      g.beginPath(); g.arc(ncx, top + h * 0.40, h * 0.16, 0, Math.PI * 2); g.fill();
      // Face hint
      g.fillStyle = '#caa088';
      g.beginPath(); g.arc(ncx, top + h * 0.40, h * 0.11, 0, Math.PI * 2); g.fill();
      // Tiny gold cross sceptre
      g.fillStyle = '#e0bf6b';
      g.fillRect(ncx + w * 0.06, top + h * 0.50, 2, h * 0.30);
      g.fillRect(ncx + w * 0.04, top + h * 0.55, 6, 2);
    }
    const tex = new THREE.CanvasTexture(cv);
    tex.colorSpace = THREE.SRGBColorSpace;
    tex.wrapS = THREE.RepeatWrapping;
    tex.anisotropy = 16;
    return tex;
  })();

  // Central dome — interior is the frescoed surface, BackSide so we see
  // the inside when looking up. Slight emissive so the Pantocrator glows
  // even when no direct light hits it.
  const DOME_RADIUS = DRUM_RADIUS;
  const domeGeo = new THREE.SphereGeometry(DOME_RADIUS, 64, 48, 0, Math.PI * 2, 0, Math.PI / 2);
  const domeIntMat = new THREE.MeshStandardMaterial({
    map: domeTex, roughness: 0.62, metalness: 0.06,
    side: THREE.BackSide, envMapIntensity: 0.55,
    emissive: 0x6a4818, emissiveIntensity: 0.32,
  });
  const dome = new THREE.Mesh(domeGeo, domeIntMat);
  dome.position.y = DRUM_Y + DRUM_HEIGHT / 2;
  dome.name = 'cathedral.dome';
  group.add(dome);

  // Outer dome shell — copper exterior, visible if user flies above the drum.
  const domeExtGeo = new THREE.SphereGeometry(DOME_RADIUS + 0.04, 48, 32, 0, Math.PI * 2, 0, Math.PI / 2);
  const domeExt = new THREE.Mesh(domeExtGeo, MAT.copper);
  domeExt.position.y = DRUM_Y + DRUM_HEIGHT / 2;
  group.add(domeExt);

  // Central cross above the dome.
  const cross = new THREE.Group();
  const cv1 = new THREE.Mesh(new THREE.BoxGeometry(0.08, 1.0, 0.08), MAT.gold);
  cv1.position.y = 0.4;
  cross.add(cv1);
  const ch1 = new THREE.Mesh(new THREE.BoxGeometry(0.42, 0.08, 0.08), MAT.gold);
  ch1.position.y = 0.55;
  cross.add(ch1);
  // Small orb at the base of the cross.
  const orb = new THREE.Mesh(new THREE.SphereGeometry(0.10, 16, 12), MAT.gold);
  orb.position.y = -0.05;
  cross.add(orb);
  cross.position.y = DRUM_Y + DRUM_HEIGHT / 2 + DOME_RADIUS;
  cross.name = 'cathedral.cross';
  group.add(cross);

  // ── 12 candle stands between the columns ──────────────────────────
  // Each candle: a marble pedestal (cylinder), a beeswax candle on top,
  // and an emissive flame mesh. Half of them carry a real PointLight so
  // the room glows from multiple warm sources without spending 12 lights.
  if (!IS_LOW_PERF) {
    const PEDESTAL_R = COL_RADIUS + 0.85;   // outside the column ring
    const pedGeo  = new THREE.CylinderGeometry(0.10, 0.14, 0.70, 14);
    const candleGeo = new THREE.CylinderGeometry(0.034, 0.038, 0.30, 10);
    const flameGeo  = new THREE.ConeGeometry(0.030, 0.10, 8);
    const candleMat = new THREE.MeshStandardMaterial({
      color: 0xf4e8c8, roughness: 0.48, metalness: 0.02,
      emissive: 0x4a2a08, emissiveIntensity: 0.08,
    });
    const flameMat = new THREE.MeshBasicMaterial({ color: 0xffd089 });
    const flameAux = [];
    for (let i = 0; i < 12; i++) {
      const angle = (i / 12) * Math.PI * 2 + Math.PI / 12;
      const x = Math.cos(angle) * PEDESTAL_R;
      const z = Math.sin(angle) * PEDESTAL_R;
      const stand = new THREE.Group();
      stand.position.set(x, -0.62, z);
      stand.name = 'cathedral.candle.' + i;
      const ped = new THREE.Mesh(pedGeo, MAT.marble);
      ped.position.y = 0.35;
      stand.add(ped);
      const cn = new THREE.Mesh(candleGeo, candleMat);
      cn.position.y = 0.85;
      stand.add(cn);
      const fl = new THREE.Mesh(flameGeo, flameMat);
      fl.position.y = 1.05;
      stand.add(fl);
      flameAux.push(fl);
      // Every 3rd candle gets a real warm PointLight (4 lights total)
      if (i % 3 === 0) {
        const lt = new THREE.PointLight(0xffaa55, 1.6, 5.5, 1.8);
        lt.position.y = 1.05;
        stand.add(lt);
      }
      group.add(stand);
    }
    // Subtle flicker on flame meshes — pulse emissive scale per frame.
    group.userData.flameAux = flameAux;

    // Chandelier — soft warm glow hanging under the central dome apex.
    const chandelier = new THREE.PointLight(0xffd49a, 1.9, 22, 1.2);
    chandelier.position.set(0, DRUM_Y - 0.2, 0);
    group.add(chandelier);
  }

  // (dust motes — handled by the global makeDust() system below; no
  // need for a second particle layer inside the cathedral group.)

  // ── Wooden lectern (ἀναλόγιον) under the book ─────────────────────
  // Walnut lectern: square base + tapered central post + broad top
  // platform. Post is taller than the previous build so the book rests
  // at a comfortable reading height (book bottom at y ≈ 0.35 world).
  const lecternMat = new THREE.MeshStandardMaterial({
    color: 0x5a3014, roughness: 0.62, metalness: 0.04, envMapIntensity: 0.8,
  });
  const lectern = new THREE.Group();
  lectern.name = 'cathedral.lectern';
  // Top platform — broader than the book footprint when closed.
  const lectTop = new THREE.Mesh(
    new THREE.BoxGeometry(1.65, 0.06, 2.10),
    lecternMat,
  );
  lectTop.position.y = 2.17;
  lectTop.castShadow = !IS_LOW_PERF;
  lectern.add(lectTop);
  // Decorative gold trim band under the platform.
  const lectTrim = new THREE.Mesh(
    new THREE.BoxGeometry(1.60, 0.020, 2.05),
    MAT.gold,
  );
  lectTrim.position.y = 2.13;
  lectern.add(lectTrim);
  // Central tapered post — pulpit / ambon proportions.
  const lectPost = new THREE.Mesh(
    new THREE.CylinderGeometry(0.16, 0.26, 2.05, 20),
    lecternMat,
  );
  lectPost.position.y = 1.075;
  lectern.add(lectPost);
  // Square base.
  const lectBase = new THREE.Mesh(
    new THREE.BoxGeometry(0.96, 0.10, 0.96),
    lecternMat,
  );
  lectBase.position.y = 0.05;
  lectBase.receiveShadow = !IS_LOW_PERF;
  lectern.add(lectBase);
  lectern.position.y = -0.62;
  group.add(lectern);

  // ── 12 stone walls between the columns, each with a stained-glass
  //    window painted in a Byzantine rose-window style. Walls sit on a
  //    slightly smaller radius than the column ring so the columns
  //    visibly stand IN FRONT of the masonry — typical Byzantine plan.
  const wallTex = (() => {
    const cv = document.createElement('canvas');
    cv.width = 1024; cv.height = 2048;
    const g = cv.getContext('2d');
    // Stone base — same cream marble as the columns, with subtle veining.
    // Drawn fully opaque (alpha 1) so the wall blocks vision elsewhere.
    g.fillStyle = '#d4c5a2'; g.fillRect(0, 0, cv.width, cv.height);
    for (let i = 0; i < 20; i++) {
      g.strokeStyle = `rgba(80,60,30,${0.04 + Math.random() * 0.05})`;
      g.lineWidth = 0.7 + Math.random() * 1.4;
      g.beginPath();
      let x = Math.random() * cv.width, y = Math.random() * cv.height;
      g.moveTo(x, y);
      for (let s = 0; s < 50; s++) {
        x += (Math.random() - 0.5) * 60;
        y += (Math.random() - 0.5) * 90;
        g.lineTo(x, y);
      }
      g.stroke();
    }
    // Single big arched window centered in the upper portion of the wall.
    const winW  = cv.width * 0.62;
    const winH  = cv.height * 0.50;
    const winX  = (cv.width - winW) / 2;
    const winY  = cv.height * 0.18;
    // Gold thick frame around window (still opaque — defines the silhouette).
    g.fillStyle = '#a07d3e';
    g.beginPath();
    g.roundRect(winX - 18, winY - 18, winW + 36, winH + 36, [winW/2 + 18, winW/2 + 18, 0, 0]);
    g.fill();
    g.fillStyle = '#3a2410';
    g.beginPath();
    g.roundRect(winX - 6, winY - 6, winW + 12, winH + 12, [winW/2 + 6, winW/2 + 6, 0, 0]);
    g.fill();

    // Punch a hole at the window — pixels there go to alpha=0 so the
    // skybox shows through. We then paint the stained-glass colours back
    // on top at reduced alpha so each cell tints the sky instead of
    // hiding it.
    const cx = winX + winW / 2;
    const cy = winY + winW / 2;        // centre of the rose part (top arch)
    const R  = winW / 2 - 8;
    const lancetTop = cy;
    const lancetH   = winH - winW / 2;

    g.globalCompositeOperation = 'destination-out';
    g.fillStyle = 'rgba(0,0,0,1)';
    g.beginPath();
    g.arc(cx, cy, R, Math.PI, Math.PI * 2);
    g.closePath(); g.fill();
    g.fillRect(winX + 4, lancetTop, winW - 8, lancetH);
    g.globalCompositeOperation = 'source-over';

    // Stained-glass colours painted with alpha so the sky tints through.
    g.globalAlpha = 0.62;
    const palette = ['#b0301a', '#1c3a82', '#0c6a30', '#caa044', '#7a1a5a', '#d04a18'];
    // 12 radial sectors in the rose
    for (let k = 0; k < 12; k++) {
      const a0 = Math.PI + (k / 12) * Math.PI;
      const a1 = Math.PI + ((k + 1) / 12) * Math.PI;
      g.fillStyle = palette[k % palette.length];
      g.beginPath();
      g.moveTo(cx, cy);
      g.arc(cx, cy, R, a0, a1, false);
      g.closePath();
      g.fill();
    }
    // 5 vertical lancets in the lower rectangular section
    const lancets = 5;
    for (let k = 0; k < lancets; k++) {
      const lx = winX + (k + 0.05) * (winW / lancets);
      const lw = winW / lancets * 0.9;
      g.fillStyle = palette[(k + 2) % palette.length];
      g.fillRect(lx, lancetTop, lw, lancetH);
    }
    g.globalAlpha = 1;

    // Lead lines (full opacity) over the translucent panes — the dark
    // came reads as the lead structure between glass cells.
    g.strokeStyle = '#1a0a05';
    g.lineWidth = 6;
    for (let k = 0; k <= 12; k++) {
      const a = Math.PI + (k / 12) * Math.PI;
      g.beginPath();
      g.moveTo(cx, cy);
      g.lineTo(cx + Math.cos(a) * R, cy + Math.sin(a) * R);
      g.stroke();
    }
    [R * 0.45, R * 0.75].forEach(r => {
      g.beginPath(); g.arc(cx, cy, r, Math.PI, Math.PI * 2); g.stroke();
    });
    // Central small disc with a tiny gold cross (full opacity — the
    // boss at the centre of the rose).
    g.fillStyle = '#e0bf6b'; g.beginPath(); g.arc(cx, cy, R * 0.16, 0, Math.PI * 2); g.fill();
    g.fillStyle = '#1a0a05';
    g.fillRect(cx - 2, cy - R * 0.12, 4, R * 0.24);
    g.fillRect(cx - R * 0.10, cy - 2, R * 0.20, 4);
    // Vertical lancet dividers
    for (let k = 1; k < lancets; k++) {
      const lx = winX + k * (winW / lancets);
      g.beginPath(); g.moveTo(lx, lancetTop); g.lineTo(lx, lancetTop + lancetH); g.stroke();
    }
    // Horizontal lancet tie.
    g.beginPath();
    g.moveTo(winX, lancetTop + lancetH * 0.5);
    g.lineTo(winX + winW, lancetTop + lancetH * 0.5);
    g.stroke();

    const tex = new THREE.CanvasTexture(cv);
    tex.colorSpace = THREE.SRGBColorSpace;
    tex.anisotropy = 16;
    return tex;
  })();

  // ── Roof shoulder — annular ceiling between wall top and drum base.
  // Without this there's an open ring of sky visible between the columns'
  // wall top and the central drum, which makes the satellite domes look
  // like they're floating in the air. The shoulder closes the gap and
  // gives the satellites something to "sit on" when seen from outside.
  const SHOULDER_Y = COL_HEIGHT + 0.55;     // a touch above the column abacus
  const shoulderGeo = new THREE.RingGeometry(DRUM_RADIUS, COL_RADIUS + 0.15, 64, 1);
  const shoulderMat = new THREE.MeshStandardMaterial({
    color: 0xd4c5a2, roughness: 0.6, metalness: 0.05,
    side: THREE.DoubleSide, envMapIntensity: 0.75,
  });
  const shoulderInside = new THREE.Mesh(shoulderGeo, shoulderMat);
  shoulderInside.rotation.x = -Math.PI / 2;
  shoulderInside.position.y = SHOULDER_Y;
  shoulderInside.receiveShadow = !IS_LOW_PERF;
  group.add(shoulderInside);
  // Outer cylindrical skirt — wraps the shoulder edge so when the user
  // flies above the cathedral they see a clean roof, not the underside.
  const skirtH = 0.30;
  const skirtGeo = new THREE.CylinderGeometry(COL_RADIUS + 0.15, COL_RADIUS + 0.15, skirtH, 64, 1, true);
  const skirt = new THREE.Mesh(skirtGeo, shoulderMat);
  skirt.position.y = SHOULDER_Y - skirtH / 2;
  group.add(skirt);
  // Cornice — projecting marble ring around the shoulder edge, just
  // above the skirt. Gives the roof a classical "lip" so it doesn't
  // look like a bare cylinder cut.
  const corniceTop = new THREE.Mesh(
    new THREE.TorusGeometry(COL_RADIUS + 0.25, 0.07, 16, 96),
    MAT.marble,
  );
  corniceTop.rotation.x = Math.PI / 2;
  corniceTop.position.y = SHOULDER_Y + 0.06;
  group.add(corniceTop);
  const corniceBot = new THREE.Mesh(
    new THREE.TorusGeometry(COL_RADIUS + 0.22, 0.05, 16, 96),
    MAT.marble,
  );
  corniceBot.rotation.x = Math.PI / 2;
  corniceBot.position.y = SHOULDER_Y - skirtH + 0.04;
  group.add(corniceBot);
  // Gold trim band along the very top edge.
  const corniceGold = new THREE.Mesh(
    new THREE.TorusGeometry(COL_RADIUS + 0.18, 0.02, 12, 96),
    MAT.gold,
  );
  corniceGold.rotation.x = Math.PI / 2;
  corniceGold.position.y = SHOULDER_Y + 0.18;
  group.add(corniceGold);

  const WALL_RADIUS = COL_RADIUS - 0.05;   // walls just inside the columns
  const segAngle = (Math.PI * 2) / COL_COUNT;
  const wallChord = 2 * WALL_RADIUS * Math.sin(segAngle / 2);
  // Walls extend up to the column abacus / shoulder ring, so the
  // perimeter masonry reads as one continuous height rather than a
  // short curtain wall with a column sticking up past it.
  const wallGeo = new THREE.PlaneGeometry(wallChord * 1.02, COL_HEIGHT + 1.15);
  // transparent:true so the per-pixel alpha in the wall texture is
  // honoured — stone stays opaque (alpha=1), stained-glass cells
  // render at alpha≈0.62 so the equirect sky shows through tinted by
  // the cell colour. depthWrite stays on; window cells are sparse and
  // we'd rather have correct sky bleed than perfect transparency sort.
  const wallMat = new THREE.MeshStandardMaterial({
    map: wallTex, transparent: true,
    roughness: 0.55, metalness: 0.06,
    emissive: 0x5a4020, emissiveIntensity: 0.16,
    side: THREE.DoubleSide,
    envMapIntensity: 0.8,
  });
  const walls = [];
  const cosHalf = Math.cos(segAngle / 2);
  for (let i = 0; i < COL_COUNT; i++) {
    const mid = (i / COL_COUNT) * Math.PI * 2 + segAngle / 2;
    const wx = Math.cos(mid) * WALL_RADIUS * cosHalf;
    const wz = Math.sin(mid) * WALL_RADIUS * cosHalf;
    const wall = new THREE.Mesh(wallGeo, wallMat);
    wall.position.set(wx, -0.62 + (COL_HEIGHT + 1.15) / 2, wz);
    // Face inward (toward the center)
    wall.lookAt(0, wall.position.y, 0);
    wall.receiveShadow = !IS_LOW_PERF;
    wall.name = 'cathedral.wall.' + i;
    group.add(wall);
    walls.push(wall);
  }

  scene.add(group);
  return { group, floor, dome, drum, cross, columns, satellites, walls, lectern };
})();

