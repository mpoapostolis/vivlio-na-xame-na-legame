// =====================================================================
//   PAGE CLASS — port of wawa Book.jsx
// =====================================================================
class Page {
  constructor(number, frontTex, backTex, totalPages, frontPhotos, backPhotos) {
    this.number = number;
    this.totalPages = totalPages;
    this.frontPhotos = frontPhotos;
    this.backPhotos = backPhotos;

    this.group = new THREE.Group();

    // --- bones (wawa formula) ---
    const bones = [];
    for (let i = 0; i <= PAGE_SEGMENTS; i++) {
      const b = new THREE.Bone();
      bones.push(b);
      b.position.x = i === 0 ? 0 : SEGMENT_WIDTH;
      if (i > 0) bones[i - 1].add(b);
    }
    this.skeleton = new THREE.Skeleton(bones);
    this.bones = bones;

    // --- materials (4 paper-edge + front + back) ---
    const isCover = (number === 0 || number === totalPages - 1);
    const paperEdgeMat = new THREE.MeshStandardMaterial({
      map: edgeTex, color: 0xe7d5a8, roughness: 0.92, metalness: 0.04,
    });
    const spineEdgeMat = new THREE.MeshStandardMaterial({
      map: leatherTex, color: 0x4a2812, roughness: 0.62, metalness: 0.10,
    });

    // Cover: stronger gold-foil iridescence + slight metallic gilding
    // Pages: glossy magazine clearcoat + paper anisotropy + subtle subsurface transmission
    const isFrontCover = isCover && number === 0;
    const isBackCover  = isCover && number === totalPages - 1;
    this.frontMat = new THREE.MeshPhysicalMaterial({
      color: 0xffffff,
      map: frontTex,
      roughness: isFrontCover ? 0.45 : 0.36,
      metalness: isFrontCover ? 0.18 : 0,
      clearcoat: isFrontCover ? 0.6 : 0.5,
      clearcoatRoughness: isFrontCover ? 0.18 : 0.2,
      normalMap: paperNormalTex,
      normalScale: new THREE.Vector2(isFrontCover ? 0.22 : 0.20, isFrontCover ? 0.22 : 0.20),
      sheen: isFrontCover ? 0.5 : 0.22,
      sheenRoughness: 0.7,
      sheenColor: new THREE.Color(isFrontCover ? 0xffd8a0 : 0xffe8c8),
      iridescence: isFrontCover ? 0.85 : 0,
      iridescenceIOR: 1.45,
      iridescenceThicknessRange: [100, 900],
      anisotropy: isFrontCover ? 0.4 : 0.3,
      anisotropyRotation: 0,
      transmission: isFrontCover ? 0 : 0.04,
      thickness: 0.001,
      attenuationColor: new THREE.Color(0xffe8c8),
      attenuationDistance: 0.5,
      emissive: emissiveColor, emissiveIntensity: 0,
      envMapIntensity: isFrontCover ? 1.1 : 0.8,
    });
    this.backMat = new THREE.MeshPhysicalMaterial({
      color: 0xffffff,
      map: backTex,
      roughness: isBackCover ? 0.45 : 0.36,
      metalness: isBackCover ? 0.18 : 0,
      clearcoat: isBackCover ? 0.6 : 0.5,
      clearcoatRoughness: isBackCover ? 0.18 : 0.2,
      normalMap: paperNormalTex,
      normalScale: new THREE.Vector2(isBackCover ? 0.22 : 0.20, isBackCover ? 0.22 : 0.20),
      sheen: isBackCover ? 0.5 : 0.22,
      sheenRoughness: 0.7,
      sheenColor: new THREE.Color(isBackCover ? 0xffd8a0 : 0xffe8c8),
      iridescence: isBackCover ? 0.85 : 0,
      iridescenceIOR: 1.45,
      iridescenceThicknessRange: [100, 900],
      anisotropy: isBackCover ? 0.4 : 0.3,
      anisotropyRotation: 0,
      transmission: isBackCover ? 0 : 0.04,
      thickness: 0.001,
      attenuationColor: new THREE.Color(0xffe8c8),
      attenuationDistance: 0.5,
      emissive: emissiveColor, emissiveIntensity: 0,
      envMapIntensity: isBackCover ? 1.1 : 0.8,
    });

    // BoxGeometry material slots: +x, -x, +y, -y, +z (front), -z (back)
    const materials = [
      paperEdgeMat,    // +x  (free edge)
      spineEdgeMat,    // -x  (spine edge)
      paperEdgeMat,    // +y  (top)
      paperEdgeMat,    // -y  (bottom)
      this.frontMat,   // +z  (front face)
      this.backMat,    // -z  (back face)
    ];

    this.mesh = new THREE.SkinnedMesh(pageGeometry, materials);
    this.mesh.castShadow = true;
    this.mesh.receiveShadow = true;
    this.mesh.frustumCulled = false;
    // Render order: page 0 (cover) on top, then page 1, ..., last page at the bottom of the stack.
    // Prevents z-fight when pages share near-identical world depth (closed-book state).
    this.mesh.renderOrder = totalPages - number;
    this.mesh.add(bones[0]);
    this.mesh.bind(this.skeleton);
    this.mesh.userData = { page: this };
    this.group.add(this.mesh);

    // --- state ---
    this.lastOpened = false;
    this.turnedAt = 0;
    this.highlighted = false;
  }

  setOpened(opened) {
    if (this.lastOpened !== opened) {
      this.turnedAt = performance.now();
      this.lastOpened = opened;
    }
  }

  // wawa: Book.jsx useFrame body, ported
  update(dt, delayedPage, isBookClosed) {
    const opened = this.lastOpened;

    let turningTime = Math.min(400, performance.now() - this.turnedAt) / 400;
    turningTime = Math.sin(turningTime * Math.PI);

    let targetRotation = opened ? -Math.PI / 2 : Math.PI / 2;
    if (!isBookClosed) {
      targetRotation += THREE.MathUtils.degToRad(this.number * 0.8);
    }

    // wawa stack-z logic (in our setup we use mesh.position.z relative to page group)
    this.mesh.position.z = -this.number * PAGE_DEPTH + delayedPage * PAGE_DEPTH;

    // Emissive lerp on hover
    const tEm = this.highlighted ? 0.18 : 0;
    this.frontMat.emissiveIntensity = THREE.MathUtils.lerp(this.frontMat.emissiveIntensity, tEm, 0.1);
    this.backMat.emissiveIntensity  = THREE.MathUtils.lerp(this.backMat.emissiveIntensity,  tEm, 0.1);

    const bones = this.bones;
    for (let i = 0; i < bones.length; i++) {
      const target = i === 0 ? this.group : bones[i];

      const insideCurveIntensity  = i < 8  ? Math.sin(i * 0.2 + 0.25) : 0;
      const outsideCurveIntensity = i >= 8 ? Math.cos(i * 0.3 + 0.09) : 0;
      const turningIntensity = Math.sin(i * Math.PI * (1 / bones.length)) * turningTime;

      let rotationAngle =
          insideCurveStrength  * insideCurveIntensity  * targetRotation
        - outsideCurveStrength * outsideCurveIntensity * targetRotation
        + turningCurveStrength * turningIntensity      * targetRotation;
      let foldRotationAngle = THREE.MathUtils.degToRad(Math.sign(targetRotation) * 2);

      if (isBookClosed) {
        if (i === 0) { rotationAngle = targetRotation; foldRotationAngle = 0; }
        else { rotationAngle = 0; foldRotationAngle = 0; }
      }

      target.rotation.y = dampAngle(target.rotation.y, rotationAngle, easingFactor, dt);

      const foldIntensity = i > 8 ? Math.sin(i * Math.PI * (1 / bones.length) - 0.5) * turningTime : 0;
      target.rotation.x = dampAngle(target.rotation.x, foldRotationAngle * foldIntensity, easingFactorFold, dt);
    }
  }
}

function dampAngle(c, t, smoothing, dt) {
  const factor = 1 - Math.exp(-dt / smoothing);
  let d = t - c;
  while (d > Math.PI) d -= Math.PI * 2;
  while (d < -Math.PI) d += Math.PI * 2;
  return c + d * factor;
}

