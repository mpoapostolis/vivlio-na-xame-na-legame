---
import ImmersiveLayout from '../layouts/ImmersiveLayout.astro';
import { PHOTO_NARRATIONS } from '../data/animations';
---

<ImmersiveLayout
  title="Τὸ Βιβλίον · Ἅγιος Ἀνδρέας Πατρῶν"
  description="Τρισδιάστατο διαδραστικὸ βιβλίο μὲ τὴν ἱστορία τοῦ Καθεδρικοῦ Ναοῦ."
>
<script type="application/json" id="photo-narrations-data" set:html={JSON.stringify(PHOTO_NARRATIONS)}></script>

<style is:global>
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;width:100%;overflow:hidden;color:#d9b478;font-family:'Inter',-apple-system,sans-serif;
    background:
      radial-gradient(ellipse 1300px 900px at 50% 48%, rgba(150,85,35,0.18) 0%, transparent 58%),
      radial-gradient(ellipse 700px 500px at 50% 52%, rgba(220,145,70,0.10) 0%, transparent 55%),
      radial-gradient(ellipse 900px 600px at 18% 22%, rgba(60,80,130,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 800px 600px at 82% 82%, rgba(80,40,80,0.06) 0%, transparent 60%),
      radial-gradient(circle at 50% 50%, #0c0604 0%, #020100 70%, #000 100%)}
  canvas{display:block;background:transparent;outline:none}

  body::before{content:'';position:fixed;inset:-10%;pointer-events:none;z-index:1;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    opacity:0.08;mix-blend-mode:overlay;animation:grain 7s steps(8) infinite}
  @keyframes grain{
    0%{transform:translate(0%,0%)}10%{transform:translate(-3%,-7%)}20%{transform:translate(-12%,4%)}
    30%{transform:translate(6%,-18%)}40%{transform:translate(-4%,18%)}50%{transform:translate(-12%,8%)}
    60%{transform:translate(11%,0%)}70%{transform:translate(0%,12%)}80%{transform:translate(2%,28%)}
    90%{transform:translate(-8%,8%)}100%{transform:translate(0%,0%)}
  }
  body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:2;
    background:radial-gradient(ellipse 50vw 35vh at 28% 32%, rgba(190,110,45,0.08) 0%, transparent 60%),
               radial-gradient(ellipse 45vw 32vh at 72% 70%, rgba(80,60,110,0.05) 0%, transparent 60%);
    animation:drift 22s ease-in-out infinite alternate}
  @keyframes drift{
    0%{transform:translate(-1.5%,-1%) scale(1);opacity:0.75}
    50%{transform:translate(0%,1%) scale(1.05);opacity:1}
    100%{transform:translate(1.5%,-0.5%) scale(0.98);opacity:0.85}
  }

  #vignette{position:fixed;inset:0;pointer-events:none;z-index:6;
    background:radial-gradient(ellipse at 50% 55%,transparent 25%,rgba(0,0,0,0.5) 95%),
               radial-gradient(ellipse 90vw 80vh at 50% 50%,transparent 45%,rgba(0,0,0,0.35) 100%)}

  #hud{position:fixed;inset:0;z-index:10;pointer-events:none;font-family:'Cormorant Garamond',Georgia,serif;color:#d9b478}
  #hud > *{pointer-events:auto}
  .brand{position:fixed;top:24px;left:32px;font-size:10px;letter-spacing:0.45em;text-transform:uppercase;opacity:0.55;font-family:'Inter',sans-serif}
  .brand b{display:block;font-family:'Cormorant Garamond',serif;font-weight:400;font-style:italic;font-size:22px;letter-spacing:0.02em;text-transform:none;margin-top:4px;color:#efddb0}
  /* Page-count + audio button stacked at top-CENTER over the book — feels
     attached to the page itself rather than floating in the corner. */
  .pagecount{position:fixed;top:22px;left:50%;transform:translateX(-50%);font-size:11px;letter-spacing:0.3em;opacity:0.75;font-family:'Inter',sans-serif;z-index:11;
    background:rgba(20,12,6,0.55);backdrop-filter:blur(8px);padding:5px 14px;border-radius:999px;border:1px solid rgba(217,180,120,0.18)}
  .pagecount em{font-style:italic;color:#efddb0;padding:0 6px;font-family:'Cormorant Garamond',serif}

  .audio-btn{position:fixed;top:60px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:9px;padding:8px 16px 8px 12px;
    background:rgba(20,12,6,0.7);backdrop-filter:blur(10px) saturate(140%);
    border:1px solid rgba(217,180,120,0.3);border-radius:999px;
    color:#d9b478;font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.28em;text-transform:uppercase;
    cursor:pointer;transition:all 0.32s;z-index:11}
  .audio-btn:hover{background:rgba(217,180,120,0.13);color:#efddb0;border-color:rgba(217,180,120,0.5)}
  .audio-btn.playing{background:rgba(154,103,48,0.55);color:#fff;border-color:rgba(217,180,120,0.7);box-shadow:0 0 18px -2px rgba(255,180,80,0.3)}
  .audio-btn.playing .audio-icon{animation:audio-pulse 1.6s ease-in-out infinite}
  .audio-icon{display:inline-block;width:14px;height:14px;line-height:14px;text-align:center;font-size:11px}
  .audio-label{font-weight:500}
  .audio-progress{position:absolute;left:0;right:0;bottom:-1px;height:1px;background:rgba(217,180,120,0.6);
    transform:scaleX(0);transform-origin:left;transition:transform 0.18s linear}
  .audio-btn.playing .audio-progress{background:#efddb0}
  @keyframes audio-pulse{0%,100%{opacity:1}50%{opacity:0.55}}
  .audio-btn:disabled{opacity:0.35;cursor:not-allowed}
  .nav{position:fixed;bottom:30px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:6px;
    background:rgba(20,12,6,0.7);backdrop-filter:blur(14px) saturate(140%);
    border:1px solid rgba(217,180,120,0.25);border-radius:999px;padding:6px;box-shadow:0 18px 40px -12px rgba(0,0,0,0.7)}
  .nav button{background:transparent;border:none;color:#d9b478;font-family:inherit;font-size:12px;
    letter-spacing:0.25em;text-transform:uppercase;padding:9px 20px;border-radius:999px;cursor:pointer;transition:all 0.35s}
  .nav button:hover:not(:disabled){background:rgba(217,180,120,0.12);color:#efddb0}
  .nav button:disabled{opacity:0.25;cursor:not-allowed}
  .nav .strip{display:flex;gap:5px;padding:0 10px;align-items:center}
  .nav .dot{width:5px;height:5px;border-radius:50%;background:rgba(217,180,120,0.3);transition:all 0.35s;cursor:pointer;border:none;padding:0}
  .nav .dot.active{background:#efddb0;width:22px;border-radius:3px}
  .hint{position:fixed;bottom:30px;right:32px;font-size:9px;letter-spacing:0.3em;text-transform:uppercase;opacity:0.45;
    text-align:right;line-height:1.85;font-family:'Inter',sans-serif}
  .hint kbd{border:1px solid rgba(217,180,120,0.3);padding:1px 5px;border-radius:3px;margin:0 2px;font-size:9px;color:#efddb0;font-family:inherit}

  #VRButton{font-family:'Inter',sans-serif !important;letter-spacing:0.25em !important;text-transform:uppercase !important;
    font-size:11px !important;bottom:90px !important;left:50% !important;transform:translateX(-50%) !important;
    padding:12px 26px !important;background:rgba(70,46,24,0.92) !important;color:#efddb0 !important;
    border:1px solid rgba(217,180,120,0.5) !important;border-radius:999px !important;
    box-shadow:0 10px 30px -8px rgba(0,0,0,0.6) !important;backdrop-filter:blur(8px) !important;opacity:1 !important}

  #modal{position:fixed;inset:0;z-index:20;display:flex;align-items:center;justify-content:center;
    background:rgba(6,3,1,0.7);backdrop-filter:blur(8px);
    opacity:0;pointer-events:none;transition:opacity 0.5s cubic-bezier(0.4,0,0.2,1)}
  #modal.open{opacity:1;pointer-events:auto}
  #modal .panel{
    width:min(92vw,920px);max-height:88vh;
    display:grid;grid-template-columns:minmax(0,1.1fr) minmax(0,1fr);gap:0;
    background:linear-gradient(180deg,#1a0e07 0%,#080403 100%);
    border:1px solid rgba(217,180,120,0.4);border-radius:3px;overflow:hidden;
    box-shadow:0 30px 80px -10px rgba(0,0,0,0.85),0 0 100px rgba(255,170,80,0.07);
    transform:scale(0.92) translateY(20px);transition:transform 0.55s cubic-bezier(0.34,1.56,0.64,1);
    font-family:'Cormorant Garamond',Georgia,serif;color:#d9b478}
  #modal.open .panel{transform:scale(1) translateY(0)}
  #modal .photo-side{background:#000;display:flex;align-items:center;justify-content:center;padding:24px;position:relative}
  #modal .photo-side img{max-width:100%;max-height:75vh;display:block;border:1px solid rgba(217,180,120,0.25);box-shadow:0 14px 40px -8px rgba(0,0,0,0.8)}
  #modal .info-side{padding:54px 44px;display:flex;flex-direction:column;justify-content:center}
  #modal .eyebrow{font-size:10px;letter-spacing:0.45em;text-transform:uppercase;color:#9a6730;font-family:'Inter',sans-serif;margin-bottom:14px;font-weight:500}
  #modal h2{font-size:36px;line-height:1.05;font-style:italic;font-weight:400;color:#efddb0;margin-bottom:18px;letter-spacing:-0.01em}
  #modal .rule{width:50px;height:2px;background:#c9a96a;margin-bottom:22px}
  #modal p{font-size:16px;line-height:1.7;color:#c9a96a;margin-bottom:12px}
  #modal p.italic{font-style:italic;color:#d9b478}
  #modal .close-btn{position:absolute;top:16px;right:16px;width:38px;height:38px;border-radius:50%;
    background:rgba(40,28,18,0.85);border:1px solid rgba(217,180,120,0.35);color:#d9b478;font-size:22px;cursor:pointer;
    display:flex;align-items:center;justify-content:center;transition:all 0.3s;font-family:inherit;z-index:2}
  #modal .close-btn:hover{background:rgba(217,180,120,0.18);color:#efddb0;transform:rotate(90deg)}

  #loading{position:fixed;inset:0;background:#060302;display:flex;align-items:center;justify-content:center;
    flex-direction:column;gap:24px;z-index:100;transition:opacity 0.7s}
  #loading.hidden{opacity:0;pointer-events:none}
  #loading .ring{width:36px;height:36px;border:1px solid rgba(217,180,120,0.3);border-top-color:#efddb0;border-radius:50%;animation:spin 1.4s linear infinite}
  #loading .label{font-style:italic;letter-spacing:0.4em;text-transform:uppercase;font-size:11px;opacity:0.6;color:#d9b478;font-family:'Cormorant Garamond',serif}
  #loading .progress{font-family:'Inter',sans-serif;font-size:9px;letter-spacing:0.3em;color:#9a6730;opacity:0.7}
  @keyframes spin{to{transform:rotate(360deg)}}

  #render-target{position:fixed;left:-10000px;top:0;pointer-events:none}
  .render-page{
    width:1200px;height:1600px;
    font-family:'Inter','Helvetica Neue',system-ui,sans-serif;
    color:#0a0a0a;position:relative;overflow:hidden;
    padding:160px 110px 130px;
    background:#faf6ec;
    background-image:
      /* spine shadow (left edge darker) */
      linear-gradient(90deg, rgba(60,40,15,0.16) 0%, rgba(60,40,15,0.04) 4%, transparent 9%, transparent 92%, rgba(80,55,20,0.05) 100%),
      /* age spots */
      radial-gradient(ellipse 320px 200px at 14% 10%, rgba(160,110,55,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 260px 180px at 86% 15%, rgba(140,90,40,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 280px 200px at 80% 88%, rgba(110,70,30,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 200px 140px at 22% 78%, rgba(130,85,40,0.045) 0%, transparent 65%),
      radial-gradient(ellipse 150px 120px at 60% 35%, rgba(90,60,25,0.03) 0%, transparent 70%),
      radial-gradient(ellipse 100px 80px at 40% 60%, rgba(170,120,60,0.025) 0%, transparent 70%),
      /* corner darkening — slight wear */
      radial-gradient(circle at 0% 0%, rgba(50,30,10,0.10) 0%, transparent 8%),
      radial-gradient(circle at 100% 0%, rgba(50,30,10,0.08) 0%, transparent 7%),
      radial-gradient(circle at 0% 100%, rgba(50,30,10,0.10) 0%, transparent 8%),
      radial-gradient(circle at 100% 100%, rgba(50,30,10,0.08) 0%, transparent 7%),
      /* paper base — subtle gradient */
      linear-gradient(180deg, #faf6ec 0%, #f4ede0 50%, #f0e6d2 100%);
  }
  .render-page::before{content:'';position:absolute;top:70px;left:110px;right:110px;height:1px;background:#0a0a0a}
  .render-page::after{
    content:'ΑΓ. ΑΝΔΡΕΑΣ — ΠΑΤΡΑΙ · ΧΡΟΝΙΚΟ ΑΝΕΓΕΡΣΕΩΣ';
    position:absolute;top:55px;left:110px;font-size:13px;letter-spacing:0.5em;font-weight:700;color:#0a0a0a;
    background:#faf6ec;padding-right:18px}
  .render-page.cover{
    padding:0;
    background:radial-gradient(ellipse at 50% 32%,#4a2812 0%,#1a0a04 92%);
    color:#d9b478;display:flex;align-items:center;justify-content:center}
  .render-page.cover::before,.render-page.cover::after{display:none}

  .render-page .eyebrow{font-size:14px;letter-spacing:0.5em;text-transform:uppercase;color:#a87a30;font-weight:700;margin-bottom:26px}
  .render-page h1{font-family:'Cormorant Garamond','Playfair Display',Georgia,serif;font-size:128px;line-height:0.92;font-weight:500;color:#0a0a0a;letter-spacing:-0.025em;margin-bottom:34px}
  .render-page h2{font-family:'Cormorant Garamond','Playfair Display',Georgia,serif;font-size:96px;line-height:0.95;font-style:italic;font-weight:500;color:#0a0a0a;letter-spacing:-0.02em;margin-bottom:34px}
  .render-page .date{font-family:'Cormorant Garamond',Georgia,serif;font-size:32px;font-style:italic;color:#a87a30;margin-bottom:32px;letter-spacing:0.01em;font-weight:500}
  .render-page .rule{width:72px;height:3px;background:#0a0a0a;margin-bottom:46px}
  .render-page p{font-size:24px;line-height:1.7;color:#1a1a1a;margin-bottom:20px;font-weight:400;letter-spacing:0.005em}
  .render-page p.lead{font-family:'Cormorant Garamond',Georgia,serif;font-size:38px;font-style:italic;line-height:1.38;color:#0a0a0a;font-weight:500;margin-bottom:34px;letter-spacing:-0.005em}
  .render-page p.lead::first-letter{font-family:'Cormorant Garamond',Georgia,serif;font-size:128px;float:left;line-height:0.82;padding:8px 22px 0 0;font-style:normal;color:#a87a30;font-weight:700}
  .render-page blockquote{font-family:'Cormorant Garamond',Georgia,serif;font-size:42px;line-height:1.32;font-style:italic;color:#0a0a0a;margin:50px 0;padding:0 0 0 38px;border-left:5px solid #a87a30;font-weight:500}
  .render-page ul{list-style:none;padding:22px 0;margin:26px 0;border-top:1px solid #c8c0ad;border-bottom:1px solid #c8c0ad}
  .render-page ul li{font-size:23px;font-weight:500;color:#1a1a1a;line-height:1.55;padding:13px 0 13px 38px;position:relative;border-bottom:1px dotted #c8c0ad}
  .render-page ul li:last-child{border-bottom:none}
  .render-page ul li::before{content:'';position:absolute;left:0;top:28px;width:22px;height:2px;background:#a87a30}
  .render-page .toc-row{display:flex;align-items:baseline;gap:32px;padding:26px 0;border-bottom:1px solid #c8c0ad}
  .render-page .toc-row:last-child{border-bottom:none}
  .render-page .toc-row .num{font-family:'Cormorant Garamond',Georgia,serif;font-size:40px;font-style:italic;color:#a87a30;width:80px;flex-shrink:0;font-weight:500}
  .render-page .toc-row .name{font-family:'Cormorant Garamond',Georgia,serif;font-size:40px;color:#0a0a0a;flex:1;font-weight:500;line-height:1.2}
  .render-page .toc-row .year{font-size:16px;letter-spacing:0.3em;color:#a87a30;font-weight:700}
  .render-page .stat{display:flex;justify-content:space-between;align-items:baseline;border-bottom:1px solid #c8c0ad;padding:20px 0;gap:24px}
  .render-page .stat .label{font-size:14px;letter-spacing:0.22em;text-transform:uppercase;color:#3a3a3a;font-weight:600;flex-shrink:0;line-height:1.3}
  .render-page .stat .value{font-family:'Cormorant Garamond',Georgia,serif;font-size:42px;color:#0a0a0a;font-weight:600;white-space:nowrap;line-height:1}
  .render-page .meta{font-size:14px;letter-spacing:0.5em;text-transform:uppercase;color:#3a3a3a;text-align:center;line-height:2;margin:24px 0;font-weight:600}
  .render-page .photo{display:block;margin:46px -110px;position:relative;background:#000}
  .render-page .photo img{display:block;width:100%;height:auto}
  .render-page .photo .cap{display:block;padding:22px 110px 0;font-size:15px;letter-spacing:0.32em;text-transform:uppercase;color:#3a3a3a;text-align:left;font-weight:600;background:#faf6ec}
  .render-page .photo .pop-hint{position:absolute;top:22px;right:130px;font-size:13px;letter-spacing:0.3em;text-transform:uppercase;background:rgba(0,0,0,0.82);color:#fff;padding:9px 16px;font-weight:600}
  .render-page .folio{position:absolute;bottom:48px;left:50%;transform:translateX(-50%);font-size:15px;letter-spacing:0.5em;text-transform:uppercase;color:#3a3a3a;font-weight:700}
  .render-page .folio::before{content:'';position:absolute;top:50%;left:-44px;width:28px;height:1px;background:#3a3a3a}
  .render-page .folio::after{content:'';position:absolute;top:50%;right:-44px;width:28px;height:1px;background:#3a3a3a}

  .cover-inner{position:relative;border:2px solid #c9a96a;padding:60px 50px;margin:50px;width:calc(100% - 100px);height:calc(100% - 100px);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
  .cover-inner::before{content:'';position:absolute;inset:10px;border:1px solid #c9a96a;opacity:0.6}
  .cover-inner .cnr{position:absolute;width:38px;height:38px;border:2.5px solid #d9b478}
  .cover-inner .cnr.tl{top:-3px;left:-3px;border-right:none;border-bottom:none}
  .cover-inner .cnr.tr{top:-3px;right:-3px;border-left:none;border-bottom:none}
  .cover-inner .cnr.bl{bottom:-3px;left:-3px;border-right:none;border-top:none}
  .cover-inner .cnr.br{bottom:-3px;right:-3px;border-left:none;border-top:none}
  .cover-orn{font-size:78px;line-height:1;color:#d9b478;text-shadow:0 4px 8px rgba(0,0,0,0.6);margin-bottom:28px}
  .cover-title{font-family:'Cormorant Garamond',Georgia,serif;font-weight:400;font-style:italic;font-size:96px;line-height:1.0;
    background:linear-gradient(180deg,#f6dba1 0%,#d9b478 45%,#c9a96a 60%,#9c7e3f 100%);
    -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;
    filter:drop-shadow(0 3px 4px rgba(0,0,0,0.5));margin-bottom:8px;white-space:pre-line}
  .cover-divider{width:140px;height:2px;background:#c9a96a;margin:30px 0;opacity:0.85}
  .cover-subtitle{font-style:italic;font-size:26px;color:#d9b478;line-height:1.4;margin-bottom:34px}
  .cover-meta{font-size:13px;letter-spacing:0.45em;text-transform:uppercase;color:#a08c64;font-family:'Inter',sans-serif}

  /* Hide the immersive-layout's default exit button while the loading screen is up */
  #loading:not(.hidden) ~ .exit-immersive { opacity: 0; pointer-events: none; transition: opacity 0.5s; }

  /* The book has its own HUD — hide the duplicate brand block to avoid clash with the
     ImmersiveLayout exit button at top-left. */
  #hud .brand { display: none; }

  /* Sync status pill — bottom-right HUD. Avoids audio btn (top-right) and nav pill (bottom-center). */
  .sync-pill{position:fixed;bottom:30px;right:32px;display:none;align-items:center;gap:8px;
    padding:6px 14px;background:rgba(20,12,6,0.7);backdrop-filter:blur(10px) saturate(140%);
    border:1px solid rgba(217,180,120,0.3);border-radius:999px;
    color:#d9b478;font-family:'Inter',sans-serif;font-size:9px;letter-spacing:0.3em;text-transform:uppercase;
    transition:opacity 0.45s ease;opacity:0;z-index:11;pointer-events:none}
  .sync-pill.visible{display:inline-flex;opacity:1}
  .sync-pill.offline{color:#c98a55;border-color:rgba(201,138,85,0.35)}

  /* ===================== MOBILE / TABLET ===================== */
  @media (max-width: 760px) {
    /* Compact top bar */
    .pagecount   { top: 14px !important; right: 14px !important; font-size: 10px !important; letter-spacing: 0.2em !important; }
    .audio-btn   { top: 46px !important; right: 14px !important; padding: 6px 12px 6px 9px !important; font-size: 8.5px !important; letter-spacing: 0.22em !important; }
    .audio-label { display: none !important; }                                /* icon only on mobile */

    /* Bottom nav: full-width, larger touch targets */
    .nav { bottom: 18px !important; padding: 4px !important; gap: 2px !important; }
    .nav button   { padding: 12px 14px !important; font-size: 10px !important; letter-spacing: 0.16em !important; }
    .nav .strip   { padding: 0 4px !important; gap: 4px !important; }
    .nav .dot     { width: 5px !important; height: 5px !important; }
    .nav .dot.active { width: 16px !important; }

    /* Hint: hidden on phones — irrelevant to touch users (no kbd, no drag affordance) */
    .hint { display: none !important; }

    /* Sync pill: smaller and shifted above mobile nav so it doesn't overlap */
    .sync-pill { bottom: 78px !important; right: 14px !important; padding: 5px 10px !important; font-size: 8px !important; letter-spacing: 0.22em !important; }

    /* Photo modal: SINGLE column, image on top, text below */
    #modal .panel {
      width: 96vw !important;
      max-height: 92vh !important;
      grid-template-columns: 1fr !important;
      grid-template-rows: auto 1fr;
    }
    #modal .photo-side { padding: 14px !important; }
    #modal .photo-side img { max-height: 44vh !important; }
    #modal .info-side  { padding: 22px 22px 26px !important; overflow-y: auto; }
    #modal .info-side h2 { font-size: 24px !important; margin-bottom: 12px !important; }
    #modal .info-side p  { font-size: 14px !important; line-height: 1.55 !important; }
