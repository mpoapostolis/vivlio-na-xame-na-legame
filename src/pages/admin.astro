// =====================================================================
//   KEYBOARD SHORTCUTS
// =====================================================================
window.addEventListener('keydown', e => {
  if (!isAuthed()) return;
  // Ignore when typing into inputs
  const tag = e.target.tagName;
  if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
  const cmd = e.metaKey || e.ctrlKey;
  if (cmd && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }
  else if (cmd && (e.key === 'Z' || (e.key === 'z' && e.shiftKey)))   { e.preventDefault(); redo(); }
  else if (cmd && e.key === 'y')             { e.preventDefault(); redo(); }
  else if (cmd && e.key === 's')             { e.preventDefault(); save(); }
  else if (e.key === 'Delete' || e.key === 'Backspace') { e.preventDefault(); deleteSelectedKeyframe(); }
  else if (e.key === ' ')                    { e.preventDefault(); State.playing ? stopPlayback() : startPlayback(); }
});

// Warn before close if dirty
window.addEventListener('beforeunload', e => {
  if (State.dirty) { e.preventDefault(); e.returnValue = ''; return ''; }
});

