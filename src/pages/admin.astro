<div id="toast"></div>

<script is:inline>
'use strict';

// =====================================================================
//   DEFAULT ANIMATIONS — what /book uses if localStorage is empty.
//   These drive DOM elements inside the photo modal (HTML target mode).
// =====================================================================
const DEFAULT_ANIMATIONS = {
  // When a photo opens, the image scales up + rotates slightly + fades in.
  photoModalOpen: {
    duration: 0.7,
    tracks: [
      { target: 'modalImg',
        properties: {
          scale: [
            { t: 0.0,  value: 0.65,  ease: 'easeOutBack' },
            { t: 0.78, value: 1.04 },
            { t: 1.0,  value: 1.00 },
          ],
          rotation: [
            { t: 0.0,  value: -0.035, ease: 'easeOutCubic' },
            { t: 0.55, value: 0.008 },
            { t: 1.0,  value: 0 },
          ],
          opacity: [
            { t: 0.0,  value: 0, ease: 'easeOutCubic' },
            { t: 0.45, value: 1 },
            { t: 1.0,  value: 1 },
          ],
        }
      },
      { target: 'modalInfo',
        properties: {
          translateX: [
            { t: 0.0, value: 40, ease: 'easeOutCubic' },
            { t: 0.3, value: 40 },
            { t: 1.0, value: 0 },
          ],
          opacity: [
            { t: 0.0, value: 0 },
            { t: 0.3, value: 0, ease: 'easeOutCubic' },
            { t: 1.0, value: 1 },
          ],
        }
      },
    ],
  },

  // Closing — quick fade-out + slight scale-down.
  photoModalClose: {
    duration: 0.35,
    tracks: [
      { target: 'modalImg',
        properties: {
          scale:    [{ t: 0.0, value: 1.0, ease: 'easeInCubic' }, { t: 1.0, value: 0.85 }],
          opacity:  [{ t: 0.0, value: 1.0, ease: 'easeInCubic' }, { t: 1.0, value: 0 }],
        }
      },
      { target: 'modalInfo',
        properties: {
          translateX: [{ t: 0.0, value: 0, ease: 'easeInCubic' }, { t: 1.0, value: 30 }],
          opacity:    [{ t: 0.0, value: 1, ease: 'easeInCubic' }, { t: 1.0, value: 0 }],
        }
      },
    ],
  },
};

// =====================================================================
//   STATE
// =====================================================================
const PB_URL    = 'https://yms.galerra.art';
const TOKEN_KEY = 'church.cms.token';

const EASE_NAMES = ['linear','easeInQuad','easeOutQuad','easeInOutQuad',
  'easeInCubic','easeOutCubic','easeInOutCubic',
  'easeInQuart','easeOutQuart','easeOutBack','easeOutElastic','easeOutBounce'];
// DOM-target animations don't use camera-relative bindings.
// Leave empty so the inspector hides the binding chip row.
const KNOWN_BINDINGS = [];

const State = {
  // Live data hydrated from PocketBase on login.
  animations:    deepClone(DEFAULT_ANIMATIONS),
  content:       {},           // pageId → { field → value, _recordId, _collectionId }
  contentLocks:  {},           // pageId → { field → bool }
  locks:         {},           // 'animName:trackIdx' → bool (per-animation-track locks)

  // PB state
  token:         null,
  pendingFiles:  {},           // recordId → { fieldName → File }
  dirtyPages:    new Set(),    // recordIds with pending text-field changes
  dirtyAnims:    new Set(),    // recordIds with pending animation changes
  animRecordId:  {},           // animName → recordId (for PATCH)

  // UI state
  selected:       { anim: null, trackIdx: -1, prop: null, kfIdx: -1 },
  selectedPageId: null,
  activeTab:      'content',
  history:        [],
  redoStack:      [],
  dirty:          false,
  playing:        false,
  playStart:      0,
  playTime:       0,
  _editingField:  null,
};

// =====================================================================
//   PERSISTENCE
// =====================================================================
// =====================================================================
//   PERSISTENCE — talks directly to PocketBase via fetch (no SDK in the
//   inline module: Astro doesn't process is:inline imports).
// =====================================================================
function authHeader(extra) {
  const h = { Authorization: State.token };
  if (extra) Object.assign(h, extra);
  return h;
}

// Map a PB record → the flat shape the form binds to.
function _recordToContent(rec) {
  const fileUrl = (f) => f ? `${PB_URL}/api/files/${rec.collectionId}/${rec.id}/${f}` : '';
  return {
    _recordId:    rec.id,
    _collId:      rec.collectionId,
    type:         rec.type         || 'page',
    eyebrow:      rec.eyebrow      || '',
    title:        rec.title        || '',
    date:         rec.date         || '',
    lead:         rec.lead         || '',
    body:         rec.body         || '',
    photoSrc:     fileUrl(rec.photo),
    photoTitle:   rec.photo_title  || '',
    photoCap:     rec.photo_cap    || '',
    photoDesc:    rec.photo_desc   || '',
    photoItalic:  rec.photo_italic || '',
    narration:    fileUrl(rec.narration),
    photoAudio:   fileUrl(rec.photo_audio),
  };
}

async function load() {
  try {
    const [pagesRes, animsRes] = await Promise.all([
      fetch(`${PB_URL}/api/collections/church_pages/records?sort=order&perPage=20`,    { headers: authHeader() }),
      fetch(`${PB_URL}/api/collections/church_animations/records?perPage=50`,         { headers: authHeader() }),
    ]);
    const pages = (await pagesRes.json()).items || [];
    const anims = (await animsRes.json()).items || [];

    State.content      = {};
    State.contentLocks = {};
    for (const rec of pages) {
      const id = 'p' + rec.order;
      State.content[id]      = _recordToContent(rec);
      const locks = Array.isArray(rec.locked_fields) ? rec.locked_fields : [];
      State.contentLocks[id] = Object.fromEntries(locks.map(f => [f, true]));
    }

    // Rebuild the sidebar from live PB records — supports any slide count.
    PAGES_DEFAULT = pages.map(rec => ({
      id:    'p' + rec.order,
      label: rec.label || ('Σελίδα ' + (rec.order + 1)),
      hint:  rec.type  || 'page',
    }));

    State.animations    = {};
    State.animRecordId  = {};
    for (const rec of anims) {
      State.animations[rec.anim_name] = {
        duration: rec.duration,
        loop:     !!rec.loop,
        tracks:   rec.tracks || [],
      };
      State.animRecordId[rec.anim_name] = rec.id;
    }
    if (!Object.keys(State.animations).length) {
      State.animations = deepClone(DEFAULT_ANIMATIONS);
    }
    toast(`Φορτώθηκαν ${pages.length} σελίδες · ${anims.length} animations`);
  } catch (e) {
    console.error('[CMS] load failed', e);
    toast('✕ ἀδυναμία φορτώματος ἀπὸ PB', 'error');
  }
}

// Map UI field name → PB column name.
const _FIELD_TO_PB = {
  type: 'type',
  eyebrow: 'eyebrow', title: 'title', date: 'date',
  lead: 'lead', body: 'body',
  photoTitle: 'photo_title', photoCap: 'photo_cap',
  photoDesc: 'photo_desc',   photoItalic: 'photo_italic',
};

async function _savePage(pageId) {
  const data = State.content[pageId]; if (!data || !data._recordId) return false;
  const locks = Object.keys(State.contentLocks[pageId] || {}).filter(f => State.contentLocks[pageId][f]);
  const files = State.pendingFiles[data._recordId] || {};
  const hasFile = Object.keys(files).length > 0;

  let body, headers;
  if (hasFile) {
    body = new FormData();
    for (const ui in _FIELD_TO_PB) body.append(_FIELD_TO_PB[ui], data[ui] ?? '');
    body.append('locked_fields', JSON.stringify(locks));
    for (const f in files) body.append(f, files[f]);
    headers = authHeader();          // browser sets Content-Type with boundary
  } else {
    const payload = { locked_fields: locks };
    for (const ui in _FIELD_TO_PB) payload[_FIELD_TO_PB[ui]] = data[ui] ?? '';
    body    = JSON.stringify(payload);
    headers = authHeader({ 'Content-Type': 'application/json' });
  }

  const res = await fetch(`${PB_URL}/api/collections/church_pages/records/${data._recordId}`, {
    method: 'PATCH', headers, body,
  });
  if (!res.ok) { console.error('save page failed', await res.text()); return false; }
  // Refresh the local copy with the canonical record (file fields get new server-side names).
  const fresh = await res.json();
  State.content[pageId] = _recordToContent(fresh);
  delete State.pendingFiles[data._recordId];
  return true;
}

async function _saveAnim(name) {
  const recId = State.animRecordId[name]; if (!recId) return false;
  const a = State.animations[name];
  const res = await fetch(`${PB_URL}/api/collections/church_animations/records/${recId}`, {
    method: 'PATCH',
    headers: authHeader({ 'Content-Type': 'application/json' }),
    body: JSON.stringify({ duration: a.duration, loop: !!a.loop, tracks: a.tracks }),
  });
  return res.ok;
}

async function save() {
  if (!State.token) { toast('μη συνδεδεμένος', 'error'); return; }
  let pageCount = 0, animCount = 0;
  for (const pid of State.dirtyPages)  { if (await _savePage(pid)) pageCount++; }
  for (const name of State.dirtyAnims) { if (await _saveAnim(name)) animCount++; }
  State.dirtyPages.clear();
  State.dirtyAnims.clear();
  State.dirty = false;
  refreshSaveBtn();
  toast(`Ἀποθηκεύθηκαν · ${pageCount} σελίδες · ${animCount} animations ✓`);
  if (typeof renderPagesList === 'function') renderPagesList();
  // Refresh the live book preview iframe if it's open
  const iframe = document.getElementById('book-preview-iframe');
  if (iframe) { iframe.src = iframe.src; }
}
function exportJson() {
  const payload = {
    animations:   State.animations,
    content:      State.content,
    contentLocks: State.contentLocks,
    locks:        State.locks,
    exportedAt:   new Date().toISOString(),
  };
  const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'church-cms.json'; a.click();
  URL.revokeObjectURL(url);
  toast('Ἐξήχθη church-cms.json');
}
function resetDefaults() {
  toast('Reset δὲν εἶναι διαθέσιμο μὲ PocketBase backend — χρησιμοποίησε τὸ /_/ admin UI', 'error');
}

// =====================================================================
//   UNDO / REDO via JSON snapshots
// =====================================================================
function deepClone(v) { return JSON.parse(JSON.stringify(v)); }
function _snap() {
  return { animations: deepClone(State.animations), content: deepClone(State.content), contentLocks: deepClone(State.contentLocks) };
}
function _restore(s) {
  State.animations   = s.animations;
  State.content      = s.content;
  State.contentLocks = s.contentLocks;
}
function pushHistory() {
  State.history.push(_snap());
  if (State.history.length > 60) State.history.shift();
  State.redoStack.length = 0;
  refreshUndoBtns();
}
function undo() {
  if (!State.history.length) return;
  State.redoStack.push(_snap());
  _restore(State.history.pop());
  selectClear();
  markDirty();
  renderAll();
  refreshUndoBtns();
  toast('Undo');
}
function redo() {
  if (!State.redoStack.length) return;
  State.history.push(_snap());
  _restore(State.redoStack.pop());
  selectClear();
  markDirty();
  renderAll();
  refreshUndoBtns();
  toast('Redo');
}
function refreshUndoBtns() {
  document.getElementById('undo-btn').disabled = State.history.length === 0;
  document.getElementById('redo-btn').disabled = State.redoStack.length === 0;
}
function refreshSaveBtn() {
  const btn = document.getElementById('save-btn');
  btn.textContent = State.dirty ? '💾 save *' : '💾 saved';
  btn.classList.toggle('primary', State.dirty);
}
function markDirty() {
  State.dirty = true;
  // Track which record(s) need PATCH on next save
  if (State.activeTab === 'content' && State.selectedPageId) {
    State.dirtyPages.add(State.selectedPageId);
  }
  if (State.activeTab === 'animations' && State.selected.anim) {
    State.dirtyAnims.add(State.selected.anim);
  }
  refreshSaveBtn();
}

// =====================================================================
//   AUTH
// =====================================================================
function isAuthed() {
  const t = localStorage.getItem(TOKEN_KEY);
  if (!t) return false;
  try {
    const payload = JSON.parse(atob(t.split('.')[1]));
    if (payload.exp && payload.exp > Date.now() / 1000) {
      State.token = t;
      return true;
    }
  } catch (_) {}
  localStorage.removeItem(TOKEN_KEY);
  return false;
}
function showLogin() {
  document.getElementById('login-screen').classList.remove('hidden');
  document.getElementById('app').classList.add('hidden');
  setTimeout(() => document.getElementById('login-user').focus(), 50);
}
function showApp() {
  document.getElementById('login-screen').classList.add('hidden');
  document.getElementById('app').classList.remove('hidden');
}
// /admin authenticates against the `users` collection in PocketBase.
async function login(email, pass) {
  const errEl = document.getElementById('login-error');
  errEl.textContent = '⌛ σύνδεση…';
  try {
    const res = await fetch(`${PB_URL}/api/collections/users/auth-with-password`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ identity: email, password: pass }),
    });
    if (!res.ok) {
      const body = await res.text();
      errEl.textContent = '✕ ' + (res.status === 400 ? 'λάθος στοιχεῖα' : ('σφάλμα ' + res.status));
      console.warn('[auth] failed:', body);
      setTimeout(() => errEl.textContent = '', 3500);
      return;
    }
    const data = await res.json();
    localStorage.setItem(TOKEN_KEY, data.token);
    State.token = data.token;
    errEl.textContent = '';
    showApp();
    await init();
  } catch (e) {
    errEl.textContent = '✕ δίκτυο: ' + e.message;
    setTimeout(() => errEl.textContent = '', 3500);
  }
}
function logout() {
  if (State.dirty && !confirm('Ἔχεις μη-ἀποθηκευμένες ἀλλαγές. Σίγουρα νὰ φύγεις;')) return;
  localStorage.removeItem(TOKEN_KEY);
  State.token = null;
  showLogin();
}

document.getElementById('login-form').addEventListener('submit', e => {
  e.preventDefault();
  login(document.getElementById('login-user').value.trim(),
        document.getElementById('login-pass').value);
});

// =====================================================================
//   RENDERING — sidebar + timeline + inspector
// =====================================================================
function renderAll() {
  renderSidebar();
  renderEditor();
}
function renderSidebar() {
  const list = document.getElementById('anim-list');
  list.innerHTML = '';
  for (const name of Object.keys(State.animations)) {
    const a = State.animations[name];
    const div = document.createElement('div');
    div.className = 'anim-item' + (State.selected.anim === name ? ' active' : '');
    const trackCount = a.tracks.length;
    let kfCount = 0;
    for (const tr of a.tracks) for (const p in tr.properties) kfCount += tr.properties[p].length;
    const loopBadge = a.loop ? '<span class="loop-badge">↻</span>' : '';
    div.innerHTML = `
      <div class="name">${name} ${loopBadge}</div>
      <div class="meta">${a.duration}s · ${trackCount}T · ${kfCount}K</div>
    `;
    div.addEventListener('click', () => { selectAnim(name); });
    list.appendChild(div);
  }
}

function selectAnim(name) {
  State.selected = { anim: name, trackIdx: -1, prop: null, kfIdx: -1 };
  renderAll();
}
function selectClear() {
  State.selected.trackIdx = -1;
  State.selected.prop = null;
  State.selected.kfIdx = -1;
}
function selectKeyframe(trackIdx, prop, kfIdx) {
  State.selected.trackIdx = trackIdx;
  State.selected.prop = prop;
  State.selected.kfIdx = kfIdx;
  renderEditor();
}

function renderEditor() {
  const animName = State.selected.anim;
  const meta = document.getElementById('anim-meta');
  const nameEl = document.getElementById('anim-name');
  const durInput = document.getElementById('anim-duration');
  const loopInput = document.getElementById('anim-loop');
  const tracksArea = document.getElementById('tracks-area');
  const ruler = document.getElementById('ruler');

  const delBtn = document.getElementById('anim-delete-btn');
  const dupBtn = document.getElementById('anim-duplicate-btn');
  if (!animName || !State.animations[animName]) {
    nameEl.textContent = '— ἐπίλεξε animation —';
    durInput.disabled = true; loopInput.disabled = true;
    if (delBtn) delBtn.disabled = true;
    if (dupBtn) dupBtn.disabled = true;
    tracksArea.innerHTML = '';
    ruler.innerHTML = '';
    document.getElementById('inspector-body').innerHTML = '<div class="empty">ἐπίλεξε animation ἀπὸ τὴν λίστα</div>';
    document.getElementById('dur-readout').textContent = '0.00';
    return;
  }
  const anim = State.animations[animName];
  nameEl.textContent = animName;
  durInput.disabled = false; durInput.value = anim.duration;
  loopInput.disabled = false; loopInput.checked = !!anim.loop;
  if (delBtn) delBtn.disabled = false;
  if (dupBtn) dupBtn.disabled = false;
  document.getElementById('dur-readout').textContent = anim.duration.toFixed(2);

  // Ruler
  ruler.innerHTML = '';
  const NUM_TICKS = 11;
  for (let i = 0; i < NUM_TICKS; i++) {
    const left = (i / (NUM_TICKS - 1)) * 100;
    const tick = document.createElement('div');
    tick.className = 'tick';
    tick.style.left = left + '%';
    ruler.appendChild(tick);
    const lbl = document.createElement('div');
    lbl.className = 'tick-label';
    lbl.style.left = left + '%';
    lbl.textContent = (anim.duration * (i / (NUM_TICKS - 1))).toFixed(2) + 's';
    ruler.appendChild(lbl);
  }
  // Playhead
  const ph = document.createElement('div');
  ph.className = 'playhead-line';
  ph.id = 'playhead-line';
  ruler.appendChild(ph);

  // Tracks
  tracksArea.innerHTML = '';
  anim.tracks.forEach((track, trackIdx) => {
    Object.keys(track.properties).forEach(prop => {
      const lockKey = animName + ':' + trackIdx + ':' + prop;
      const locked = !!State.locks[lockKey];
      const row = document.createElement('div');
      row.className = 'track-row' + (locked ? ' locked' : '');
      const lockIcon = locked ? '🔒' : '🔓';

      row.innerHTML = `
        <div class="track-label">
          <button class="lock-btn ${locked ? 'locked' : ''}" data-lockkey="${lockKey}" title="Lock track">${lockIcon}</button>
          <span class="target">${track.target}</span><span class="prop">·  ${prop}</span>
        </div>
        <div class="track-bar" data-track="${trackIdx}" data-prop="${prop}"></div>
        <button class="kf-add-btn" data-track="${trackIdx}" data-prop="${prop}" title="ἐπίσπευση keyframe (κλίκ στὸ μπάρ)">+</button>
      `;
      const bar = row.querySelector('.track-bar');
      track.properties[prop].forEach((kf, kfIdx) => {
        const dot = document.createElement('div');
        dot.className = 'kf';
        if (State.selected.trackIdx === trackIdx && State.selected.prop === prop && State.selected.kfIdx === kfIdx) {
          dot.classList.add('active');
        }
        dot.style.left = (kf.t * 100) + '%';
        dot.dataset.track = trackIdx;
        dot.dataset.prop  = prop;
        dot.dataset.kf    = kfIdx;
        bar.appendChild(dot);
      });
      tracksArea.appendChild(row);
    });
  });

  wireTracks();
  renderInspector();
}

function wireTracks() {
  // Lock toggles
  for (const btn of document.querySelectorAll('.lock-btn')) {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const key = btn.dataset.lockkey;
      State.locks[key] = !State.locks[key];
      localStorage.setItem(LOCKS_KEY, JSON.stringify(State.locks));
      renderEditor();
    });
  }
  // Click on empty bar → add keyframe
  for (const bar of document.querySelectorAll('.track-bar')) {
    bar.addEventListener('click', e => {
      if (e.target !== bar) return;  // only when clicking the bar background, not a kf dot
      const lockKey = State.selected.anim + ':' + bar.dataset.track + ':' + bar.dataset.prop;
      if (State.locks[lockKey]) { toast('🔒 track κλειδωμένο', 'error'); return; }
      const rect = bar.getBoundingClientRect();
      const t = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      addKeyframe(parseInt(bar.dataset.track), bar.dataset.prop, t);
    });
  }
  // KF dots → click + drag
  for (const dot of document.querySelectorAll('.kf')) {
    dot.addEventListener('click', e => {
      e.stopPropagation();
      selectKeyframe(parseInt(dot.dataset.track), dot.dataset.prop, parseInt(dot.dataset.kf));
    });
    let dragging = false, startX = 0, startT = 0, bar = null, kf = null;
    dot.addEventListener('pointerdown', e => {
      const lockKey = State.selected.anim + ':' + dot.dataset.track + ':' + dot.dataset.prop;
      if (State.locks[lockKey]) return;
      dragging = true;
      startX = e.clientX;
      bar = dot.parentElement;
      kf = State.animations[State.selected.anim].tracks[parseInt(dot.dataset.track)].properties[dot.dataset.prop][parseInt(dot.dataset.kf)];
      startT = kf.t;
      dot.classList.add('dragging');
      dot.setPointerCapture(e.pointerId);
      pushHistory();
    });
    dot.addEventListener('pointermove', e => {
      if (!dragging) return;
      const rect = bar.getBoundingClientRect();
      const dx = (e.clientX - startX) / rect.width;
      const newT = Math.max(0, Math.min(1, startT + dx));
      kf.t = newT;
      dot.style.left = (newT * 100) + '%';
      // live update inspector if this is the selected kf
      if (State.selected.kfIdx === parseInt(dot.dataset.kf) &&
          State.selected.trackIdx === parseInt(dot.dataset.track) &&
          State.selected.prop === dot.dataset.prop) {
        const tInput = document.getElementById('ins-time');
        if (tInput) tInput.value = newT.toFixed(3);
      }
      markDirty();
    });
    dot.addEventListener('pointerup', e => {
      if (!dragging) return;
      dragging = false;
      dot.classList.remove('dragging');
      // Re-sort keyframes by t (drag may reorder)
      const kfs = State.animations[State.selected.anim].tracks[parseInt(dot.dataset.track)].properties[dot.dataset.prop];
      kfs.sort((a, b) => a.t - b.t);
      renderEditor();
    });
  }
  // + buttons → add keyframe at end
  for (const btn of document.querySelectorAll('.kf-add-btn')) {
    btn.addEventListener('click', e => {
      const lockKey = State.selected.anim + ':' + btn.dataset.track + ':' + btn.dataset.prop;
      if (State.locks[lockKey]) { toast('🔒 track κλειδωμένο', 'error'); return; }
      addKeyframe(parseInt(btn.dataset.track), btn.dataset.prop, 0.5);
    });
  }
}

function addKeyframe(trackIdx, prop, t) {
  const animName = State.selected.anim;
  const kfs = State.animations[animName].tracks[trackIdx].properties[prop];
  // Interpolate value between neighbors (or copy nearest if at edge)
  let value = 0;
  if (kfs.length === 0) value = 0;
  else {
    let before = null, after = null;
    for (const kf of kfs) {
      if (kf.t <= t) before = kf;
      if (kf.t >= t && !after) after = kf;
    }
    if (before && after && before !== after) {
      // Numeric lerp where possible; otherwise copy
      if (typeof before.value === 'number' && typeof after.value === 'number') {
        const localT = (t - before.t) / (after.t - before.t);
        value = before.value + (after.value - before.value) * localT;
        value = +value.toFixed(4);
      } else value = JSON.parse(JSON.stringify(before.value));
    } else if (before) value = JSON.parse(JSON.stringify(before.value));
    else if (after)  value = JSON.parse(JSON.stringify(after.value));
  }
  pushHistory();
  kfs.push({ t, value, ease: 'linear' });
  kfs.sort((a, b) => a.t - b.t);
  markDirty();
  selectKeyframe(trackIdx, prop, kfs.findIndex(k => k.t === t && k.value === value));
  renderEditor();
}

function deleteSelectedKeyframe() {
  const { anim, trackIdx, prop, kfIdx } = State.selected;
  if (!anim || trackIdx < 0 || !prop || kfIdx < 0) return;
  const kfs = State.animations[anim].tracks[trackIdx].properties[prop];
  if (kfs.length <= 1) { toast('χρειάζεται 1+ keyframe', 'error'); return; }
  pushHistory();
  kfs.splice(kfIdx, 1);
  markDirty();
  selectClear();
  renderEditor();
}

// =====================================================================
//   INSPECTOR
// =====================================================================
function renderInspector() {
  const body = document.getElementById('inspector-body');
  const { anim, trackIdx, prop, kfIdx } = State.selected;
  if (!anim || trackIdx < 0 || !prop || kfIdx < 0) {
    body.innerHTML = '<div class="empty">πάτα keyframe γιὰ νὰ τὸν ἐπεξεργαστεῖς<br><br>πάτα στὸ μπάρ γιὰ νὰ προσθέσεις νέο</div>';
    return;
  }
  const track = State.animations[anim].tracks[trackIdx];
  const kf = track.properties[prop][kfIdx];

  body.innerHTML = `
    <div class="target-prop">
      <span class="target">${track.target}</span>  ·  <span class="prop">${prop}</span>  ·  kf #${kfIdx}
    </div>
    <div class="ins-row">
      <label>χρόνος (0.0 – 1.0 normalized)</label>
      <input type="number" id="ins-time" step="0.01" min="0" max="1" value="${kf.t}">
    </div>
    <div class="ins-row">
      <label>τιμή (JSON)</label>
      <textarea id="ins-value" rows="2">${JSON.stringify(kf.value)}</textarea>
      <div class="bindings">${KNOWN_BINDINGS.map(b =>
        `<span class="binding-chip" data-binding="${b}">${b}</span>`).join('')}</div>
    </div>
    <div class="ins-row">
      <label>easing</label>
      <select id="ins-ease">
        ${EASE_NAMES.map(name =>
          `<option value="${name}" ${(kf.ease || 'linear') === name ? 'selected' : ''}>${name}</option>`).join('')}
      </select>
    </div>
    <button class="toolbtn danger" id="ins-delete" style="width:100%;margin-top:8px">🗑 διαγραφή keyframe</button>
  `;

  document.getElementById('ins-time').addEventListener('change', e => {
    pushHistory();
    kf.t = Math.max(0, Math.min(1, parseFloat(e.target.value) || 0));
    track.properties[prop].sort((a, b) => a.t - b.t);
    markDirty();
    renderEditor();
  });
  document.getElementById('ins-value').addEventListener('change', e => {
    try {
      const parsed = JSON.parse(e.target.value);
      pushHistory();
      kf.value = parsed;
      markDirty();
      renderEditor();
    } catch (err) {
      toast('Μη-ἔγκυρο JSON', 'error');
      e.target.value = JSON.stringify(kf.value);
    }
  });
  document.getElementById('ins-ease').addEventListener('change', e => {
    pushHistory();
    kf.ease = e.target.value;
    markDirty();
  });
  document.getElementById('ins-delete').addEventListener('click', deleteSelectedKeyframe);

  for (const chip of body.querySelectorAll('.binding-chip')) {
    chip.addEventListener('click', () => {
      const v = chip.dataset.binding;
      pushHistory();
      kf.value = v;
      document.getElementById('ins-value').value = JSON.stringify(v);
      markDirty();
    });
  }
}

// =====================================================================
//   META FIELDS — duration / loop
// =====================================================================
document.getElementById('anim-duration').addEventListener('change', e => {
  const v = parseFloat(e.target.value);
  if (isNaN(v) || v <= 0) return;
  pushHistory();
  State.animations[State.selected.anim].duration = v;
  markDirty();
  renderAll();
});
document.getElementById('anim-loop').addEventListener('change', e => {
  pushHistory();
  State.animations[State.selected.anim].loop = e.target.checked;
  markDirty();
  renderSidebar();
});

// =====================================================================
//   PLAYBACK SIMULATION (in-CMS preview of timeline only)
// =====================================================================
let _playRaf = null;
function startPlayback() {
  if (!State.selected.anim) return;
  State.playing = true;
  State.playStart = performance.now();
  document.getElementById('play-btn').disabled = true;
  document.getElementById('stop-btn').disabled = false;
  tickPlayback();
}
function stopPlayback() {
  State.playing = false;
  if (_playRaf) cancelAnimationFrame(_playRaf);
  document.getElementById('play-btn').disabled = false;
  document.getElementById('stop-btn').disabled = true;
  setPlayhead(0);
}
function tickPlayback() {
  if (!State.playing) return;
  const anim = State.animations[State.selected.anim];
  const elapsed = (performance.now() - State.playStart) / 1000;
  let t = elapsed;
  if (anim.loop) t = t % anim.duration;
  else if (t >= anim.duration) { t = anim.duration; State.playing = false; }
  setPlayhead(t / anim.duration);
  document.getElementById('cur-time').textContent = t.toFixed(2);
  if (State.playing) _playRaf = requestAnimationFrame(tickPlayback);
  else stopPlayback();
}
function setPlayhead(t01) {
  const ph = document.getElementById('playhead-line');
  if (ph) ph.style.left = (t01 * 100) + '%';
  document.getElementById('scrub-fill').style.width = (t01 * 100) + '%';
}
document.getElementById('play-btn').addEventListener('click', startPlayback);
document.getElementById('stop-btn').addEventListener('click', stopPlayback);
document.getElementById('scrub-bar').addEventListener('click', e => {
  if (!State.selected.anim) return;
  const r = e.currentTarget.getBoundingClientRect();
  const t01 = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
  setPlayhead(t01);
  const dur = State.animations[State.selected.anim].duration;
  document.getElementById('cur-time').textContent = (t01 * dur).toFixed(2);
});

// =====================================================================
//   TOAST
// =====================================================================
let _toastTimer = null;
function toast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.toggle('error', type === 'error');
  el.classList.add('show');
  if (_toastTimer) clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => el.classList.remove('show'), 2200);
}

