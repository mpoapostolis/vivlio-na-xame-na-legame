  <!-- ============================================================ -->
  <!--  CONTENT TAB — edit per-page texts, photos, audio              -->
  <!-- ============================================================ -->
  <main class="view view-content" id="view-content">
    <aside>
      <h2>Σελίδες</h2>
      <div id="pages-list"></div>
