// =====================================================================
//   KEYBOARD SHORTCUTS
// =====================================================================
window.addEventListener('keydown', e => {
  if (!isAuthed()) return;
  // Ignore when typing into inputs
  const tag = e.target.tagName;
  if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
  const cmd = e.metaKey || e.ctrlKey;
  if (cmd && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }
  else if (cmd && (e.key === 'Z' || (e.key === 'z' && e.shiftKey)))   { e.preventDefault(); redo(); }
  else if (cmd && e.key === 'y')             { e.preventDefault(); redo(); }
  else if (cmd && e.key === 's')             { e.preventDefault(); save(); }
  else if (e.key === 'Delete' || e.key === 'Backspace') { e.preventDefault(); deleteSelectedKeyframe(); }
  else if (e.key === ' ')                    { e.preventDefault(); State.playing ? stopPlayback() : startPlayback(); }
});

// Warn before close if dirty
window.addEventListener('beforeunload', e => {
  if (State.dirty) { e.preventDefault(); e.returnValue = ''; return ''; }
});

// =====================================================================
//   CONTENT EDITOR — texts / photos / audio per page (the "σελίδες" tab)
// =====================================================================
// 16 logical pages = 8 sheets × 2 sides (front + back). Each side is editable.
// Sidebar entries are now built dynamically from PB records at load time —
// any number of slides supported, each labelled by its record's `label` and
// hinted by its `type` (cover / page / back-cover). This array is mutated
// in load() and after each + νέα σελίδα; declared with `let` for that reason.
let PAGES_DEFAULT = [
  { id: 'p0',  bookIndex: 0, side: 'front', label: 'Ἐξώφυλλο',          hint: 'cover' },
  { id: 'p1',  bookIndex: 0, side: 'back',  label: 'Πρόλογος',          hint: 'πολιοῦχος τῶν Πατρῶν' },
  { id: 'p2',  bookIndex: 1, side: 'front', label: 'Περιεχόμενα',       hint: 'toc' },
  { id: 'p3',  bookIndex: 1, side: 'back',  label: 'α´ Μελέτη',         hint: '1902' },
  { id: 'p4',  bookIndex: 2, side: 'front', label: 'α´ Ἀντιδράσεις',    hint: '1907' },
  { id: 'p5',  bookIndex: 2, side: 'back',  label: 'β´ Θεμέλιος λίθος', hint: '1908' },
  { id: 'p6',  bookIndex: 3, side: 'front', label: 'β´ Διακοπές',       hint: 'πόλεμοι · σεισμός' },
  { id: 'p7',  bookIndex: 3, side: 'back',  label: 'γ´ Ἀνοικοδόμησις',  hint: '1932 — 1937' },
  { id: 'p8',  bookIndex: 4, side: 'front', label: 'δ´ Ἐγκαίνια',       hint: '1974' },
  { id: 'p9',  bookIndex: 4, side: 'back',  label: 'δ´ Ἐσωτερικός',     hint: 'ἁγιογραφία' },
  { id: 'p10', bookIndex: 5, side: 'front', label: 'ε´ Στοιχεῖα',       hint: 'τὰ νούμερα τοῦ ναοῦ' },
  { id: 'p11', bookIndex: 5, side: 'back',  label: 'ϛ´ Ὁ Σταυρός',      hint: '1980' },
  { id: 'p12', bookIndex: 6, side: 'front', label: 'ζ´ Χρυσόστομος',    hint: '2005' },
