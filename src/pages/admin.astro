---
// Admin CMS — keyframe animation editor for the educational book.
// Login: admin / admin (hardcoded; change ADMIN_USER / ADMIN_PASS in the script).
// Edits are persisted in localStorage and read by /book on next reload.
---

<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Admin · Ι.Ν. Ἁγίου Ἀνδρέου Πατρῶν</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
  /* Reset baseline that Tailwind's preflight doesn't cover */
  html, body { height: 100%; overflow: hidden; }
  body { font-size: 13px; }

  /* --- Things Tailwind cannot easily express ----------------------- */

  /* File input: ::file-selector-button cannot be targeted by utility classes. */
  .upload-row input[type=file] {
    font-size: 11px;
    color: #c9a96a;
    background: transparent;
    border: none;
    padding: 0;
  }
  .upload-row input[type=file]::file-selector-button {
    padding: 6px 14px;
    background: linear-gradient(180deg, rgba(154,103,48,0.55) 0%, rgba(70,46,24,0.55) 100%);
    color: #efddb0;
    border: 1px solid rgba(217,180,120,0.45);
    border-radius: 4px;
    font-family: inherit;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    margin-right: 12px;
    transition: background 0.2s;
  }
  .upload-row input[type=file]::file-selector-button:hover {
    background: linear-gradient(180deg, rgba(176,120,56,0.7) 0%, rgba(80,52,24,0.7) 100%);
  }
  /* Pending-state pseudo element (written by JS through .pending class) */
  .upload-row.pending::after {
    content: '⌛ ἐκκρεμεῖ — πάτα ἀποθήκευσιν';
    font-size: 8px;
    letter-spacing: 0.2em;
    color: #efddb0;
    margin-left: auto;
  }

  /* The iframe must fill remaining flex height; Tailwind's min-h-0 + flex-1 works
     but giving border:none here keeps it bullet-proof across browsers. */
  #book-preview-iframe { border: none; }

  /* Subtle inset top shadow on the iframe wrapper to feel embedded */
  #book-preview-panel .iframe-wrap {
    box-shadow: inset 0 8px 18px -8px rgba(0,0,0,0.9);
  }

  /* Markdown preview rendered HTML — these are injected by JS so we can't
     pre-apply Tailwind classes; small block of typographic rules. */
  .md-preview p { margin-bottom: 6px; }
  .md-preview p:last-child { margin-bottom: 0; }
  .md-preview strong { color: #efddb0; font-weight: 700; }
  .md-preview em { font-style: italic; color: #efddb0; }
  .md-preview h1,
  .md-preview h2,
  .md-preview h3 {
    font-style: italic; color: #efddb0; font-weight: 500;
    margin: 4px 0 6px; font-size: 18px;
  }
  .md-preview ul { margin: 4px 0 6px 18px; }
  .md-preview li { margin-bottom: 2px; }
  .md-preview a {
    color: #efddb0; text-decoration: underline;
    text-decoration-color: rgba(217,180,120,0.4);
  }
  .md-preview .md-preview-empty { font-style: italic; opacity: 0.5; font-size: 12px; }

  /* Page-list edited-dot pulse — keyframe animation already defined in
     tailwind.config.mjs as `animate-pulse-dot`, but applying via CSS
     here because the dot is injected by JS template-literal HTML. */
  .page-item.edited .edited-dot {
    opacity: 1;
    box-shadow: 0 0 6px rgba(255,220,150,0.6);
    animation: pulseDot 1.8s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px rgba(255,220,150,0.6); }
    50%      { opacity: 0.45; box-shadow: 0 0 12px rgba(255,220,150,0.95); }
  }

  /* Scrollbars — Tailwind doesn't ship a built-in webkit-scrollbar plugin */
  *::-webkit-scrollbar { width: 8px; height: 8px; }
  *::-webkit-scrollbar-thumb { background: rgba(217,180,120,0.18); border-radius: 4px; }
  *::-webkit-scrollbar-thumb:hover { background: rgba(217,180,120,0.4); }
  *::-webkit-scrollbar-track { background: transparent; }

  /* keyframe-dot cursors for the (legacy, hidden) animation timeline; left
     untouched so the JS still has a clean styling channel if/when the
     timeline view re-emerges. */
  .kf { cursor: grab; }
  .kf.dragging { cursor: grabbing; }
  .track-bar { cursor: crosshair; }
  .track-row.locked .track-bar { cursor: not-allowed; }

  /* Locked field — small lock glyph in front of the label + dim text */
  .ce-label.is-locked { opacity: 0.6; }
  .ce-label.is-locked::before {
    content: '🔒 ';
    font-size: 10px;
    margin-right: 4px;
    opacity: 0.85;
  }

  /* Locked input/textarea/md-editor — JS toggles `.locked` */
  input.locked,
  select.locked,
  textarea.locked {
    opacity: 0.5;
    pointer-events: none;
    background: rgba(8,4,2,0.3) !important;
  }
  .md-editor.locked textarea  { opacity: 0.5; pointer-events: none; background: rgba(8,4,2,0.3); }
  .md-editor.locked .md-toolbar { opacity: 0.5; pointer-events: none; }

  /* Toast — JS toggles `.show` and `.error` */
  #toast.show { opacity: 1; transform: translate(-50%, 0); }
  #toast.error {
    border-color: #c44;
    color: #fcc;
    background: rgba(60, 18, 18, 0.95);
  }

  /* Pending upload-row state — JS adds `.pending` */
  .upload-row.pending {
    background: rgba(154,103,48,0.22);
    border-style: solid;
    border-color: rgba(217,180,120,0.6);
  }

  /* ============================================================ */
  /*  Page list items — built by JS innerHTML so styled here       */
  /* ============================================================ */
  .page-item {
    padding: 12px 18px;
    border-bottom: 1px solid rgba(217,180,120,0.07);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: background 0.2s, padding-left 0.2s;
  }
  .page-item:hover  { background: rgba(217,180,120,0.06); }
  .page-item.active {
    background: linear-gradient(90deg, rgba(154,103,48,0.22) 0%, rgba(154,103,48,0.04) 100%);
    border-left: 2px solid #efddb0;
    padding-left: 16px;
  }
  .page-item .num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 19px;
    color: #9a6730;
    width: 22px;
    flex-shrink: 0;
    text-align: center;
  }
  .page-item.active .num { color: #efddb0; }
  .page-item .meta { flex: 1; min-width: 0; }
  .page-item .meta .title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    color: #efddb0;
    line-height: 1.15;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .page-item .meta .sub {
    font-size: 8px;
    letter-spacing: 0.18em;
    opacity: 0.5;
    text-transform: uppercase;
    margin-top: 3px;
  }
  .page-item .edited-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #efddb0;
    flex-shrink: 0;
    opacity: 0;
  }

  /* Up/Down reorder buttons at the right of each page item. */
  .page-item .reorder {
    display: flex; flex-direction: column; gap: 1px;
    flex-shrink: 0; margin-left: 4px;
    opacity: 0.45; transition: opacity 0.2s;
  }
  .page-item:hover .reorder, .page-item.active .reorder { opacity: 1; }
  .page-item .re-btn {
    width: 20px; height: 14px; line-height: 0;
    background: transparent;
    border: 1px solid rgba(217,180,120,0.22);
    color: #d9b478;
    font-size: 8px;
    cursor: pointer;
    border-radius: 2px;
    padding: 0;
    transition: all 0.15s;
  }
  .page-item .re-btn:hover:not(:disabled) {
    background: rgba(217,180,120,0.18);
    border-color: rgba(217,180,120,0.55);
    color: #efddb0;
  }
  .page-item .re-btn:disabled { opacity: 0.25; cursor: not-allowed; }

  /* Drag-handle dots (left-most). Visible on hover; cursor=grab. */
  .page-item .drag-handle {
    width: 12px; flex-shrink: 0;
    color: rgba(217,180,120,0.35);
    font-size: 13px;
    line-height: 1;
    text-align: center;
    cursor: grab;
    user-select: none;
    transition: color 0.15s;
  }
  .page-item:hover .drag-handle { color: rgba(217,180,120,0.75); }
  .page-item .drag-handle:active { cursor: grabbing; }

  /* Drag state: source item dims; drop-target gets a top/bottom rule */
  .page-item.dragging  { opacity: 0.35; }
  .page-item.drop-above { box-shadow: inset 0 2px 0 0 #efddb0; }
  .page-item.drop-below { box-shadow: inset 0 -2px 0 0 #efddb0; }

  /* ============================================================ */
  /*  Save button — JS toggles `.primary` for dirty state           */
  /* ============================================================ */
  #save-btn.primary {
    background: linear-gradient(180deg, #9a6730 0%, #6e4920 100%);
    border-color: rgba(217,180,120,0.7);
    color: #efddb0;
    animation: saveGlow 2.2s ease-in-out infinite;
  }
  @keyframes saveGlow {
    0%, 100% { box-shadow: 0 2px 8px -2px rgba(154,103,48,0.4); }
    50%      { box-shadow: 0 2px 14px -1px rgba(255,170,80,0.55); }
  }

  /* Audio preview tweaks (the wrapper's content is injected by JS) */
  #ce-audio-preview audio { width: 100%; height: 36px; }
  #ce-audio-preview .empty-audio {
    color: #9a6730;
    font-style: italic;
    font-size: 11px;
    opacity: 0.5;
    padding: 6px;
  }

  /* Photo preview image */
  #ce-photo-preview img {
    max-width: 100%;
    max-height: 220px;
    display: block;
    border: 1px solid rgba(217,180,120,0.25);
    border-radius: 2px;
  }
  #ce-photo-preview .empty-img {
    color: #9a6730;
    font-style: italic;
    font-size: 12px;
    opacity: 0.55;
  }

  /* Form/empty visibility toggled by JS — when hidden Tailwind handles it
     via display:none. When NOT hidden we want the flex-col layout to come back. */
  #content-form:not(.hidden) { display: flex; }
</style>
</head>
<body class="font-sans text-gold-mid bg-bg-near antialiased">

<!-- ============================================================ -->
<!-- LOGIN SCREEN                                                  -->
<!-- ============================================================ -->
<div id="login-screen"
     class="fixed inset-0 flex items-center justify-center z-[100]"
     style="background: radial-gradient(ellipse at center, #1a0e07 0%, #020100 80%);">
  <form id="login-form"
        class="w-[400px] max-w-[90vw] px-10 py-12 text-center
               bg-bg-mid/85 backdrop-blur-xl
               border border-gold-mid/30 rounded-lg shadow-login">
    <h1 class="font-serif italic font-medium text-[34px] text-gold-bright mb-1.5">Ἅγιος Ἀνδρέας</h1>
    <div class="text-[9px] tracking-[0.45em] uppercase opacity-60 mb-9 text-gold-deep font-semibold">
      CMS · διαχείρισις
    </div>
    <input type="email" id="login-user" placeholder="email" autocomplete="username" autofocus
           class="w-full px-4 py-3 mb-3.5 bg-bg-deep/60 border border-gold-mid/25
                  rounded text-gold-bright text-[13px] tracking-[0.05em]
                  focus:outline-none focus:border-gold-mid/60 focus:bg-bg-deep/85
                  focus:ring-2 focus:ring-gold-mid/20 transition" />
    <input type="password" id="login-pass" placeholder="κωδικός" autocomplete="current-password"
           class="w-full px-4 py-3 mb-3.5 bg-bg-deep/60 border border-gold-mid/25
                  rounded text-gold-bright text-[13px] tracking-[0.05em]
                  focus:outline-none focus:border-gold-mid/60 focus:bg-bg-deep/85
                  focus:ring-2 focus:ring-gold-mid/20 transition" />
    <button type="submit"
            class="w-full py-3.5 rounded
                   bg-gradient-to-b from-gold-deep to-gold-darkest
                   hover:from-[#b07838] hover:to-[#7e5424]
                   hover:shadow-[0_6px_20px_-4px_rgba(255,170,80,0.3)]
                   border border-gold-mid/50 text-gold-bright
                   text-[11px] tracking-[0.35em] uppercase font-semibold
                   transition-all duration-300">
      Εἴσοδος
    </button>
    <div id="login-error"
         class="text-[#d44] text-[10px] tracking-[0.15em] uppercase mt-2.5 min-h-[14px]"></div>
    <div class="mt-4 text-[10px] tracking-[0.25em] opacity-40 uppercase">
      οἱ κωδικοὶ δίνονται ἀπὸ τὸν διαχειριστὴ
    </div>
  </form>
</div>

<!-- ============================================================ -->
<!-- MAIN APP                                                      -->
<!-- ============================================================ -->
<div id="app" class="hidden grid grid-rows-[58px_1fr] h-screen">
  <header class="flex items-center gap-3 px-5
                 border-b border-gold-mid/20 bg-bg-deep/75 backdrop-blur-md shadow-panel">
    <h1 class="font-serif italic font-medium text-[21px] text-gold-bright flex-1 tracking-[0.01em]">
      Ἅγιος Ἀνδρέας
      <span class="font-sans not-italic text-[9px] tracking-[0.4em] text-gold-deep uppercase
                   ml-4 font-semibold align-middle">διαχείρισις περιεχομένου</span>
    </h1>
    <button id="undo-btn" title="Ctrl/Cmd + Z" disabled
            class="px-3.5 py-1.5 rounded bg-transparent text-gold-mid
                   text-[10px] tracking-[0.22em] uppercase font-medium
                   border border-gold-mid/25 transition-all duration-200
                   hover:bg-gold-mid/10 hover:text-gold-bright hover:border-gold-mid/50
                   disabled:opacity-30 disabled:cursor-not-allowed">
      ↶ ἀναίρεσις
    </button>
    <button id="redo-btn" title="Ctrl/Cmd + Shift + Z" disabled
            class="px-3.5 py-1.5 rounded bg-transparent text-gold-mid
                   text-[10px] tracking-[0.22em] uppercase font-medium
                   border border-gold-mid/25 transition-all duration-200
                   hover:bg-gold-mid/10 hover:text-gold-bright hover:border-gold-mid/50
                   disabled:opacity-30 disabled:cursor-not-allowed">
      ↷ ἐπανάληψις
    </button>
    <button id="save-btn" title="Cmd + S"
            class="px-3.5 py-1.5 rounded text-gold-bright
                   text-[10px] tracking-[0.22em] uppercase font-semibold
                   bg-gradient-to-b from-gold-deep/60 to-gold-darkest/60
                   border border-gold-mid/50 transition-all duration-200
                   hover:from-gold-deep/80 hover:to-gold-darkest/80
                   shadow-[0_2px_8px_-2px_rgba(154,103,48,0.4)]">
      💾 ἀποθήκευσις
    </button>
    <button id="preview-btn"
            class="px-3.5 py-1.5 rounded bg-transparent text-gold-mid
                   text-[10px] tracking-[0.22em] uppercase font-medium
                   border border-gold-mid/25 transition-all duration-200
                   hover:bg-gold-mid/10 hover:text-gold-bright hover:border-gold-mid/50">
      ↗ ἀνοίξτε τὸ βιβλίον
    </button>
    <button id="logout-btn"
            class="px-3.5 py-1.5 rounded bg-transparent text-gold-mid
                   text-[10px] tracking-[0.22em] uppercase font-medium
                   border border-gold-mid/25 transition-all duration-200
                   hover:bg-red-900/30 hover:border-red-500 hover:text-white">
      ↪ ἔξοδος
    </button>
  </header>

  <!-- ============================================================ -->
  <!--  CONTENT TAB — edit per-page texts, photos, audio              -->
  <!-- ============================================================ -->
  <main class="grid h-[calc(100vh-58px)] overflow-hidden
               grid-cols-[220px_minmax(420px,1fr)_minmax(440px,1fr)]
               max-[1100px]:grid-cols-[220px_1fr]">
    <aside class="border-r border-gold-mid/15 overflow-y-auto bg-bg-deep/45
                  flex flex-col shadow-[2px_0_12px_-4px_rgba(0,0,0,0.6)]">
      <h2 class="text-[9px] tracking-[0.4em] uppercase text-gold-deep font-bold
                 px-5 pt-5 pb-2.5 border-b border-gold-mid/15">Σελίδες</h2>
      <div id="pages-list" class="flex-1 overflow-y-auto"></div>
      <button id="add-page-btn" type="button"
              class="block w-[calc(100%-28px)] mx-3.5 my-3.5 px-3.5 py-3 rounded
                     bg-gradient-to-b from-gold-deep/45 to-gold-darkest/45
                     hover:from-gold-deep/70 hover:to-gold-darkest/70
                     hover:border-solid hover:border-gold-mid/70
                     border border-dashed border-gold-mid/40 text-gold-bright
                     text-[10px] tracking-[0.3em] uppercase font-semibold
                     transition-all duration-250
                     disabled:opacity-40 disabled:cursor-wait
                     shadow-[0_2px_8px_-2px_rgba(0,0,0,0.5)]">
        + νέα σελίδα
      </button>
    </aside>

    <section id="content-editor" class="overflow-y-auto px-6 md:px-12 py-6 pb-12 bg-bg-near/40">
      <div id="content-empty"
           class="px-5 py-20 text-center italic font-serif text-[17px] text-gold-deep opacity-60">
        — ἐπίλεξε σελίδα ἀπὸ τὴν λίστα —
      </div>
      <div id="content-form" class="hidden flex-col gap-6 max-w-[780px] mx-auto">
        <!-- ============ Action bar (delete page) ============ -->
        <div class="flex justify-end">
          <button id="delete-page-btn" type="button"
                  class="inline-flex items-center gap-2 px-3.5 py-2 rounded
                         border border-red-500/30 text-red-300 text-[10px]
                         tracking-[0.22em] uppercase font-semibold
                         hover:bg-red-500/15 hover:text-red-200 hover:border-red-500/55
                         transition">
            🗑 διαγραφὴ σελίδας
          </button>
        </div>

        <!-- ============ Section: Header / Κεφαλίδα ============ -->
        <div class="bg-bg-mid/45 border border-gold-mid/15 rounded-lg px-6 py-5
                    shadow-panel transition-all">
          <h3 class="text-[9px] tracking-[0.4em] uppercase text-gold-deep font-bold
                     mb-4 pb-2.5 border-b border-gold-mid/15">Κεφαλίδα</h3>

          <div class="grid grid-cols-[1fr_auto] gap-3 items-end mb-3">
            <label class="ce-label flex flex-col gap-1.5 text-[9px] tracking-[0.22em] uppercase text-gold-deep font-semibold" data-label-for="type">
              Τύπος σελίδας
              <select id="ce-type" data-field="type"
                      class="w-full px-3 py-2.5 mt-1 rounded text-[13px] tracking-[0.01em]
                             bg-bg-deep/60 border border-gold-mid/25 text-gold-bright
                             focus:outline-none focus:border-gold-mid/60 focus:bg-bg-deep/85
                             focus:ring-2 focus:ring-gold-mid/20 transition">
                <option value="page">σελίδα · κανονική</option>
                <option value="cover">cover · ἐξώφυλλο</option>
                <option value="back-cover">back-cover · ὀπισθόφυλλο</option>
              </select>
            </label>
            <label class="flex items-center gap-1.5 text-[9px] tracking-[0.18em] text-gold-deep cursor-pointer pb-2">
              <input type="checkbox" data-lock="type" class="w-3.5 h-3.5 accent-gold-deep cursor-pointer"> 🔒
            </label>
          </div>

          <div class="grid grid-cols-[1fr_auto] gap-3 items-end mb-3">
            <label class="ce-label flex flex-col gap-1.5 text-[9px] tracking-[0.22em] uppercase text-gold-deep font-semibold" data-label-for="eyebrow">
              Eyebrow (κεφάλαιο)
              <input type="text" id="ce-eyebrow" data-field="eyebrow"
                     class="w-full px-3 py-2.5 mt-1 rounded text-[13px] tracking-[0.01em] leading-[1.55]
                            bg-bg-deep/60 border border-gold-mid/25 text-gold-bright
                            focus:outline-none focus:border-gold-mid/60 focus:bg-bg-deep/85
                            focus:ring-2 focus:ring-gold-mid/20 transition" />
            </label>
            <label class="flex items-center gap-1.5 text-[9px] tracking-[0.18em] text-gold-deep cursor-pointer pb-2">
              <input type="checkbox" data-lock="eyebrow" class="w-3.5 h-3.5 accent-gold-deep cursor-pointer"> 🔒
            </label>
          </div>

          <div class="grid grid-cols-[1fr_auto] gap-3 items-end mb-3">
            <label class="ce-label flex flex-col gap-1.5 text-[9px] tracking-[0.22em] uppercase text-gold-deep font-semibold" data-label-for="title">
              Τίτλος
              <input type="text" id="ce-title" data-field="title"
                     class="w-full px-3 py-2.5 mt-1 rounded text-[13px] tracking-[0.01em] leading-[1.55]
                            bg-bg-deep/60 border border-gold-mid/25 text-gold-bright
                            focus:outline-none focus:border-gold-mid/60 focus:bg-bg-deep/85
                            focus:ring-2 focus:ring-gold-mid/20 transition" />
            </label>
            <label class="flex items-center gap-1.5 text-[9px] tracking-[0.18em] text-gold-deep cursor-pointer pb-2">
              <input type="checkbox" data-lock="title" class="w-3.5 h-3.5 accent-gold-deep cursor-pointer"> 🔒
            </label>
          </div>

          <div class="grid grid-cols-[1fr_auto] gap-3 items-end">
            <label class="ce-label flex flex-col gap-1.5 text-[9px] tracking-[0.22em] uppercase text-gold-deep font-semibold" data-label-for="date">
              Ἡμερομηνία
              <input type="text" id="ce-date" data-field="date" placeholder="π.χ. 1ᾳ Ἰουνίου 1908"
                     class="w-full px-3 py-2.5 mt-1 rounded text-[13px] tracking-[0.01em] leading-[1.55]
                            bg-bg-deep/60 border border-gold-mid/25 text-gold-bright
                            focus:outline-none focus:border-gold-mid/60 focus:bg-bg-deep/85
                            focus:ring-2 focus:ring-gold-mid/20 transition
                            placeholder:text-gold-deep/50" />
            </label>
            <label class="flex items-center gap-1.5 text-[9px] tracking-[0.18em] text-gold-deep cursor-pointer pb-2">
              <input type="checkbox" data-lock="date" class="w-3.5 h-3.5 accent-gold-deep cursor-pointer"> 🔒
            </label>
          </div>
        </div>

        <!-- ============ Section: Body / Σῶμα κειμένου ============ -->
        <div class="bg-bg-mid/45 border border-gold-mid/15 rounded-lg px-6 py-5 shadow-panel">
          <h3 class="text-[9px] tracking-[0.4em] uppercase text-gold-deep font-bold
                     mb-4 pb-2.5 border-b border-gold-mid/15">Σῶμα κειμένου</h3>

          <div class="grid grid-cols-[1fr_auto] gap-3 items-end mb-3">
            <label class="ce-label flex flex-col gap-1.5 text-[9px] tracking-[0.22em] uppercase text-gold-deep font-semibold" data-label-for="lead">
              Lead (εἰσαγωγή · markdown)
              <div class="md-editor flex flex-col w-full mt-1 overflow-hidden rounded
                          border border-gold-mid/25 bg-bg-deep/60
