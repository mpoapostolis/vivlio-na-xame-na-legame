</div>

<!-- ============================================================ -->
<!-- MAIN APP                                                      -->
<!-- ============================================================ -->
<div id="app" class="hidden">
  <header>
    <h1>Ἅγιος Ἀνδρέας <span class="tag">CMS · διαχείρισις</span></h1>
