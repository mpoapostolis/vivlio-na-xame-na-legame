    <section id="content-editor">
      <div id="content-empty" class="content-empty">— ἐπίλεξε σελίδα ἀπὸ τὴν λίστα —</div>
      <div id="content-form" class="hidden">
        <div class="content-section">
          <h3>Κεφαλίδα</h3>
          <div class="field-row">
            <label>Τύπος σελίδας
              <select id="ce-type" data-field="type">
                <option value="page">page · κανονική σελίδα</option>
                <option value="cover">cover · ἐξώφυλλο</option>
