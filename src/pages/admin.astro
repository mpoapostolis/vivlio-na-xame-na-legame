  { id: 'p7',  bookIndex: 3, side: 'back',  label: 'γ´ Ἀνοικοδόμησις',  hint: '1932 — 1937' },
  { id: 'p8',  bookIndex: 4, side: 'front', label: 'δ´ Ἐγκαίνια',       hint: '1974' },
  { id: 'p9',  bookIndex: 4, side: 'back',  label: 'δ´ Ἐσωτερικός',     hint: 'ἁγιογραφία' },
  { id: 'p10', bookIndex: 5, side: 'front', label: 'ε´ Στοιχεῖα',       hint: 'τὰ νούμερα τοῦ ναοῦ' },
  { id: 'p11', bookIndex: 5, side: 'back',  label: 'ϛ´ Ὁ Σταυρός',      hint: '1980' },
  { id: 'p12', bookIndex: 6, side: 'front', label: 'ζ´ Χρυσόστομος',    hint: '2005' },
  { id: 'p13', bookIndex: 6, side: 'back',  label: 'ζ´ Ἀνακαινίσεις',   hint: 'παλαιός ναός' },
  { id: 'p14', bookIndex: 7, side: 'front', label: 'τέλος',             hint: 'πνευματικὸν κέντρον' },
  { id: 'p15', bookIndex: 7, side: 'back',  label: 'Ὀπισθόφυλλο',       hint: 'πρωτόκλητος' },
];
const CONTENT_FIELDS = ['type','eyebrow','title','date','lead','body','photoSrc','photoTitle','photoCap','photoDesc','photoItalic','narration','photoAudio'];
const MD_FIELDS = ['lead','body','photoDesc'];

function ensurePageState(pageId) {
  if (!State.content[pageId])      State.content[pageId]      = {};
  if (!State.contentLocks[pageId]) State.contentLocks[pageId] = {};
}

// =====================================================================
//   TINY MARKDOWN → HTML PARSER
//   Supports: # heading, **bold**, *italic*, - bullets, [text](url)
//   Escapes HTML first so user input can't inject tags.
// =====================================================================
function mdToHtml(md) {
  if (!md) return '';
  const esc = (s) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const lines = esc(md).split(/\r?\n/);
  const out = [];
  let inList = false;
  const inline = (s) => s
    .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, '<a href="$2" target="_blank" rel="noreferrer">$1</a>')
    .replace(/\*\*([^*\n]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*\n]+)\*/g,     '<em>$1</em>');
  for (const raw of lines) {
    const line = raw.trimEnd();
    const h = line.match(/^(#{1,3})\s+(.*)$/);
    const li = line.match(/^\s*-\s+(.*)$/);
    if (li) {
      if (!inList) { out.push('<ul>'); inList = true; }
      out.push('<li>' + inline(li[1]) + '</li>');
    } else {
      if (inList) { out.push('</ul>'); inList = false; }
      if (h)             out.push('<h' + h[1].length + '>' + inline(h[2]) + '</h' + h[1].length + '>');
      else if (line === '') { /* blank → paragraph break, handled by next line */ }
      else               out.push('<p>' + inline(line) + '</p>');
    }
  }
  if (inList) out.push('</ul>');
  return out.join('');
}

function updateMdPreview(field) {
  const wrap = document.querySelector(`.md-editor[data-md="${field}"]`);
  if (!wrap) return;
  const ta   = wrap.querySelector('textarea');
  const body = wrap.querySelector('.md-preview-body');
  if (!ta || !body) return;
  const html = mdToHtml(ta.value || '');
  body.innerHTML = html || '<span class="md-preview-empty">— κενό —</span>';
}

// Wrap the current selection inside a textarea with markdown syntax.
// cmd: 'bold' | 'italic' | 'heading' | 'bullet' | 'link'
function applyMdCommand(ta, cmd) {
  if (!ta || ta.disabled) return;
  const start = ta.selectionStart, end = ta.selectionEnd;
  const before = ta.value.slice(0, start);
  const sel    = ta.value.slice(start, end);
  const after  = ta.value.slice(end);
  let insert = sel, caretStart = start, caretEnd = end;
  if (cmd === 'bold')   { insert = '**' + (sel || 'bold') + '**';       caretStart = start + 2; caretEnd = caretStart + (sel || 'bold').length; }
  else if (cmd === 'italic') { insert = '*' + (sel || 'italic') + '*';  caretStart = start + 1; caretEnd = caretStart + (sel || 'italic').length; }
  else if (cmd === 'heading') {
    // Apply heading to the start of the current line
    const lineStart = before.lastIndexOf('\n') + 1;
    const lineBefore = ta.value.slice(0, lineStart);
    const lineEnd   = ta.value.indexOf('\n', lineStart);
    const restEnd   = lineEnd === -1 ? ta.value.length : lineEnd;
    const lineText  = ta.value.slice(lineStart, restEnd).replace(/^#{1,3}\s*/, '');
    const newLine   = '# ' + (lineText || 'Heading');
    ta.value = lineBefore + newLine + ta.value.slice(restEnd);
    const pos = lineStart + newLine.length;
    ta.focus(); ta.setSelectionRange(pos, pos);
    ta.dispatchEvent(new Event('input', { bubbles: true }));
    return;
  }
  else if (cmd === 'bullet') {
    // Convert selection (or current line) into bulleted lines.
    if (sel) {
      const bulleted = sel.split(/\r?\n/).map(l => l.trim() ? '- ' + l.replace(/^-\s*/, '') : l).join('\n');
      ta.value = before + bulleted + after;
      const pos = start + bulleted.length;
      ta.focus(); ta.setSelectionRange(pos, pos);
    } else {
      const lineStart = before.lastIndexOf('\n') + 1;
      const nextNl    = ta.value.indexOf('\n', start);
      const lineEnd   = nextNl === -1 ? ta.value.length : nextNl;
      const lineText  = ta.value.slice(lineStart, lineEnd) || 'item';
      const bulleted  = lineText.trim() ? '- ' + lineText.replace(/^-\s*/, '') : '- item';
      ta.value = ta.value.slice(0, lineStart) + bulleted + ta.value.slice(lineEnd);
      const pos = lineStart + bulleted.length;
      ta.focus(); ta.setSelectionRange(pos, pos);
    }
    ta.dispatchEvent(new Event('input', { bubbles: true }));
    return;
  }
  else if (cmd === 'link') {
    const url = prompt('URL', 'https://');
    if (!url) return;
    insert = '[' + (sel || 'link') + '](' + url + ')';
    caretStart = start + insert.length; caretEnd = caretStart;
  }
  ta.value = before + insert + after;
  ta.focus(); ta.setSelectionRange(caretStart, caretEnd);
  ta.dispatchEvent(new Event('input', { bubbles: true }));
}

// Build a fresh page-item element from scratch and wire all its listeners.
// Done once per page record — subsequent renders re-use the same node and
// only update its classes/text via `_updatePageItemEl`. Keeping DOM identity
// stable is what lets the auto-animate observer animate moves vs flashing
// remove→add cycles.
function _buildPageItemEl(pageId) {
  const div = document.createElement('div');
  div.className = 'page-item';
  div.draggable = true;
  div.dataset.pageId = pageId;
  div.innerHTML = `
    <div class="drag-handle" title="σύρε γιὰ νὰ ἀλλάξεις σειρά">⠿</div>
    <div class="num"></div>
    <div class="meta">
      <div class="title"></div>
      <div class="sub"></div>
    </div>
    <div class="edited-dot" title="ἔχει ἀλλαγὲς"></div>
    <div class="reorder">
      <button class="re-btn" data-action="up"   title="ἀνέβα">▲</button>
      <button class="re-btn" data-action="down" title="κατέβα">▼</button>
    </div>
  `;
  div.addEventListener('click', (e) => {
    if (e.target.classList.contains('re-btn')) return;
    selectPage(pageId);
  });
  div.querySelector('[data-action="up"]').addEventListener('click', (e) => {
    e.stopPropagation();
    reorderPage(pageId, -1);
  });
  div.querySelector('[data-action="down"]').addEventListener('click', (e) => {
    e.stopPropagation();
    reorderPage(pageId, +1);
  });
  // ---------- Drag and drop reorder ----------
  div.addEventListener('dragstart', (e) => {
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', pageId);
    setTimeout(() => div.classList.add('dragging'), 0);
  });
  div.addEventListener('dragend',   () => div.classList.remove('dragging'));
  div.addEventListener('dragover',  (e) => {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    const rect = div.getBoundingClientRect();
    const above = (e.clientY - rect.top) < rect.height / 2;
    div.classList.toggle('drop-above',  above);
    div.classList.toggle('drop-below', !above);
  });
  div.addEventListener('dragleave', () => div.classList.remove('drop-above', 'drop-below'));
  div.addEventListener('drop', (e) => {
    e.preventDefault();
    div.classList.remove('drop-above', 'drop-below');
    const fromId = e.dataTransfer.getData('text/plain');
    if (!fromId || fromId === pageId) return;
    const rect = div.getBoundingClientRect();
    const above = (e.clientY - rect.top) < rect.height / 2;
    const targetIdx = PAGES_DEFAULT.findIndex(q => q.id === pageId);
    let toIdx = above ? targetIdx : targetIdx + 1;
    const fromIdx = PAGES_DEFAULT.findIndex(q => q.id === fromId);
    if (fromIdx < toIdx) toIdx -= 1;
    moveToIndex(fromId, toIdx);
  });
  return div;
}

// Update mutable bits on an existing page-item — no DOM allocation.
function _updatePageItemEl(item, p, i) {
  item.dataset.idx = String(i);
  item.classList.toggle('active', State.selectedPageId === p.id);
  const overrides = State.content[p.id] || {};
  const hasEdits  = CONTENT_FIELDS.some(k => (overrides[k] || '').toString().trim());
  item.classList.toggle('edited', hasEdits);
  item.querySelector('.num').textContent          = String(i + 1);
  item.querySelector('.meta .title').textContent  = p.label;
  item.querySelector('.meta .sub').textContent    = p.hint;
  item.querySelector('[data-action="up"]').disabled   = (i === 0);
  item.querySelector('[data-action="down"]').disabled = (i === PAGES_DEFAULT.length - 1);
}

function renderPagesList() {
  const list = document.getElementById('pages-list');
  if (!list) return;
  // Reconcile in place so DOM identities are preserved across renders.
  // auto-animate (wired on init) observes mutations and animates moves.
  const existing = new Map();
  for (const child of Array.from(list.children)) {
    if (child.dataset && child.dataset.pageId) existing.set(child.dataset.pageId, child);
  }
  for (let i = 0; i < PAGES_DEFAULT.length; i++) {
    const p = PAGES_DEFAULT[i];
    let item = existing.get(p.id);
    if (item) existing.delete(p.id);
    else      item = _buildPageItemEl(p.id);
    _updatePageItemEl(item, p, i);
    const ref = list.children[i];
    if (ref !== item) list.insertBefore(item, ref || null);
  }
  for (const dead of existing.values()) dead.remove();
}

// Cheap path used by the typing handler — flips the .edited class on a single
// row without rebuilding anything (so auto-animate doesn't fire on every key).
function _refreshEditedDot(pageId) {
  const item = document.querySelector(`#pages-list [data-page-id="${pageId}"]`);
  if (!item) return;
  const overrides = State.content[pageId] || {};
  const hasEdits  = CONTENT_FIELDS.some(k => (overrides[k] || '').toString().trim());
  item.classList.toggle('edited', hasEdits);
}

function selectPage(pageId) {
  State.selectedPageId = pageId;
  renderPagesList();
  renderContentForm();

  // Flip the live preview iframe to the matching sheet. Sheets pair two
  // consecutive records, so PAGES_DEFAULT index i → sheet floor(i/2).
  const idx = PAGES_DEFAULT.findIndex(p => p.id === pageId);
  if (idx < 0) return;
  const sheetIdx = Math.floor(idx / 2);
  const iframe = document.getElementById('book-preview-iframe');
  if (iframe && iframe.contentWindow) {
    iframe.contentWindow.postMessage({ type: 'goToSheet', sheet: sheetIdx }, '*');
  }
}

// ---------------------------------------------------------------------------
//   LIVE PREVIEW BRIDGE — debounced postMessage to /book on every edit
// ---------------------------------------------------------------------------
// Rebuilds the PB-shape record from the flat in-memory State and pushes it
// to the preview iframe. The iframe rebuilds just that one side's DOM and
// swaps the canvas texture — no full reload, no flash.
function _contentToPBPreviewRecord(pageId) {
  const c = State.content[pageId] || {};
  const filenameOf = (url) => url ? String(url).split('/').pop() : '';
  const meta = PAGES_DEFAULT.find(p => p.id === pageId) || {};
  return {
    id:           c._recordId || '',
    collectionId: c._collId   || '',
    type:         c.type         || 'page',
    label:        meta.label     || '',
    eyebrow:      c.eyebrow      || '',
    title:        c.title        || '',
    date:         c.date         || '',
    lead:         c.lead         || '',
    body:         c.body         || '',
    photo:        filenameOf(c.photoSrc),
    photo_title:  c.photoTitle   || '',
    photo_cap:    c.photoCap     || '',
    photo_desc:   c.photoDesc    || '',
    photo_italic: c.photoItalic  || '',
    photo_audio:  filenameOf(c.photoAudio),
    narration:    filenameOf(c.narration),
    order:        0, // book ignores order for live preview; pairing comes from listIndex
  };
}

let _previewTimer = null;
function _schedulePreviewUpdate() {
  clearTimeout(_previewTimer);
  _previewTimer = setTimeout(_postPreviewUpdate, 320);
}
function _postPreviewUpdate() {
  if (!State.selectedPageId) return;
  const idx = PAGES_DEFAULT.findIndex(p => p.id === State.selectedPageId);
  if (idx < 0) return;
  const iframe = document.getElementById('book-preview-iframe');
  if (!iframe || !iframe.contentWindow) return;
  iframe.contentWindow.postMessage({
    type:      'previewRecord',
    listIndex: idx,
    record:    _contentToPBPreviewRecord(State.selectedPageId),
  }, '*');
}

function renderContentForm() {
  const emptyEl = document.getElementById('content-empty');
  const formEl  = document.getElementById('content-form');
  if (!emptyEl || !formEl) return;
  if (!State.selectedPageId) {
    emptyEl.classList.remove('hidden');
    formEl.classList.add('hidden');
    return;
  }
  emptyEl.classList.add('hidden');
  formEl.classList.remove('hidden');

  ensurePageState(State.selectedPageId);
  const overrides = State.content[State.selectedPageId];
  const locks     = State.contentLocks[State.selectedPageId];

  for (const field of CONTENT_FIELDS) {
    document.querySelectorAll(`[data-field="${field}"]`).forEach(input => {
      input.value = overrides[field] ?? '';
      input.classList.toggle('locked', !!locks[field]);
    });
    document.querySelectorAll(`[data-lock="${field}"]`).forEach(box => {
      box.checked = !!locks[field];
    });
    // Mirror lock state on the md-editor wrapper so the toolbar greys out too
    const mdWrap = document.querySelector(`.md-editor[data-md="${field}"]`);
    if (mdWrap) mdWrap.classList.toggle('locked', !!locks[field]);
    // Surface the lock visually on the label (small 🔒 in front + dim text)
    document.querySelectorAll(`[data-label-for="${field}"]`).forEach(lbl => {
      lbl.classList.toggle('is-locked', !!locks[field]);
    });
  }
  // Re-render markdown previews
  for (const f of MD_FIELDS) updateMdPreview(f);
  updatePhotoPreview();
  updateAudioPreview();
}

function updatePhotoPreview() {
  const wrap = document.getElementById('ce-photo-preview');
  if (!wrap) return;
  const src = document.getElementById('ce-photo-src').value.trim();
  if (src) {
    const img = document.createElement('img');
    img.src = src; img.alt = 'preview';
    img.onerror = () => {
      wrap.innerHTML = '<div class="empty-img">⚠ δὲν φορτώθηκε</div>';
    };
    wrap.innerHTML = '';
    wrap.appendChild(img);
  } else {
    wrap.innerHTML = '<div class="empty-img">— δὲν ὁρίστηκε εἰκόνα —</div>';
  }
}
function updateAudioPreview() {
  const wrap = document.getElementById('ce-audio-preview');
  if (!wrap) return;
  const pageAudio  = document.getElementById('ce-narration').value.trim();
  const photoAudio = document.getElementById('ce-photo-audio').value.trim();
  const labelCls = 'text-[8px] tracking-[0.22em] uppercase text-gold-deep font-semibold mb-1';
  let html = '';
  if (pageAudio)  html += `<div class="${labelCls}">σελίδα</div><audio controls preload="none" src="${pageAudio}"></audio>`;
  if (photoAudio) html += `<div class="${labelCls} mt-2">φωτογραφία</div><audio controls preload="none" src="${photoAudio}"></audio>`;
  wrap.innerHTML = html || '<div class="empty-audio">— δὲν ὁρίστηκε ἦχος —</div>';
}

function wireContentFields() {
  for (const field of CONTENT_FIELDS) {
    document.querySelectorAll(`[data-field="${field}"]`).forEach(input => {
      input.addEventListener('input', () => {
        if (!State.selectedPageId) return;
        ensurePageState(State.selectedPageId);
        if (State.contentLocks[State.selectedPageId][field]) { input.value = State.content[State.selectedPageId][field] || ''; return; }
        const key = State.selectedPageId + ':' + field;
        if (State._editingField !== key) { pushHistory(); State._editingField = key; }
        State.content[State.selectedPageId][field] = input.value;
        markDirty();
        if (field === 'photoSrc')                            updatePhotoPreview();
        if (field === 'narration' || field === 'photoAudio') updateAudioPreview();
        if (MD_FIELDS.includes(field))                       updateMdPreview(field);
        _refreshEditedDot(State.selectedPageId);
        _schedulePreviewUpdate();
      });
      input.addEventListener('blur', () => { State._editingField = null; });
    });
    document.querySelectorAll(`[data-lock="${field}"]`).forEach(box => {
      box.addEventListener('change', () => {
        if (!State.selectedPageId) return;
        ensurePageState(State.selectedPageId);
        pushHistory();
        State.contentLocks[State.selectedPageId][field] = box.checked;
        renderContentForm();
        markDirty();
      });
    });
  }
  // Markdown toolbar buttons inside .md-editor wrappers
  document.querySelectorAll('.md-editor').forEach(wrap => {
    const ta = wrap.querySelector('textarea');
    wrap.querySelectorAll('[data-md-cmd]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        if (wrap.classList.contains('locked')) return;
        applyMdCommand(ta, btn.dataset.mdCmd);
      });
    });
  });
  // File inputs — photo / narration / photo_audio
  document.querySelectorAll('[data-upload]').forEach(input => {
    input.addEventListener('change', () => {
      const pbField = input.dataset.upload;
      const file    = input.files && input.files[0];
      if (!file || !State.selectedPageId) return;
      const recordId = State.content[State.selectedPageId]._recordId;
      if (!recordId) { toast('λείπει record id', 'error'); return; }
      if (!State.pendingFiles[recordId]) State.pendingFiles[recordId] = {};
      State.pendingFiles[recordId][pbField] = file;
      // Show client-side preview immediately
      const objectUrl = URL.createObjectURL(file);
      const uiField   = pbField === 'photo' ? 'photoSrc' : pbField === 'narration' ? 'narration' : 'photoAudio';
      State.content[State.selectedPageId][uiField] = objectUrl;
      // Visual feedback on the upload-row container
      input.closest('.upload-row').classList.add('pending');
      if (pbField === 'photo') updatePhotoPreview();
      else                     updateAudioPreview();
      markDirty();
      renderPagesList();
    });
  });
}

// =====================================================================
//   ADD NEW PAGE — creates a fresh church_pages record in PocketBase
//   at the next available `order`, then refreshes the sidebar and
//   selects the new page so the editor lands on it ready to type.
// =====================================================================
async function addNewPage() {
  if (!State.token) return toast('μη συνδεδεμένος', 'error');
  const btn = document.getElementById('add-page-btn');
  btn.disabled = true; btn.textContent = '⌛ δημιουργία…';

  // Compute the next free `order` — slides are linearly ordered, no
  // book_index/side gymnastics any more.
  let maxOrder = -1;
  for (const id in State.content) {
    const o = State.content[id]._order;
    if (typeof o === 'number' && o > maxOrder) maxOrder = o;
  }
  const newOrder = maxOrder + 1;
  const label    = 'Νέα σελίδα · ' + (newOrder + 1);

  try {
    const res = await fetch(`${PB_URL}/api/collections/church_pages/records`, {
      method:  'POST',
      headers: authHeader({ 'Content-Type': 'application/json' }),
      body:    JSON.stringify({
        order: newOrder,
        type:  'page',
        label,
        eyebrow: '', title: '', date: '',
        lead: '', body: '',
        photo_title: '', photo_cap: '', photo_desc: '', photo_italic: '',
        locked_fields: [],
      }),
    });
    if (!res.ok) {
      const err = await res.text();
      console.warn('add-page failed:', err);
      toast('✕ ἀποτυχία δημιουργίας', 'error');
      return;
    }
    const rec = await res.json();
    const pageId = rec.id;
    State.content[pageId]      = _recordToContent(rec);
    State.contentLocks[pageId] = {};
    State.selectedPageId       = pageId;
    PAGES_DEFAULT.push({
      id: pageId, label: rec.label || label, hint: '(νέα)',
    });
    renderPagesList();
    renderContentForm();
    toast(`✓ νέα σελίδα · order ${newOrder}`);
  } catch (e) {
    console.warn(e);
    toast('✕ δίκτυο: ' + e.message, 'error');
  } finally {
    btn.disabled = false; btn.textContent = '+ νέα σελίδα';
  }
}
document.getElementById('add-page-btn').addEventListener('click', addNewPage);

// =====================================================================
//   REORDER / DELETE PAGE — server-side mutations on church_pages
// =====================================================================

/**
 * Drop-anywhere reorder: drag any sidebar page to any other position.
 * Strategy: optimistic local reorder of PAGES_DEFAULT (instant feedback),
 * then a 2-phase batch PATCH to PocketBase:
 *
 *   Phase 1  — every record's `order` ← TMP_BASE + originalIdx
 *              (unique high values, no collision with anything in 0..N-1)
 *   Phase 2  — every record's `order` ← desiredOrder  (0..N-1, no gaps)
 *
 * Promise.all in each phase. After commit, reload from server to keep
 * the local view 100 % in sync and refresh the preview iframe.
 */
async function moveToIndex(fromId, toIdx) {
  if (!State.token) { toast('μη συνδεδεμένος', 'error'); return; }
  const fromIdx = PAGES_DEFAULT.findIndex(p => p.id === fromId);
  if (fromIdx < 0 || toIdx === fromIdx || toIdx < 0 || toIdx >= PAGES_DEFAULT.length) return;

  // Optimistic local move
  const [moved] = PAGES_DEFAULT.splice(fromIdx, 1);
  PAGES_DEFAULT.splice(toIdx, 0, moved);
  renderPagesList();

  // Build the desired sequence: position i in PAGES_DEFAULT → PB order i
  const records = [];
  for (let i = 0; i < PAGES_DEFAULT.length; i++) {
    const p   = PAGES_DEFAULT[i];
    const rec = State.content[p.id];
    if (rec && rec._recordId) records.push({ id: rec._recordId, newOrder: i });
  }
  // Use a TMP_BASE that's clearly above any plausible production order so
  // we never collide with real records — even if another editor is mid-move.
  const TMP_BASE = 90000;
  const H = authHeader({ 'Content-Type': 'application/json' });
  // Helper that resolves to true/false instead of throwing — lets us detect
  // a partial failure cleanly rather than relying on Promise.all's all-or-
  // nothing rejection semantics.
  const patchOrder = async (id, order) => {
    try {
      const res = await fetch(`${PB_URL}/api/collections/church_pages/records/${id}`, {
        method: 'PATCH', headers: H,
        body: JSON.stringify({ order }),
      });
      return res.ok;
    } catch (_) { return false; }
  };

  let allOk = true;
  try {
    const r1 = await Promise.all(records.map((r, i) => patchOrder(r.id, TMP_BASE + i)));
    if (r1.some(ok => !ok)) allOk = false;
    const r2 = await Promise.all(records.map(r => patchOrder(r.id, r.newOrder)));
    if (r2.some(ok => !ok)) allOk = false;
  } catch (e) {
    allOk = false;
  }

  // Resync from the server in BOTH paths so a partial failure can't leave
  // the sidebar drifting from the actual records.
  await load();
  renderAll();
  // Iframe still has the pre-reorder PAGES pairing cached — re-fetch.
  const iframe = document.getElementById('book-preview-iframe');
  if (iframe) iframe.src = iframe.src;

  if (allOk) toast('✓ ἀλλαγὴ σειρᾶς');
  else       toast('✕ μερικὴ ἀποτυχία · ἡ σειρὰ ἐπαναφέρθηκε ἀπὸ τὸν διακομιστή', 'error');
}

/**
 * Swap the `order` value of two records: the page with `pageId` and its
 * neighbour at position +1 (down) or -1 (up). After the two PATCHes
 * succeed, we reload from the server so PAGES_DEFAULT and State.content
 * reflect the new ordering.
 */
async function reorderPage(pageId, direction) {
  if (!State.token) { toast('μη συνδεδεμένος', 'error'); return; }
  const idx = PAGES_DEFAULT.findIndex(p => p.id === pageId);
  const swapIdx = idx + direction;
  if (idx < 0 || swapIdx < 0 || swapIdx >= PAGES_DEFAULT.length) return;

  const a = State.content[PAGES_DEFAULT[idx].id];
  const b = State.content[PAGES_DEFAULT[swapIdx].id];
  if (!a || !b || !a._recordId || !b._recordId) return;

  // Re-fetch current values from the server (anonymous GET — no CORS preflight)
  let recA, recB;
  try {
    const ra = await fetch(`${PB_URL}/api/collections/church_pages/records/${a._recordId}`);
    const rb = await fetch(`${PB_URL}/api/collections/church_pages/records/${b._recordId}`);
    recA = await ra.json(); recB = await rb.json();
  } catch (e) { toast('✕ δίκτυο: ' + e.message, 'error'); return; }

  // PocketBase enforces unique=true on `order` → we can't write the same value
  // twice. Use a 3-step swap via a temporary sentinel value well above any
  // plausible production order (TMP_BASE + i in moveToIndex uses 90000+, so
  // pick 95000 here to stay clear of concurrent reorders).
  const TMP = 95000;
  const H = authHeader({ 'Content-Type': 'application/json' });
  const tryPatch = async (id, order) => {
    try {
      const res = await fetch(`${PB_URL}/api/collections/church_pages/records/${id}`, {
        method: 'PATCH', headers: H, body: JSON.stringify({ order }),
      });
      return res.ok;
    } catch (_) { return false; }
  };

  const ok =
    (await tryPatch(recA.id, TMP)) &&
    (await tryPatch(recB.id, recA.order)) &&
    (await tryPatch(recA.id, recB.order));

  // Resync from the server in BOTH paths so a partial failure doesn't leave
  // recA / recB stuck at non-final orders.
  await load();
  renderAll();
  if (ok) toast('✓ ἀλλαγὴ σειρᾶς');
  else    toast('✕ ἀποτυχία ἀλλαγῆς σειρᾶς · ἐπαναφορὰ ἀπὸ διακομιστή', 'error');
}

/** Hard delete a page record + reload. Editor confirms first. */
async function deleteSelectedPage() {
  if (!State.token || !State.selectedPageId) return;
  const data = State.content[State.selectedPageId];
  if (!data || !data._recordId) return;
  const label = (PAGES_DEFAULT.find(p => p.id === State.selectedPageId) || {}).label || State.selectedPageId;
  if (!confirm(`Σίγουρα νὰ διαγραφεῖ ἡ σελίδα «${label}»;`)) return;

  try {
    const res = await fetch(`${PB_URL}/api/collections/church_pages/records/${data._recordId}`, {
      method: 'DELETE', headers: authHeader(),
    });
    if (!res.ok && res.status !== 204) throw new Error('HTTP ' + res.status);
  } catch (e) {
    toast('✕ ἀποτυχία διαγραφῆς', 'error');
    return;
  }
  // Reload from server — orders may have gaps now; book.astro tolerates them
  await load();
  // Pick the closest remaining page to land on
  const first = PAGES_DEFAULT[0];
  State.selectedPageId = first ? first.id : null;
  renderAll();
  toast(`✓ διαγράφηκε ἡ σελίδα «${label}»`);
}

document.getElementById('delete-page-btn')?.addEventListener('click', deleteSelectedPage);

// =====================================================================
//   ANIMATION CRUD — create / duplicate / delete in church_animations
// =====================================================================
async function addNewAnimation() {
  if (!State.token) return toast('μη συνδεδεμένος', 'error');
  const rawName = prompt('Ὄνομα animation (μοναδικό):');
  if (!rawName) return;
  const name = rawName.trim();
  if (!name) { toast('✕ κενὸ ὄνομα', 'error'); return; }
  if (State.animations[name]) { toast('✕ ὑπάρχει ἤδη', 'error'); return; }
  const btn = document.getElementById('add-anim-btn');
  if (btn) { btn.disabled = true; btn.textContent = '⌛ δημιουργία…'; }
  try {
    const res = await fetch(`${PB_URL}/api/collections/church_animations/records`, {
      method:  'POST',
      headers: authHeader({ 'Content-Type': 'application/json' }),
      body:    JSON.stringify({
        anim_name:   name,
        duration:    0.5,
        loop:        false,
        tracks:      [],
        description: '',
      }),
    });
    if (!res.ok) {
      const err = await res.text();
      console.warn('add-anim failed:', err);
      toast('✕ ἀποτυχία δημιουργίας', 'error');
      return;
    }
    const rec = await res.json();
    State.animations[rec.anim_name] = {
      duration: rec.duration, loop: !!rec.loop, tracks: rec.tracks || [],
    };
    State.animRecordId[rec.anim_name] = rec.id;
    State.selected = { anim: rec.anim_name, trackIdx: -1, prop: null, kfIdx: -1 };
    renderAll();
    toast(`✓ νέα animation · ${rec.anim_name}`);
  } catch (e) {
    console.warn(e);
    toast('✕ δίκτυο: ' + e.message, 'error');
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = '+ νέα animation'; }
  }
}

async function deleteSelectedAnimation() {
  const name = State.selected.anim;
  if (!name) return;
  const recId = State.animRecordId[name];
  if (!recId) { toast('✕ λείπει record id', 'error'); return; }
  if (!confirm(`Διαγραφὴ animation "${name}";\nἈμετάκλητο.`)) return;
  try {
    const res = await fetch(`${PB_URL}/api/collections/church_animations/records/${recId}`, {
      method: 'DELETE', headers: authHeader(),
    });
    if (!res.ok && res.status !== 204) {
      const err = await res.text();
      console.warn('delete-anim failed:', err);
      toast('✕ ἀποτυχία διαγραφῆς', 'error');
      return;
    }
    delete State.animations[name];
    delete State.animRecordId[name];
    State.dirtyAnims.delete(name);
    // Pick another animation (or none) and refresh
    const next = Object.keys(State.animations)[0] || null;
    State.selected = { anim: next, trackIdx: -1, prop: null, kfIdx: -1 };
    renderAll();
    toast(`✓ διαγράφηκε · ${name}`);
  } catch (e) {
    console.warn(e);
    toast('✕ δίκτυο: ' + e.message, 'error');
  }
}

async function duplicateSelectedAnimation() {
  const name = State.selected.anim;
  if (!name || !State.animations[name]) return;
  // Find an available "-copy" name (append a numeric suffix if needed)
  let dupName = name + '-copy';
  let n = 2;
  while (State.animations[dupName]) { dupName = name + '-copy-' + n; n++; }
  const src = State.animations[name];
  try {
    const res = await fetch(`${PB_URL}/api/collections/church_animations/records`, {
      method:  'POST',
      headers: authHeader({ 'Content-Type': 'application/json' }),
      body:    JSON.stringify({
        anim_name:   dupName,
        duration:    src.duration,
        loop:        !!src.loop,
        tracks:      deepClone(src.tracks || []),
        description: '',
      }),
    });
    if (!res.ok) {
      const err = await res.text();
      console.warn('duplicate-anim failed:', err);
      toast('✕ ἀποτυχία ἀντιγραφῆς', 'error');
      return;
    }
    const rec = await res.json();
    State.animations[rec.anim_name] = {
      duration: rec.duration, loop: !!rec.loop, tracks: rec.tracks || [],
    };
    State.animRecordId[rec.anim_name] = rec.id;
    State.selected = { anim: rec.anim_name, trackIdx: -1, prop: null, kfIdx: -1 };
    renderAll();
    toast(`✓ ἀντίγραφο · ${rec.anim_name}`);
  } catch (e) {
    console.warn(e);
    toast('✕ δίκτυο: ' + e.message, 'error');
  }
}

// Animation tab UI is gone — these buttons no longer exist in the DOM.
// Guard with ?. so the legacy handlers don't crash at module init.
document.getElementById('add-anim-btn')?.addEventListener('click',       addNewAnimation);
document.getElementById('anim-delete-btn')?.addEventListener('click',    deleteSelectedAnimation);
document.getElementById('anim-duplicate-btn')?.addEventListener('click', duplicateSelectedAnimation);

// =====================================================================
//   TAB SWITCHING
// =====================================================================
function setActiveTab(tab) {
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
  document.getElementById('view-content').classList.toggle('hidden',    tab !== 'content');
  document.getElementById('view-animations').classList.toggle('hidden', tab !== 'animations');
  State.activeTab = tab;
}
// (tabs removed — single content view)

// =====================================================================
//   INIT — extend renderAll to refresh both views, set up content wiring
// =====================================================================
const _origRenderAll = renderAll;
renderAll = function () {
  _origRenderAll();
  renderPagesList();
  renderContentForm();
};

async function init() {
  wireContentFields();          // wire BEFORE load so the input listeners exist for the first render
  await load();
  const first = Object.keys(State.animations)[0];
  if (first) State.selected.anim = first;
  if (PAGES_DEFAULT[0]) State.selectedPageId = PAGES_DEFAULT[0].id;
  refreshSaveBtn();
  refreshUndoBtns();
  renderAll();
}

if (isAuthed()) { showApp(); init(); }
else            { showLogin(); }
</script>
</body>
