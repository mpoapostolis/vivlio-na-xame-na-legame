<!--
  auto-animate — FLIP-based mutation observer that animates list reorders,
  inserts, and removes with no per-item bookkeeping. Loaded as a module
  from esm.sh; runs after the main inline script has rendered the list.
-->
<script is:inline type="module">
  import autoAnimate from 'https://esm.sh/@formkit/auto-animate@0.8.2';
  // The list element is in the static markup, so it always exists by the
  // time this module runs. Subsequent renderPagesList() calls reuse DOM
  // identities, which is exactly what auto-animate needs to detect moves.
  const list = document.getElementById('pages-list');
  if (list) autoAnimate(list, { duration: 260, easing: 'ease-out' });
</script>

<script is:inline>
'use strict';

// =====================================================================
//   DEFAULT ANIMATIONS — what /book uses if localStorage is empty.
//   These drive DOM elements inside the photo modal (HTML target mode).
// =====================================================================
const DEFAULT_ANIMATIONS = {
  // When a photo opens, the image scales up + rotates slightly + fades in.
  photoModalOpen: {
    duration: 0.7,
    tracks: [
      { target: 'modalImg',
        properties: {
          scale: [
            { t: 0.0,  value: 0.65,  ease: 'easeOutBack' },
            { t: 0.78, value: 1.04 },
            { t: 1.0,  value: 1.00 },
          ],
          rotation: [
            { t: 0.0,  value: -0.035, ease: 'easeOutCubic' },
            { t: 0.55, value: 0.008 },
            { t: 1.0,  value: 0 },
          ],
          opacity: [
            { t: 0.0,  value: 0, ease: 'easeOutCubic' },
            { t: 0.45, value: 1 },
            { t: 1.0,  value: 1 },
          ],
        }
      },
      { target: 'modalInfo',
        properties: {
          translateX: [
            { t: 0.0, value: 40, ease: 'easeOutCubic' },
            { t: 0.3, value: 40 },
            { t: 1.0, value: 0 },
          ],
          opacity: [
            { t: 0.0, value: 0 },
            { t: 0.3, value: 0, ease: 'easeOutCubic' },
            { t: 1.0, value: 1 },
          ],
        }
      },
    ],
  },

  // Closing — quick fade-out + slight scale-down.
  photoModalClose: {
    duration: 0.35,
    tracks: [
      { target: 'modalImg',
        properties: {
          scale:    [{ t: 0.0, value: 1.0, ease: 'easeInCubic' }, { t: 1.0, value: 0.85 }],
          opacity:  [{ t: 0.0, value: 1.0, ease: 'easeInCubic' }, { t: 1.0, value: 0 }],
        }
      },
      { target: 'modalInfo',
        properties: {
          translateX: [{ t: 0.0, value: 0, ease: 'easeInCubic' }, { t: 1.0, value: 30 }],
          opacity:    [{ t: 0.0, value: 1, ease: 'easeInCubic' }, { t: 1.0, value: 0 }],
        }
      },
    ],
  },
};

// =====================================================================
//   STATE
