            </label>
            <label class="field-lock"><input type="checkbox" data-lock="lead"> 🔒</label>
          </div>
          <div class="field-row">
            <label>Παράγραφος (markdown)
              <div class="md-editor" data-md="body">
                <div class="md-toolbar">
